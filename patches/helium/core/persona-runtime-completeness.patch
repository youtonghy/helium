+blink::HeliumPersonaSnapshot GetHeliumPersonaSnapshotForFrameTreeNode(
+    FrameTreeNode* frame_tree_node) {
+  if (!frame_tree_node) {
+    return blink::HeliumPersonaSnapshot();
+  }
+  return GetContentClient()->browser()->GetHeliumPersonaSnapshot(
+      frame_tree_node->navigator().controller().GetBrowserContext());
+}
+
+blink::HeliumPersonaSnapshot GetHeliumPersonaSnapshotForContext(
+    BrowserContext* browser_context,
+    FrameTreeNode* frame_tree_node) {
+  if (frame_tree_node) {
+    return GetHeliumPersonaSnapshotForFrameTreeNode(frame_tree_node);
+  }
+  if (!browser_context) {
+    return blink::HeliumPersonaSnapshot();
+  }
+  return GetContentClient()->browser()->GetHeliumPersonaSnapshot(
+      browser_context);
+}
+
+void ApplyPersonaUserAgentMetadata(
+    const blink::HeliumPersonaSnapshot& persona_snapshot,
+    blink::UserAgentMetadata* ua_metadata) {
+  if (!ua_metadata || !persona_snapshot.IsEnabled() ||
+      !persona_snapshot.client_hints_enabled) {
+    return;
+  }
+  ua_metadata->mobile = persona_snapshot.ua_ch_mobile;
+  if (!persona_snapshot.ua_ch_platform.empty()) {
+    ua_metadata->platform = persona_snapshot.ua_ch_platform;
+  }
+  if (!persona_snapshot.ua_ch_platform_version.empty()) {
+    ua_metadata->platform_version = persona_snapshot.ua_ch_platform_version;
+  }
+  if (!persona_snapshot.ua_ch_architecture.empty()) {
+    ua_metadata->architecture = persona_snapshot.ua_ch_architecture;
+  }
+  if (!persona_snapshot.ua_ch_model.empty()) {
+    ua_metadata->model = persona_snapshot.ua_ch_model;
+  }
+  if (!persona_snapshot.ua_ch_bitness.empty()) {
+    ua_metadata->bitness = persona_snapshot.ua_ch_bitness;
+  }
+  if (!persona_snapshot.ua_ch_full_version.empty()) {
+    ua_metadata->full_version = persona_snapshot.ua_ch_full_version;
+    ua_metadata->brand_full_version_list = ua_metadata->brand_version_list;
+    for (blink::UserAgentBrandVersion& brand_version :
+         ua_metadata->brand_full_version_list) {
+      if (brand_version.brand != "Not_A Brand") {
+        brand_version.version = persona_snapshot.ua_ch_full_version;
+      }
+    }
+  }
+  ua_metadata->wow64 = persona_snapshot.ua_ch_wow64;
+  if (!persona_snapshot.ua_ch_form_factors.empty()) {
+    ua_metadata->form_factors = persona_snapshot.ua_ch_form_factors;
+  } else {
+    ua_metadata->form_factors = {
+        persona_snapshot.ua_ch_mobile ? "Mobile" : "Desktop"};
+  }
+}
