+void AddPersonaDeviceMemoryHeader(
+    net::HttpRequestHeaders* headers,
+    const blink::HeliumPersonaSnapshot& persona_snapshot,
+    bool use_deprecated_version = false) {
+  if (persona_snapshot.device_memory <= 0) {
+    AddDeviceMemoryHeader(headers, use_deprecated_version);
+    return;
+  }
+  SetHeaderToDouble(headers,
+                    use_deprecated_version
+                        ? WebClientHintsType::kDeviceMemory_DEPRECATED
+                        : WebClientHintsType::kDeviceMemory,
+                    persona_snapshot.device_memory);
+}
+
+void AddPersonaDPRHeader(net::HttpRequestHeaders* headers,
+                         BrowserContext* context,
+                         const GURL& url,
+                         const blink::HeliumPersonaSnapshot& persona_snapshot,
+                         bool use_deprecated_version = false) {
+  if (persona_snapshot.device_scale_factor <= 0) {
+    AddDPRHeader(headers, context, url, use_deprecated_version);
+    return;
+  }
+  SetHeaderToDouble(headers,
+                    use_deprecated_version
+                        ? WebClientHintsType::kDpr_DEPRECATED
+                        : WebClientHintsType::kDpr,
+                    persona_snapshot.device_scale_factor);
+}
