+class HeliumPersonaRuntimeOverride final {
+ public:
+  HeliumPersonaRuntimeOverride() = default;
+  HeliumPersonaRuntimeOverride(const HeliumPersonaRuntimeOverride&) = delete;
+  HeliumPersonaRuntimeOverride& operator=(const HeliumPersonaRuntimeOverride&) =
+      delete;
+  ~HeliumPersonaRuntimeOverride() {
+    ResetLocale();
+    timezone_override_.reset();
+  }
+
+  void Apply(const HeliumPersonaSnapshot& snapshot) {
+    ApplyTimezone(snapshot);
+    ApplyLocale(snapshot);
+  }
+
+ private:
+  void ApplyTimezone(const HeliumPersonaSnapshot& snapshot) {
+    if (!snapshot.IsEnabled() || snapshot.timezone.empty()) {
+      timezone_override_.reset();
+      return;
+    }
+
+    String timezone = String::FromUTF8(snapshot.timezone);
+    if (timezone_override_) {
+      timezone_override_->change(timezone);
+      return;
+    }
+
+    auto result = TimeZoneController::SetTimeZoneOverride(timezone);
+    if (result.status == TimeZoneController::TimeZoneOverrideStatus::kSuccess) {
+      timezone_override_ = std::move(result.handle);
+    }
+  }
+
+  void ApplyLocale(const HeliumPersonaSnapshot& snapshot) {
+    if (!snapshot.IsEnabled() || snapshot.locale.empty()) {
+      ResetLocale();
+      return;
+    }
+
+    String locale = String::FromUTF8(snapshot.locale);
+    String error = LocaleController::instance().SetLocaleOverride(
+        locale, !locale_override_active_);
+    if (error.empty()) {
+      locale_override_active_ = true;
+    }
+  }
+
+  void ResetLocale() {
+    if (!locale_override_active_) {
+      return;
+    }
+    LocaleController::instance().SetLocaleOverride(String(), false);
+    locale_override_active_ = false;
+  }
+
+  std::unique_ptr<TimeZoneController::TimeZoneOverride> timezone_override_;
+  bool locale_override_active_ = false;
+};
