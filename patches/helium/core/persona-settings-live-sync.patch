+void WebContentsImpl::UpdateHeliumPersonaSnapshot(
+    const blink::HeliumPersonaSnapshot& snapshot) {
+  ForEachFrameTree([&snapshot](FrameTree& frame_tree) {
+    frame_tree.root()->current_frame_host()->GetPage().set_persona_snapshot(
+        snapshot);
+    frame_tree.root()->render_manager()->ExecutePageBroadcastMethod(
+        [&snapshot](RenderViewHostImpl* rvh) {
+          if (auto& broadcast = rvh->GetAssociatedPageBroadcast()) {
+            broadcast->UpdateHeliumPersonaSnapshot(snapshot);
+          }
+        });
+  });
+}
