+
+void HeliumPersonaHandler::BroadcastActivePersonaSnapshot() {
+  blink::HeliumPersonaSnapshot snapshot =
+      content::GetContentClient()->browser()->GetHeliumPersonaSnapshot(
+          profile_);
+
+  tabs::ForEachTabInterface([this, &snapshot](tabs::TabInterface* tab) {
+    if (tab->GetProfile() != profile_) {
+      return true;
+    }
+    if (content::WebContents* contents = tab->GetContents()) {
+      contents->UpdateHeliumPersonaSnapshot(snapshot);
+    }
+    return true;
+  });
+}
