 std::string ProfileNetworkContextService::ComputeAcceptLanguage() const {
+  helium_persona::PersonaSnapshot persona_snapshot =
+      helium_persona::MakePersonaSnapshot(*profile_->GetPrefs());
+  if (!persona_snapshot.passthrough) {
+    if (!persona_snapshot.accept_language.empty()) {
+      return persona_snapshot.accept_language;
+    }
+    if (!persona_snapshot.navigator_languages.empty()) {
+      return ComputeAcceptLanguageFromPref(
+          base::JoinString(persona_snapshot.navigator_languages, ","));
+    }
+    if (!persona_snapshot.locale.empty()) {
+      return ComputeAcceptLanguageFromPref(persona_snapshot.locale);
+    }
+  }
+
