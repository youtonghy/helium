+gfx::FontRenderParams::Hinting HeliumPersonaHintingToRendererHinting(
+    const std::string& hinting) {
+  if (base::EqualsCaseInsensitiveASCII(hinting, "none")) {
+    return gfx::FontRenderParams::HINTING_NONE;
+  }
+  if (base::EqualsCaseInsensitiveASCII(hinting, "slight")) {
+    return gfx::FontRenderParams::HINTING_SLIGHT;
+  }
+  if (base::EqualsCaseInsensitiveASCII(hinting, "full")) {
+    return gfx::FontRenderParams::HINTING_FULL;
+  }
+  return gfx::FontRenderParams::HINTING_MEDIUM;
+}
+
+void ApplyHeliumPersonaFontRenderingPreferences(
+    const helium_persona::PersonaSnapshot& persona_snapshot,
+    blink::RendererPreferences* prefs) {
+  if (persona_snapshot.font_rendering_id.empty()) {
+    return;
+  }
+
+  prefs->should_antialias_text = persona_snapshot.font_antialiasing;
+  prefs->hinting = HeliumPersonaHintingToRendererHinting(
+      persona_snapshot.font_rendering_hinting);
+  prefs->subpixel_rendering =
+      persona_snapshot.font_subpixel_rendering || persona_snapshot.font_lcd_text
+          ? gfx::FontRenderParams::SUBPIXEL_RENDERING_RGB
+          : gfx::FontRenderParams::SUBPIXEL_RENDERING_NONE;
+  prefs->use_subpixel_positioning =
+      persona_snapshot.font_subpixel_positioning;
+  prefs->use_autohinter = persona_snapshot.font_use_autohinter;
+  prefs->use_bitmaps = persona_snapshot.font_use_bitmaps;
+  if (persona_snapshot.font_text_gamma > 0) {
+    prefs->text_gamma = persona_snapshot.font_text_gamma;
+  }
+  if (persona_snapshot.font_text_contrast >= 0) {
+    prefs->text_contrast = persona_snapshot.font_text_contrast;
+  }
+}
+
 }  // namespace
 
