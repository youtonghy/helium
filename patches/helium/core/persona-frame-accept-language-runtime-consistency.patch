@@ -1509,6 +1509,21 @@ String FrameFetchContext::GetReducedAcceptLanguage() const {
   String override_accept_language;
   probe::ApplyAcceptLanguageOverride(Probe(), &override_accept_language);
   if (override_accept_language.empty()) {
+    if (const HeliumPersonaSnapshot* snapshot =
+            PersonaSpoofingHelper::Get(GetExecutionContext())) {
+      if (!snapshot->accept_language.empty()) {
+        return String::FromUtf8(snapshot->accept_language);
+      }
+      if (!snapshot->navigator_languages.empty()) {
+        return network_utils::GenerateAcceptLanguageHeader(String::FromUtf8(
+            base::JoinString(snapshot->navigator_languages, ",")));
+      }
+      if (!snapshot->locale.empty()) {
+        return network_utils::GenerateAcceptLanguageHeader(
