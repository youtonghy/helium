+
+std::string GetString(const base::Value::Dict& dict, const char* key) {
+  const std::string* value = dict.FindString(key);
+  return value ? *value : std::string();
+}
+
+std::string GetNestedString(const base::Value::Dict& dict,
+                            const char* object_key,
+                            const char* key) {
+  const base::Value::Dict* object = dict.FindDict(object_key);
+  return object ? GetString(*object, key) : std::string();
+}
+
+int GetNestedInt(const base::Value::Dict& dict,
+                 const char* object_key,
+                 const char* key) {
+  const base::Value::Dict* object = dict.FindDict(object_key);
+  return object ? object->FindInt(key).value_or(0) : 0;
+}
+
+double GetNestedDouble(const base::Value::Dict& dict,
+                       const char* object_key,
+                       const char* key) {
+  const base::Value::Dict* object = dict.FindDict(object_key);
+  if (!object) {
+    return 0;
+  }
+  if (std::optional<double> value = object->FindDouble(key)) {
+    return *value;
+  }
+  return object->FindInt(key).value_or(0);
+}
+
+bool GetNestedBool(const base::Value::Dict& dict,
+                   const char* object_key,
+                   const char* key,
+                   bool default_value) {
+  const base::Value::Dict* object = dict.FindDict(object_key);
+  if (!object) {
+    return default_value;
+  }
+  return object->FindBool(key).value_or(default_value);
+}
+
+std::vector<std::string> GetStringList(const base::Value::Dict& dict,
+                                       const char* object_key,
+                                       const char* key) {
+  std::vector<std::string> output;
+  const base::Value::Dict* object = dict.FindDict(object_key);
+  const base::Value::List* list = object ? object->FindList(key) : nullptr;
+  if (!list) {
+    return output;
+  }
+  for (const base::Value& value : *list) {
+    if (const std::string* item = value.GetIfString()) {
+      output.push_back(*item);
+    }
+  }
+  return output;
+}
+
+base::Value::List MakeStringList(const std::vector<std::string>& values) {
+  base::Value::List output;
+  for (const std::string& value : values) {
+    output.Append(value);
+  }
+  return output;
+}
+
+}  // namespace
+
+PersonaSnapshot MakePersonaSnapshot(const PrefService& pref_service) {
+  return MakePersonaSnapshot(GetActivePersona(pref_service));
+}
+
+PersonaSnapshot MakePersonaSnapshot(const base::Value::Dict& persona) {
+  PersonaSnapshot snapshot;
+  snapshot.id = GetString(persona, "id");
+  snapshot.name = GetString(persona, "name");
+  snapshot.device = GetString(persona, "device");
+  snapshot.os = GetString(persona, "os");
+  snapshot.user_agent = GetString(persona, "userAgent");
+  snapshot.platform = GetString(persona, "platform");
+  snapshot.passthrough = persona.FindBool("passthrough").value_or(false);
+
+  snapshot.ua_ch_platform = GetNestedString(persona, "uaCh", "platform");
+  snapshot.ua_ch_platform_version =
+      GetNestedString(persona, "uaCh", "platformVersion");
+  snapshot.ua_ch_architecture =
+      GetNestedString(persona, "uaCh", "architecture");
+  snapshot.ua_ch_bitness = GetNestedString(persona, "uaCh", "bitness");
+  snapshot.ua_ch_model = GetNestedString(persona, "uaCh", "model");
+  snapshot.ua_ch_mobile = GetNestedBool(persona, "uaCh", "mobile", false);
+
+  snapshot.timezone = GetNestedString(persona, "region", "timezone");
+  snapshot.locale = GetNestedString(persona, "region", "locale");
+  snapshot.accept_language =
+      GetNestedString(persona, "region", "acceptLanguage");
+  snapshot.navigator_languages =
+      GetStringList(persona, "region", "navigatorLanguages");
+
+  snapshot.gpu_vendor = GetNestedString(persona, "gpu", "vendor");
+  snapshot.gpu_renderer = GetNestedString(persona, "gpu", "renderer");
+  snapshot.webgpu_adapter = GetNestedString(persona, "gpu", "webgpuAdapter");
+  snapshot.gpu_driver = GetNestedString(persona, "gpu", "driver");
+
+  snapshot.screen_width = GetNestedInt(persona, "screen", "width");
+  snapshot.screen_height = GetNestedInt(persona, "screen", "height");
+  snapshot.avail_width = GetNestedInt(persona, "screen", "availWidth");
+  snapshot.avail_height = GetNestedInt(persona, "screen", "availHeight");
+  snapshot.device_scale_factor =
+      GetNestedDouble(persona, "screen", "deviceScaleFactor");
+  snapshot.color_depth = GetNestedInt(persona, "screen", "colorDepth");
+  snapshot.pixel_depth = GetNestedInt(persona, "screen", "pixelDepth");
+  snapshot.refresh_rate = GetNestedInt(persona, "screen", "refreshRate");
+
+  snapshot.hardware_concurrency =
+      GetNestedInt(persona, "hardware", "hardwareConcurrency");
+  snapshot.device_memory = GetNestedDouble(persona, "hardware", "deviceMemory");
+  snapshot.touch_enabled =
+      GetNestedBool(persona, "hardware", "touchEnabled", false);
+  snapshot.max_touch_points =
+      GetNestedInt(persona, "hardware", "maxTouchPoints");
+
+  snapshot.font_pack_id = GetNestedString(persona, "fonts", "id");
+  snapshot.font_pack_name = GetNestedString(persona, "fonts", "displayName");
+  snapshot.font_families = GetStringList(persona, "fonts", "families");
+  snapshot.font_aliases = GetStringList(persona, "fonts", "aliases");
+
+  snapshot.client_hints_enabled =
+      GetNestedBool(persona, "advanced", "clientHintsEnabled", true);
+  snapshot.reduce_system_info =
+      GetNestedBool(persona, "advanced", "reduceSystemInfo", false);
+  snapshot.canvas_noise =
+      GetNestedBool(persona, "advanced", "canvasNoise", true);
+  snapshot.audio_noise =
+      GetNestedBool(persona, "advanced", "audioNoise", true);
+  snapshot.font_metric_noise =
+      GetNestedBool(persona, "advanced", "fontMetricNoise", true);
+  return snapshot;
+}
+
+base::Value::Dict PersonaSnapshotToValue(const PersonaSnapshot& snapshot) {
+  base::Value::Dict value;
+  value.Set("id", snapshot.id);
+  value.Set("name", snapshot.name);
+  value.Set("device", snapshot.device);
+  value.Set("os", snapshot.os);
+  value.Set("userAgent", snapshot.user_agent);
+  value.Set("platform", snapshot.platform);
+  value.Set("passthrough", snapshot.passthrough);
+
+  base::Value::Dict ua_ch;
+  ua_ch.Set("platform", snapshot.ua_ch_platform);
+  ua_ch.Set("platformVersion", snapshot.ua_ch_platform_version);
+  ua_ch.Set("architecture", snapshot.ua_ch_architecture);
+  ua_ch.Set("bitness", snapshot.ua_ch_bitness);
+  ua_ch.Set("model", snapshot.ua_ch_model);
+  ua_ch.Set("mobile", snapshot.ua_ch_mobile);
+  value.Set("uaCh", std::move(ua_ch));
+
+  base::Value::Dict region;
+  region.Set("timezone", snapshot.timezone);
+  region.Set("locale", snapshot.locale);
+  region.Set("acceptLanguage", snapshot.accept_language);
+  region.Set("navigatorLanguages", MakeStringList(snapshot.navigator_languages));
+  value.Set("region", std::move(region));
+
+  base::Value::Dict gpu;
+  gpu.Set("vendor", snapshot.gpu_vendor);
+  gpu.Set("renderer", snapshot.gpu_renderer);
+  gpu.Set("webgpuAdapter", snapshot.webgpu_adapter);
+  gpu.Set("driver", snapshot.gpu_driver);
+  value.Set("gpu", std::move(gpu));
+
+  base::Value::Dict screen;
+  screen.Set("width", snapshot.screen_width);
+  screen.Set("height", snapshot.screen_height);
+  screen.Set("availWidth", snapshot.avail_width);
+  screen.Set("availHeight", snapshot.avail_height);
+  screen.Set("deviceScaleFactor", snapshot.device_scale_factor);
+  screen.Set("colorDepth", snapshot.color_depth);
+  screen.Set("pixelDepth", snapshot.pixel_depth);
+  screen.Set("refreshRate", snapshot.refresh_rate);
+  value.Set("screen", std::move(screen));
+
+  base::Value::Dict hardware;
+  hardware.Set("hardwareConcurrency", snapshot.hardware_concurrency);
+  hardware.Set("deviceMemory", snapshot.device_memory);
+  hardware.Set("touchEnabled", snapshot.touch_enabled);
+  hardware.Set("maxTouchPoints", snapshot.max_touch_points);
+  value.Set("hardware", std::move(hardware));
+
+  base::Value::Dict fonts;
+  fonts.Set("id", snapshot.font_pack_id);
+  fonts.Set("displayName", snapshot.font_pack_name);
+  fonts.Set("families", MakeStringList(snapshot.font_families));
+  fonts.Set("aliases", MakeStringList(snapshot.font_aliases));
+  value.Set("fonts", std::move(fonts));
+
+  base::Value::Dict advanced;
+  advanced.Set("clientHintsEnabled", snapshot.client_hints_enabled);
+  advanced.Set("reduceSystemInfo", snapshot.reduce_system_info);
+  advanced.Set("canvasNoise", snapshot.canvas_noise);
+  advanced.Set("audioNoise", snapshot.audio_noise);
+  advanced.Set("fontMetricNoise", snapshot.font_metric_noise);
+  value.Set("advanced", std::move(advanced));
+  return value;
+}
+
