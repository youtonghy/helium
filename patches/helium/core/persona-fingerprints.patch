+HeliumPersonaHandler::HeliumPersonaHandler(Profile* profile)
+    : pref_service_(profile->GetPrefs()) {}
+
+HeliumPersonaHandler::~HeliumPersonaHandler() = default;
+
+void HeliumPersonaHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getHeliumPersonaState",
+      base::BindRepeating(&HeliumPersonaHandler::HandleGetState,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "setHeliumActivePersona",
+      base::BindRepeating(&HeliumPersonaHandler::HandleSetActivePersona,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "cloneHeliumPersonaPreset",
+      base::BindRepeating(&HeliumPersonaHandler::HandleClonePreset,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "saveHeliumPersona",
+      base::BindRepeating(&HeliumPersonaHandler::HandleSavePersona,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "deleteHeliumPersona",
+      base::BindRepeating(&HeliumPersonaHandler::HandleDeletePersona,
+                          base::Unretained(this)));
+}
+
+void HeliumPersonaHandler::HandleGetState(const base::ListValue& args) {
+  CHECK_EQ(1U, args.size());
+  const std::string& callback_id = args[0].GetString();
+
+  AllowJavascript();
+  ResolveJavascriptCallback(base::Value(callback_id),
+                            helium_persona::GetPersonaState(*pref_service_));
+}
+
+void HeliumPersonaHandler::HandleSetActivePersona(
+    const base::ListValue& args) {
+  CHECK_EQ(2U, args.size());
+  const std::string& callback_id = args[0].GetString();
+  const std::string& persona_id = args[1].GetString();
+
+  const bool success =
+      helium_persona::SetActivePersona(*pref_service_, persona_id);
+  AllowJavascript();
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(success));
+}
+
+void HeliumPersonaHandler::HandleClonePreset(const base::ListValue& args) {
+  CHECK_EQ(2U, args.size());
+  const std::string& callback_id = args[0].GetString();
+  const std::string& preset_id = args[1].GetString();
+
+  base::Value::Dict persona =
+      helium_persona::ClonePresetIntoProfile(*pref_service_, preset_id);
+  AllowJavascript();
+  ResolveJavascriptCallback(base::Value(callback_id),
+                            base::Value(std::move(persona)));
+}
+
+void HeliumPersonaHandler::HandleSavePersona(const base::ListValue& args) {
+  CHECK_EQ(2U, args.size());
+  const std::string& callback_id = args[0].GetString();
+  const base::Value::Dict* persona = args[1].GetIfDict();
+  if (!persona) {
+    AllowJavascript();
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  const bool success =
+      helium_persona::SavePersona(*pref_service_, persona->Clone());
+  AllowJavascript();
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(success));
+}
+
+void HeliumPersonaHandler::HandleDeletePersona(const base::ListValue& args) {
+  CHECK_EQ(2U, args.size());
+  const std::string& callback_id = args[0].GetString();
+  const std::string& persona_id = args[1].GetString();
+
+  const bool success =
+      helium_persona::DeletePersona(*pref_service_, persona_id);
+  AllowJavascript();
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(success));
+}
