+  grease_brand.Set("brand", "Not_A Brand");
+  grease_brand.Set("version", "24");
+  brands.Append(std::move(grease_brand));
+  ua_ch.Set("brands", std::move(brands));
+  ua_ch.Set("fullVersion", "149.0.7827.114");
+  return ua_ch;
+}
+
+base::Value::Dict MakeRegion(std::string_view timezone,
+                             std::string_view locale,
+                             std::string_view accept_language,
+                             std::initializer_list<std::string_view> languages) {
+  base::Value::Dict region;
+  region.Set("timezone", timezone);
+  region.Set("locale", locale);
+  region.Set("acceptLanguage", accept_language);
+
+  base::Value::List navigator_languages;
+  for (std::string_view language : languages) {
+    navigator_languages.Append(language);
+  }
+  region.Set("navigatorLanguages", std::move(navigator_languages));
+  return region;
+}
