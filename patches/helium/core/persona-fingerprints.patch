+void RegisterTestPrefs(sync_preferences::TestingPrefServiceSyncable& prefs) {
+  RegisterProfilePrefs(prefs.registry());
+}
+
+const base::Value::Dict& DictAt(const base::Value::List& list, size_t index) {
+  const base::Value::Dict* dict = list[index].GetIfDict();
+  CHECK(dict);
+  return *dict;
+}
+
+bool WarningsContain(const base::Value::List& warnings,
+                     std::string_view expected) {
+  for (const base::Value& warning : warnings) {
+    const std::string* text = warning.GetIfString();
+    if (text && text->find(expected) != std::string::npos) {
+      return true;
+    }
+  }
+  return false;
+}
+
+}  // namespace
+
+TEST(HeliumPersonaPrefsTest, BuiltinPresetsContainCompleteSystemImage) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  ASSERT_GE(presets.size(), 5u);
+
+  const base::Value::Dict& windows = DictAt(presets, 1);
+  EXPECT_TRUE(PersonaHasRequiredFields(windows));
+  EXPECT_EQ("Windows 11", *windows.FindString("os"));
+  EXPECT_EQ("Win32", *windows.FindString("platform"));
+
+  const base::Value::Dict* region = windows.FindDict("region");
+  ASSERT_TRUE(region);
+  EXPECT_EQ("America/New_York", *region->FindString("timezone"));
+  EXPECT_EQ("en-US", *region->FindString("locale"));
+
+  const base::Value::Dict* gpu = windows.FindDict("gpu");
+  ASSERT_TRUE(gpu);
+  EXPECT_TRUE(gpu->FindString("renderer"));
+
+  const base::Value::Dict* fonts = windows.FindDict("fonts");
+  ASSERT_TRUE(fonts);
+  const base::Value::List* families = fonts->FindList("families");
+  ASSERT_TRUE(families);
+  EXPECT_FALSE(families->empty());
+
+  const base::Value::Dict& current = DictAt(presets, 0);
+  EXPECT_TRUE(current.FindBool("passthrough").value_or(false));
+  EXPECT_TRUE(PersonaHasRequiredFields(current));
+  EXPECT_TRUE(ValidatePersona(current).empty());
+
+  const base::Value::Dict& macos = DictAt(presets, 2);
+  EXPECT_EQ("arm", *macos.FindDict("uaCh")->FindString("architecture"));
+  EXPECT_EQ(24, macos.FindDict("screen")->FindInt("colorDepth").value_or(0));
+
+  const base::Value::Dict& zh_cn = DictAt(presets, 3);
+  EXPECT_EQ(
+      8, zh_cn.FindDict("hardware")->FindDouble("deviceMemory").value_or(0));
+
+  const base::Value::Dict& linux = DictAt(presets, 4);
+  EXPECT_TRUE(linux.FindDict("uaCh")->FindString("platformVersion")->empty());
+}
+
+TEST(HeliumPersonaPrefsTest, ClonePresetPersistsAndBecomesActive) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
