+base::Value::Dict MakePreset(std::string_view id,
+                             std::string_view name,
+                             std::string_view source,
+                             std::string_view device,
+                             std::string_view os,
+                             std::string_view ua,
+                             std::string_view platform,
+                             base::Value::Dict ua_ch,
+                             base::Value::Dict region,
+                             base::Value::Dict gpu,
+                             base::Value::Dict screen,
+                             base::Value::Dict hardware,
+                             base::Value::Dict fonts,
+                             base::Value::Dict advanced) {
+  base::Value::Dict preset;
+  preset.Set("id", id);
+  preset.Set("name", name);
+  preset.Set("source", source);
+  preset.Set("device", device);
+  preset.Set("os", os);
+  preset.Set("userAgent", ua);
+  preset.Set("platform", platform);
+  preset.Set("uaCh", std::move(ua_ch));
+  preset.Set("region", std::move(region));
+  preset.Set("gpu", std::move(gpu));
+  preset.Set("screen", std::move(screen));
+  preset.Set("hardware", std::move(hardware));
+  preset.Set("fonts", std::move(fonts));
+  preset.Set("advanced", std::move(advanced));
+  preset.Set("builtin", true);
+  preset.Set("modified", false);
+  return preset;
+}
