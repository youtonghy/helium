+namespace helium_persona {
+
+namespace {
+
+std::string MakeCustomPersonaId() {
+  uint64_t token = base::RandUint64();
+  return base::StringPrintf("persona-%s",
+                            base::NumberToString(token).c_str());
+}
+
+std::string GetPersonaId(const base::Value::Dict& persona) {
+  const std::string* id = persona.FindString("id");
+  return id ? *id : std::string();
+}
+
+bool IsPassthroughPersona(const base::Value::Dict& persona) {
+  return persona.FindBool("passthrough").value_or(false);
+}
+
+base::Value::Dict* FindPersonaInList(base::Value::List& personas,
+                                     std::string_view persona_id) {
+  for (base::Value& entry : personas) {
+    base::Value::Dict* dict = entry.GetIfDict();
+    if (!dict) {
+      continue;
+    }
+    const std::string* id = dict->FindString("id");
+    if (id && *id == persona_id) {
+      return dict;
+    }
+  }
+  return nullptr;
+}
+
+const base::Value::Dict* FindPersonaInList(const base::Value::List& personas,
+                                           std::string_view persona_id) {
+  for (const base::Value& entry : personas) {
+    const base::Value::Dict* dict = entry.GetIfDict();
+    if (!dict) {
+      continue;
+    }
+    const std::string* id = dict->FindString("id");
+    if (id && *id == persona_id) {
+      return dict;
+    }
+  }
+  return nullptr;
+}
+
+base::Value::Dict MakeEditablePersona(base::Value::Dict persona) {
+  persona.Set("id", MakeCustomPersonaId());
+  persona.Set("source", "custom");
+  persona.Set("builtin", false);
+  persona.Set("modified", false);
+  persona.Set("created", base::Time::Now().InMillisecondsFSinceUnixEpoch());
+  persona.Set("updated", base::Time::Now().InMillisecondsFSinceUnixEpoch());
+
+  const std::string* preset_name = persona.FindString("name");
+  persona.Set("name", preset_name ? base::StringPrintf("%s copy", preset_name->c_str())
+                                  : "Custom persona");
+  return persona;
+}
+
+base::Value::List CloneUserPersonas(const PrefService& pref_service) {
+  return pref_service.GetList(prefs::kHeliumPersonaRecords).Clone();
+}
+
+base::Value::Dict FindBuiltinPersona(std::string_view persona_id) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  const base::Value::Dict* preset = FindPersonaInList(presets, persona_id);
+  return preset ? preset->Clone() : base::Value::Dict();
+}
+
+bool PersonaExists(const PrefService& pref_service, std::string_view persona_id) {
+  if (persona_id == kDefaultPresetId) {
+    return true;
+  }
+
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  if (FindPersonaInList(presets, persona_id)) {
+    return true;
+  }
+
+  const base::Value::List& personas =
+      pref_service.GetList(prefs::kHeliumPersonaRecords);
+  return FindPersonaInList(personas, persona_id) != nullptr;
+}
+
+base::Value::Dict MakeSnapshotFromPersona(base::Value::Dict persona) {
+  // Runtime consumers should read this single normalized snapshot rather than
+  // reinterpreting presets and custom records independently.
+  persona.Set("snapshotVersion", 1);
+  persona.Set("warnings", ValidatePersona(persona));
+  return persona;
+}
+
+}  // namespace
+
+void RegisterProfilePrefs(user_prefs::PrefRegistrySyncable* registry) {
+  registry->RegisterStringPref(prefs::kHeliumActivePersonaId,
+                               kDefaultPresetId);
+  registry->RegisterListPref(prefs::kHeliumPersonaRecords);
+  registry->RegisterIntegerPref(prefs::kHeliumPersonaRevision, 1);
+  registry->RegisterBooleanPref(prefs::kHeliumPersonaLegacyFlagsMigrated,
+                                false);
+}
+
+base::Value::Dict GetActivePersona(const PrefService& pref_service) {
+  std::string active_id = pref_service.GetString(prefs::kHeliumActivePersonaId);
+
+  const base::Value::List& user_personas =
+      pref_service.GetList(prefs::kHeliumPersonaRecords);
+  if (const base::Value::Dict* persona =
+          FindPersonaInList(user_personas, active_id)) {
+    return persona->Clone();
+  }
+
+  if (base::Value::Dict preset = FindBuiltinPersona(active_id); !preset.empty()) {
+    return preset;
+  }
+
+  return MakeCurrentSystemPreset();
+}
+
+base::Value::Dict GetPersonaState(const PrefService& pref_service) {
+  base::Value::Dict state;
+  state.Set("activePersonaId",
+            pref_service.GetString(prefs::kHeliumActivePersonaId));
+  state.Set("presets", GetBuiltinPersonaPresets());
+  state.Set("personas", CloneUserPersonas(pref_service));
+
+  base::Value::Dict active = GetActivePersona(pref_service);
+  state.Set("activePersona", active.Clone());
+  state.Set("warnings", ValidatePersona(active));
+  state.Set("revision", pref_service.GetInteger(prefs::kHeliumPersonaRevision));
+  return state;
+}
+
+base::Value::Dict ClonePresetIntoProfile(PrefService& pref_service,
+                                         std::string_view preset_id) {
+  base::Value::Dict preset = FindBuiltinPersona(preset_id);
+  if (preset.empty() || IsPassthroughPersona(preset)) {
+    return base::Value::Dict();
+  }
+
+  base::Value::Dict persona = MakeEditablePersona(std::move(preset));
+  std::string persona_id = GetPersonaId(persona);
+
+  base::Value::List personas = CloneUserPersonas(pref_service);
+  personas.Append(persona.Clone());
+  pref_service.SetList(prefs::kHeliumPersonaRecords, std::move(personas));
+  pref_service.SetString(prefs::kHeliumActivePersonaId, persona_id);
+  pref_service.SetInteger(
+      prefs::kHeliumPersonaRevision,
+      pref_service.GetInteger(prefs::kHeliumPersonaRevision) + 1);
+
+  return persona;
+}
+
+bool SetActivePersona(PrefService& pref_service, std::string_view persona_id) {
+  if (!PersonaExists(pref_service, persona_id)) {
+    return false;
+  }
+
+  pref_service.SetString(prefs::kHeliumActivePersonaId,
+                         std::string(persona_id));
+  pref_service.SetInteger(
+      prefs::kHeliumPersonaRevision,
+      pref_service.GetInteger(prefs::kHeliumPersonaRevision) + 1);
+  return true;
+}
+
+bool SavePersona(PrefService& pref_service, base::Value::Dict persona) {
+  if (!PersonaHasRequiredFields(persona) || IsPassthroughPersona(persona)) {
+    return false;
+  }
+
+  std::string id = GetPersonaId(persona);
+  if (id.empty()) {
+    id = MakeCustomPersonaId();
+    persona.Set("id", id);
+  }
+
+  if (FindBuiltinPersona(id).empty() == false) {
+    // Built-in presets are immutable. Saving a built-in id creates a copy.
+    persona.Set("id", MakeCustomPersonaId());
+    id = GetPersonaId(persona);
+  }
+
+  persona.Set("source", "custom");
+  persona.Set("builtin", false);
+  persona.Set("modified", true);
+  persona.Set("updated", base::Time::Now().InMillisecondsFSinceUnixEpoch());
+  persona.Set("warnings", ValidatePersona(persona));
+
+  base::Value::List personas = CloneUserPersonas(pref_service);
+  if (base::Value::Dict* existing = FindPersonaInList(personas, id)) {
+    *existing = std::move(persona);
+  } else {
+    personas.Append(std::move(persona));
+  }
+
+  pref_service.SetList(prefs::kHeliumPersonaRecords, std::move(personas));
+  pref_service.SetString(prefs::kHeliumActivePersonaId, id);
+  pref_service.SetInteger(
+      prefs::kHeliumPersonaRevision,
+      pref_service.GetInteger(prefs::kHeliumPersonaRevision) + 1);
+  return true;
+}
+
+bool DeletePersona(PrefService& pref_service, std::string_view persona_id) {
+  base::Value::List personas = CloneUserPersonas(pref_service);
+  bool removed = false;
+
+  for (auto it = personas.begin(); it != personas.end();) {
+    const base::Value::Dict* dict = it->GetIfDict();
+    const std::string* id = dict ? dict->FindString("id") : nullptr;
+    if (id && *id == persona_id) {
+      it = personas.erase(it);
+      removed = true;
+    } else {
+      ++it;
+    }
+  }
+
+  if (!removed) {
+    return false;
+  }
+
+  pref_service.SetList(prefs::kHeliumPersonaRecords, std::move(personas));
+  if (pref_service.GetString(prefs::kHeliumActivePersonaId) == persona_id) {
+    pref_service.SetString(prefs::kHeliumActivePersonaId, kDefaultPresetId);
+  }
+  pref_service.SetInteger(
+      prefs::kHeliumPersonaRevision,
+      pref_service.GetInteger(prefs::kHeliumPersonaRevision) + 1);
+  return true;
+}
+
+base::Value::Dict MakeRuntimeSnapshot(const PrefService& pref_service) {
+  return MakeSnapshotFromPersona(GetActivePersona(pref_service));
+}
+
+}  // namespace helium_persona
