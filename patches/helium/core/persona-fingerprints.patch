+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import {sendWithPromise} from 'chrome://resources/js/cr.js';
+
+export interface PersonaRecord {
+  id: string;
+  name: string;
+  source: string;
+  device: string;
+  os: string;
+  userAgent: string;
+  platform: string;
+  uaCh: Record<string, unknown>;
+  region: Record<string, unknown>;
+  gpu: Record<string, unknown>;
+  screen: Record<string, unknown>;
+  hardware: Record<string, unknown>;
+  fonts: Record<string, unknown>;
+  advanced: Record<string, unknown>;
+  builtin?: boolean;
+  modified?: boolean;
+  passthrough?: boolean;
+  warnings?: string[];
+}
+
+export interface PersonaState {
+  activePersonaId: string;
+  activePersona: PersonaRecord;
+  presets: PersonaRecord[];
+  personas: PersonaRecord[];
+  warnings: string[];
+  revision: number;
+}
+
+export interface HeliumPersonaBrowserProxy {
+  getState(): Promise<PersonaState>;
+  setActivePersona(personaId: string): Promise<boolean>;
+  clonePreset(presetId: string): Promise<PersonaRecord>;
+  savePersona(persona: PersonaRecord): Promise<boolean>;
+  deletePersona(personaId: string): Promise<boolean>;
+}
+
+export class HeliumPersonaBrowserProxyImpl implements
+    HeliumPersonaBrowserProxy {
+  getState() {
+    return sendWithPromise<PersonaState>('getHeliumPersonaState');
+  }
+
+  setActivePersona(personaId: string) {
+    return sendWithPromise<boolean>('setHeliumActivePersona', personaId);
+  }
+
+  clonePreset(presetId: string) {
+    return sendWithPromise<PersonaRecord>('cloneHeliumPersonaPreset', presetId);
+  }
+
+  savePersona(persona: PersonaRecord) {
+    return sendWithPromise<boolean>('saveHeliumPersona', persona);
+  }
+
+  deletePersona(personaId: string) {
+    return sendWithPromise<boolean>('deleteHeliumPersona', personaId);
+  }
+
+  static getInstance(): HeliumPersonaBrowserProxy {
+    return instance || (instance = new HeliumPersonaBrowserProxyImpl());
+  }
+
+  static setInstance(obj: HeliumPersonaBrowserProxy) {
+    instance = obj;
+  }
+}
+
+let instance: HeliumPersonaBrowserProxy|null = null;
