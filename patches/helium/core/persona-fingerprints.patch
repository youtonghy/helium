+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import '../settings_page/settings_subpage.js';
+import 'chrome://resources/cr_elements/cr_button/cr_button.js';
+import 'chrome://resources/cr_elements/cr_checkbox/cr_checkbox.js';
+import 'chrome://resources/cr_elements/cr_input/cr_input.js';
+
+import {PolymerElement} from 'chrome://resources/polymer/v3_0/polymer/polymer_bundled.min.js';
+
+import type {PersonaRecord, PersonaState} from './persona_browser_proxy.js';
+import {HeliumPersonaBrowserProxyImpl} from './persona_browser_proxy.js';
+import {getTemplate} from './persona_page.html.js';
+
+export class SettingsHeliumPersonaPageElement extends PolymerElement {
+  static get is() {
+    return 'settings-helium-persona-page';
+  }
+
+  static get template() {
+    return getTemplate();
+  }
+
+  static get properties() {
+    return {
+      routePath: String,
+      presets_: Array,
+      personas_: Array,
+      personaOptions_: Array,
+      editablePersona_: Object,
+      activePersonaId_: String,
+      activePersonaSummary_: String,
+      warnings_: Array,
+      navigatorLanguagesText_: String,
+      fontFamiliesText_: String,
+      fontAliasesText_: String,
+    };
+  }
+
+  declare routePath: string;
+  declare private presets_: PersonaRecord[];
+  declare private personas_: PersonaRecord[];
+  declare private personaOptions_: PersonaRecord[];
+  declare private editablePersona_: PersonaRecord;
+  declare private activePersonaId_: string;
+  declare private activePersonaSummary_: string;
+  declare private warnings_: string[];
+  declare private navigatorLanguagesText_: string;
+  declare private fontFamiliesText_: string;
+  declare private fontAliasesText_: string;
+
+  private browserProxy_ = HeliumPersonaBrowserProxyImpl.getInstance();
+
+  override connectedCallback() {
+    super.connectedCallback();
+    this.loadState_();
+  }
+
+  private async loadState_() {
+    const state = await this.browserProxy_.getState();
+    this.applyState_(state);
+  }
+
+  private applyState_(state: PersonaState) {
+    this.presets_ = state.presets || [];
+    this.personas_ = state.personas || [];
+    this.personaOptions_ = [...this.presets_, ...this.personas_];
+    this.activePersonaId_ = state.activePersonaId || state.activePersona?.id || '';
+    this.editablePersona_ = this.clonePersona_(state.activePersona);
+    this.activePersonaSummary_ = this.formatPersonaSummary_(this.editablePersona_);
+    this.warnings_ = state.warnings || [];
+    this.syncTextFields_();
+  }
+
+  private clonePersona_(persona: PersonaRecord): PersonaRecord {
+    return JSON.parse(JSON.stringify(persona || {}));
+  }
+
+  private syncTextFields_() {
+    const region = this.editablePersona_.region || {};
+    const languages = region['navigatorLanguages'] as string[]|undefined;
+    this.navigatorLanguagesText_ = (languages || []).join(', ');
+
+    const fonts = this.editablePersona_.fonts || {};
+    this.fontFamiliesText_ = ((fonts['families'] as string[]|undefined) || [])
+        .join(', ');
+    this.fontAliasesText_ = ((fonts['aliases'] as string[]|undefined) || [])
+        .join(', ');
+  }
+
+  private stringListFromInput_(value: string): string[] {
+    return value.split(',')
+        .map(item => item.trim())
+        .filter(item => item.length > 0);
+  }
+
+  private onNavigatorLanguagesChanged_() {
+    this.set(
+        'editablePersona_.region.navigatorLanguages',
+        this.stringListFromInput_(this.navigatorLanguagesText_));
+  }
+
+  private onFontFamiliesChanged_() {
+    this.set(
+        'editablePersona_.fonts.families',
+        this.stringListFromInput_(this.fontFamiliesText_));
+  }
+
+  private onFontAliasesChanged_() {
+    this.set(
+        'editablePersona_.fonts.aliases',
+        this.stringListFromInput_(this.fontAliasesText_));
+  }
+
+  private formatRegion_(persona: PersonaRecord): string {
+    const region = persona.region || {};
+    return [
+      region['locale'] || '',
+      region['timezone'] || '',
+    ].filter(Boolean).join(' / ');
+  }
+
+  private formatPersonaSummary_(persona: PersonaRecord): string {
+    return [
+      persona.device || '',
+      persona.os || '',
+      this.formatRegion_(persona),
+    ].filter(Boolean).join(' / ');
+  }
+
+  private isActiveOption_(optionId: string, activePersonaId: string): boolean {
+    return optionId === activePersonaId;
+  }
+
+  private isPassthroughPersona_(persona: PersonaRecord): boolean {
+    return Boolean(persona?.passthrough);
+  }
+
+  private async onActivePersonaChanged_(event: Event) {
+    const select = event.target as HTMLSelectElement;
+    if (!select.value) {
+      return;
+    }
+    await this.browserProxy_.setActivePersona(select.value);
+    await this.loadState_();
+  }
+
+  private async onUsePresetClick_(event: Event) {
+    const model = (event as CustomEvent).model;
+    const preset = model.preset as PersonaRecord;
+    await this.browserProxy_.setActivePersona(preset.id);
+    await this.loadState_();
+  }
+
+  private async onClonePresetClick_(event: Event) {
+    const model = (event as CustomEvent).model;
+    const preset = model.preset as PersonaRecord;
+    if (this.isPassthroughPersona_(preset)) {
+      return;
+    }
+    await this.browserProxy_.clonePreset(preset.id);
+    await this.loadState_();
+  }
+
+  private async onUsePersonaClick_(event: Event) {
+    const model = (event as CustomEvent).model;
+    const persona = model.persona as PersonaRecord;
+    await this.browserProxy_.setActivePersona(persona.id);
+    await this.loadState_();
+  }
+
+  private async onDeletePersonaClick_(event: Event) {
+    const model = (event as CustomEvent).model;
+    const persona = model.persona as PersonaRecord;
+    await this.browserProxy_.deletePersona(persona.id);
+    await this.loadState_();
+  }
+
+  private ensureEditableShape_(persona: PersonaRecord) {
+    persona.uaCh = persona.uaCh || {};
+    persona.region = persona.region || {};
+    persona.gpu = persona.gpu || {};
+    persona.hardware = persona.hardware || {};
+    persona.screen = persona.screen || {};
+    persona.fonts = persona.fonts || {};
+    persona.advanced = persona.advanced || {};
+  }
+
+  private normalizeNumbers_(persona: PersonaRecord) {
+    this.ensureEditableShape_(persona);
+    const toNumber = (value: unknown) => Number(value || 0);
+    persona.hardware['hardwareConcurrency'] =
+        toNumber(persona.hardware['hardwareConcurrency']);
+    persona.hardware['deviceMemory'] =
+        toNumber(persona.hardware['deviceMemory']);
+    persona.hardware['maxTouchPoints'] =
+        toNumber(persona.hardware['maxTouchPoints']);
+    persona.hardware['touchEnabled'] = Boolean(persona.hardware['touchEnabled']);
+    persona.uaCh['mobile'] = Boolean(persona.uaCh['mobile']);
+    persona.screen['width'] = toNumber(persona.screen['width']);
+    persona.screen['height'] = toNumber(persona.screen['height']);
+    persona.screen['availWidth'] = toNumber(persona.screen['availWidth']);
+    persona.screen['availHeight'] = toNumber(persona.screen['availHeight']);
+    persona.screen['deviceScaleFactor'] =
+        toNumber(persona.screen['deviceScaleFactor']);
+    persona.screen['colorDepth'] = toNumber(persona.screen['colorDepth']);
+    persona.screen['pixelDepth'] = toNumber(persona.screen['pixelDepth']);
+    persona.screen['refreshRate'] = toNumber(persona.screen['refreshRate']);
+  }
+
+  private async onSaveClick_() {
+    const persona = this.clonePersona_(this.editablePersona_);
+    this.normalizeNumbers_(persona);
+    await this.browserProxy_.savePersona(persona);
+    await this.loadState_();
+  }
+}
+
+declare global {
+  interface HTMLElementTagNameMap {
+    'settings-helium-persona-page': SettingsHeliumPersonaPageElement;
+  }
+}
+
+customElements.define(
+    SettingsHeliumPersonaPageElement.is, SettingsHeliumPersonaPageElement);
