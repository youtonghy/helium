+  ua_ch.Set("platform", platform);
+  ua_ch.Set("platformVersion", platform_version);
+  ua_ch.Set("architecture", architecture);
+  ua_ch.Set("bitness", bitness);
+  ua_ch.Set("model", model);
+  ua_ch.Set("mobile", mobile);
+
+  base::Value::List brands;
+  base::Value::Dict chromium_brand;
+  chromium_brand.Set("brand", "Chromium");
+  chromium_brand.Set("version", "149");
+  brands.Append(std::move(chromium_brand));
+  base::Value::Dict chrome_brand;
+  chrome_brand.Set("brand", "Google Chrome");
+  chrome_brand.Set("version", "149");
