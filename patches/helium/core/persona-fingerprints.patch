+base::Value::Dict MakeCurrentSystemPreset() {
+  base::Value::Dict preset = MakePreset(
+      kDefaultPresetId,
+      "Current device passthrough",
+      "builtin",
+      "No spoofed device",
+      "No spoofed OS",
+      "",
+      "",
+      MakeUaCh("", "", "", "", "", false),
+      MakeRegion("", "", "", {}),
+      MakeGpu("", "", "", ""),
+      MakeScreen(0, 0, 0, 0, 0, 0, 0),
+      MakeHardware(0, 0, false, 0),
+      MakeFontPack("current-system", "Current installed fonts", {}, {}),
+      MakeAdvanced(true, false, true, true, true));
+  preset.Set("passthrough", true);
+  return preset;
+}
