+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "components/helium_persona/persona_validation.h"
+
+#include <optional>
+#include <string>
+#include <string_view>
+#include <vector>
+
+#include "base/strings/string_util.h"
+#include "base/values.h"
+#include "components/helium_persona/persona_presets.h"
+
+namespace helium_persona {
+
+namespace {
+
+std::string_view GetString(const base::Value::Dict& dict,
+                           std::string_view key) {
+  const std::string* value = dict.FindString(key);
+  return value ? std::string_view(*value) : std::string_view();
+}
+
+std::string_view GetNestedString(const base::Value::Dict& dict,
+                                 std::string_view dict_key,
+                                 std::string_view key) {
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  if (!nested) {
+    return std::string_view();
+  }
+  return GetString(*nested, key);
+}
+
+bool HasString(const base::Value::Dict& dict, std::string_view key) {
+  const std::string* value = dict.FindString(key);
+  return value && !value->empty();
+}
+
+bool HasNestedString(const base::Value::Dict& dict,
+                     std::string_view dict_key,
+                     std::string_view key) {
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  return nested && HasString(*nested, key);
+}
+
+int GetNestedInt(const base::Value::Dict& dict,
+                 std::string_view dict_key,
+                 std::string_view key) {
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  if (!nested) {
+    return 0;
+  }
+  return nested->FindInt(key).value_or(0);
+}
+
+double GetNestedDouble(const base::Value::Dict& dict,
+                       std::string_view dict_key,
+                       std::string_view key) {
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  if (!nested) {
+    return 0;
+  }
+  if (std::optional<double> value = nested->FindDouble(key)) {
+    return *value;
+  }
+  return nested->FindInt(key).value_or(0);
+}
+
+bool GetNestedBool(const base::Value::Dict& dict,
+                   std::string_view dict_key,
+                   std::string_view key) {
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  return nested ? nested->FindBool(key).value_or(false) : false;
+}
+
+std::vector<std::string> GetNestedStringList(const base::Value::Dict& dict,
+                                             std::string_view dict_key,
+                                             std::string_view key) {
+  std::vector<std::string> output;
+  const base::Value::Dict* nested = dict.FindDict(dict_key);
+  const base::Value::List* list = nested ? nested->FindList(key) : nullptr;
+  if (!list) {
+    return output;
+  }
+  for (const base::Value& value : *list) {
+    if (const std::string* item = value.GetIfString(); item && !item->empty()) {
+      output.push_back(*item);
+    }
+  }
+  return output;
+}
+
+bool HasNestedStringList(const base::Value::Dict& dict,
+                         std::string_view dict_key,
+                         std::string_view key) {
+  return !GetNestedStringList(dict, dict_key, key).empty();
+}
+
+bool HasNestedPositiveInt(const base::Value::Dict& dict,
+                          std::string_view dict_key,
+                          std::string_view key) {
+  return GetNestedInt(dict, dict_key, key) > 0;
+}
+
+bool HasNestedPositiveDouble(const base::Value::Dict& dict,
+                             std::string_view dict_key,
+                             std::string_view key) {
+  return GetNestedDouble(dict, dict_key, key) > 0;
+}
+
+bool IsPassthroughPersona(const base::Value::Dict& persona) {
+  const std::string* id = persona.FindString("id");
+  return persona.FindBool("passthrough").value_or(false) ||
+         (id && *id == kDefaultPresetId);
+}
+
+bool Contains(std::string_view value, std::string_view needle) {
+  return base::ToLowerASCII(std::string(value))
+             .find(base::ToLowerASCII(std::string(needle))) !=
+         std::string::npos;
+}
+
+bool StartsWithInsensitive(std::string_view value, std::string_view prefix) {
+  return base::StartsWith(base::ToLowerASCII(std::string(value)),
+                          base::ToLowerASCII(std::string(prefix)));
+}
+
+bool EqualsInsensitive(std::string_view lhs, std::string_view rhs) {
+  return base::ToLowerASCII(std::string(lhs)) ==
+         base::ToLowerASCII(std::string(rhs));
+}
+
+bool IsDeviceMemoryBucket(double value) {
+  constexpr double kBuckets[] = {0.25, 0.5, 1, 2, 4, 8};
+  for (double bucket : kBuckets) {
+    if (value == bucket) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void AddWarning(base::Value::List& warnings, std::string_view warning) {
+  warnings.Append(std::string(warning));
+}
+
+}  // namespace
+
+bool PersonaHasRequiredFields(const base::Value::Dict& persona) {
+  const bool has_base_shape =
+      HasString(persona, "id") && HasString(persona, "name") &&
+      HasString(persona, "device") && HasString(persona, "os") &&
+      persona.FindDict("uaCh") && persona.FindDict("region") &&
+      persona.FindDict("gpu") && persona.FindDict("screen") &&
+      persona.FindDict("hardware") && persona.FindDict("fonts") &&
+      persona.FindDict("advanced");
+  if (!has_base_shape || IsPassthroughPersona(persona)) {
+    return has_base_shape;
+  }
+
+  return HasString(persona, "userAgent") && HasString(persona, "platform") &&
+         HasNestedString(persona, "uaCh", "platform") &&
+         HasNestedString(persona, "uaCh", "architecture") &&
+         HasNestedString(persona, "uaCh", "bitness") &&
+         HasNestedString(persona, "region", "timezone") &&
+         HasNestedString(persona, "region", "locale") &&
+         HasNestedString(persona, "region", "acceptLanguage") &&
+         HasNestedStringList(persona, "region", "navigatorLanguages") &&
+         HasNestedString(persona, "gpu", "vendor") &&
+         HasNestedString(persona, "gpu", "renderer") &&
+         HasNestedString(persona, "gpu", "driver") &&
+         HasNestedPositiveInt(persona, "screen", "width") &&
+         HasNestedPositiveInt(persona, "screen", "height") &&
+         HasNestedPositiveInt(persona, "screen", "availWidth") &&
+         HasNestedPositiveInt(persona, "screen", "availHeight") &&
+         HasNestedPositiveDouble(persona, "screen", "deviceScaleFactor") &&
+         HasNestedPositiveInt(persona, "screen", "colorDepth") &&
+         HasNestedPositiveInt(persona, "screen", "pixelDepth") &&
+         HasNestedPositiveInt(persona, "screen", "refreshRate") &&
+         HasNestedPositiveInt(persona, "hardware", "hardwareConcurrency") &&
+         HasNestedPositiveDouble(persona, "hardware", "deviceMemory") &&
+         HasNestedString(persona, "fonts", "id") &&
+         HasNestedString(persona, "fonts", "displayName") &&
+         HasNestedStringList(persona, "fonts", "families") &&
+         HasNestedStringList(persona, "fonts", "aliases");
+}
+
+base::Value::List ValidatePersona(const base::Value::Dict& persona) {
+  base::Value::List warnings;
+  if (!PersonaHasRequiredFields(persona)) {
+    AddWarning(warnings, "This persona is missing one or more required fields.");
+    return warnings;
+  }
+  if (IsPassthroughPersona(persona)) {
+    return warnings;
+  }
+
+  const std::string_view os = GetString(persona, "os");
+  const std::string_view ua = GetString(persona, "userAgent");
+  const std::string_view platform = GetString(persona, "platform");
+  const std::string_view ua_ch_platform =
+      GetNestedString(persona, "uaCh", "platform");
+  const std::string_view ua_ch_platform_version =
+      GetNestedString(persona, "uaCh", "platformVersion");
+  const std::string_view ua_ch_architecture =
+      GetNestedString(persona, "uaCh", "architecture");
+  const bool ua_ch_mobile = GetNestedBool(persona, "uaCh", "mobile");
+  const std::string_view timezone =
+      GetNestedString(persona, "region", "timezone");
+  const std::string_view locale = GetNestedString(persona, "region", "locale");
+  const std::string_view accept_language =
+      GetNestedString(persona, "region", "acceptLanguage");
+  const std::vector<std::string> navigator_languages =
+      GetNestedStringList(persona, "region", "navigatorLanguages");
+  const std::string_view gpu_vendor = GetNestedString(persona, "gpu", "vendor");
+  const std::string_view gpu_renderer =
+      GetNestedString(persona, "gpu", "renderer");
+  const std::string_view gpu_driver = GetNestedString(persona, "gpu", "driver");
+  const int width = GetNestedInt(persona, "screen", "width");
+  const int height = GetNestedInt(persona, "screen", "height");
+  const int avail_width = GetNestedInt(persona, "screen", "availWidth");
+  const int avail_height = GetNestedInt(persona, "screen", "availHeight");
+  const double device_scale_factor =
+      GetNestedDouble(persona, "screen", "deviceScaleFactor");
+  const int color_depth = GetNestedInt(persona, "screen", "colorDepth");
+  const int pixel_depth = GetNestedInt(persona, "screen", "pixelDepth");
+  const int cores = GetNestedInt(persona, "hardware", "hardwareConcurrency");
+  const double device_memory =
+      GetNestedDouble(persona, "hardware", "deviceMemory");
+  const bool touch_enabled =
+      GetNestedBool(persona, "hardware", "touchEnabled");
+  const int max_touch_points =
+      GetNestedInt(persona, "hardware", "maxTouchPoints");
+
+  if (Contains(os, "windows") &&
+      (!Contains(ua, "windows nt") || !Contains(platform, "win"))) {
+    AddWarning(warnings,
+               "Windows personas should use a Windows UA and Win32 platform.");
+  }
+  if (Contains(os, "windows") && !Contains(ua_ch_platform, "windows")) {
+    AddWarning(warnings,
+               "Windows personas should use Windows UA-CH platform metadata.");
+  }
+
+  if (Contains(os, "macos") &&
+      (!Contains(ua, "macintosh") || !Contains(platform, "mac"))) {
+    AddWarning(warnings,
+               "macOS personas should use a Macintosh UA and MacIntel platform.");
+  }
+  if (Contains(os, "macos") && !Contains(ua_ch_platform, "macos")) {
+    AddWarning(warnings,
+               "macOS personas should use macOS UA-CH platform metadata.");
+  }
+  if (Contains(os, "macos") && Contains(gpu_renderer, "apple m") &&
+      Contains(ua_ch_architecture, "x86")) {
+    AddWarning(warnings,
+               "Apple Silicon macOS personas should not expose x86 UA-CH architecture.");
+  }
+
+  if (Contains(os, "linux") &&
+      (!Contains(ua, "linux") || !Contains(platform, "linux"))) {
+    AddWarning(warnings,
+               "Linux personas should use a Linux UA and Linux platform.");
+  }
+  if (Contains(os, "linux") && !Contains(ua_ch_platform, "linux")) {
+    AddWarning(warnings,
+               "Linux personas should use Linux UA-CH platform metadata.");
+  }
+  if (Contains(os, "linux") && !ua_ch_platform_version.empty()) {
+    AddWarning(warnings,
+               "Linux UA-CH platformVersion is usually blank or very coarse.");
+  }
+
+  if (Contains(os, "macos") &&
+      (Contains(gpu_vendor, "nvidia") || Contains(gpu_vendor, "mesa"))) {
+    AddWarning(warnings,
+               "macOS presets usually pair best with Apple GPU or AMD GPU data.");
+  }
+  if (Contains(os, "windows") &&
+      (Contains(gpu_driver, "metal") || Contains(gpu_driver, "mesa") ||
+       Contains(gpu_renderer, "metal"))) {
+    AddWarning(warnings,
+               "Windows GPU data should normally use a Direct3D/ANGLE renderer.");
+  }
+  if (Contains(os, "macos") &&
+      (Contains(gpu_driver, "d3d") || Contains(gpu_renderer, "direct3d"))) {
+    AddWarning(warnings,
+               "macOS GPU data should not expose Direct3D renderer strings.");
+  }
+  if (Contains(os, "linux") &&
+      (Contains(gpu_driver, "d3d") || Contains(gpu_driver, "metal") ||
+       Contains(gpu_renderer, "direct3d"))) {
+    AddWarning(warnings,
+               "Linux GPU data should normally use Mesa/Vulkan/OpenGL-style renderer data.");
+  }
+
+  if (Contains(locale, "zh") && !Contains(timezone, "asia")) {
+    AddWarning(warnings,
+               "Chinese language profiles commonly pair with an Asia/* timezone.");
+  }
+
+  if ((Contains(locale, "en-us") || Contains(locale, "es-us")) &&
+      !(Contains(timezone, "america") || timezone.empty())) {
+    AddWarning(warnings,
+               "US language profiles commonly pair with an America/* timezone.");
+  }
+  if (Contains(locale, "en-au") && !Contains(timezone, "australia")) {
+    AddWarning(warnings,
+               "Australian English profiles commonly pair with an Australia/* timezone.");
+  }
+  if (Contains(locale, "de-de") && !Contains(timezone, "europe")) {
+    AddWarning(warnings,
+               "German profiles commonly pair with a Europe/* timezone.");
+  }
+  if (!accept_language.empty() &&
+      !StartsWithInsensitive(accept_language, locale)) {
+    AddWarning(warnings,
+               "Accept-Language should begin with the persona locale.");
+  }
+  if (!navigator_languages.empty() &&
+      !EqualsInsensitive(navigator_languages.front(), locale)) {
+    AddWarning(warnings,
+               "navigator.languages[0] should match the persona locale.");
+  }
+
+  if (width > 0 && height > 0 && (width < 1024 || height < 720)) {
+    AddWarning(warnings,
+               "The selected screen size looks mobile; v1 personas are desktop-only.");
+  }
+  if ((width > 0 && avail_width > width) ||
+      (height > 0 && avail_height > height)) {
+    AddWarning(warnings,
+               "Available screen dimensions should not exceed total screen size.");
+  }
+  if (device_scale_factor > 0 &&
+      (device_scale_factor < 1.0 || device_scale_factor > 3.0)) {
+    AddWarning(warnings,
+               "Desktop device scale factor should usually stay between 1 and 3.");
+  }
+  if (color_depth > 0 && pixel_depth > 0 && color_depth != pixel_depth) {
+    AddWarning(warnings,
+               "screen.colorDepth and screen.pixelDepth should usually match.");
+  }
+  if (color_depth > 0 && color_depth != 24 && color_depth != 30) {
+    AddWarning(warnings,
+               "screen.colorDepth should usually be 24 or 30.");
+  }
+
+  if (cores > 0 && cores % 2 != 0) {
+    AddWarning(warnings,
+               "Odd CPU core counts are uncommon on desktop fingerprint sets.");
+  }
+  if (device_memory > 0 && !IsDeviceMemoryBucket(device_memory)) {
+    AddWarning(warnings,
+               "navigator.deviceMemory should use Chromium bucket values up to 8 GB.");
+  }
+
+  if (!touch_enabled && max_touch_points > 0) {
+    AddWarning(warnings,
+               "maxTouchPoints should be 0 when touch capability is disabled.");
+  }
+  if (touch_enabled && max_touch_points == 0) {
+    AddWarning(warnings,
+               "Touch-enabled personas should expose at least one touch point.");
+  }
+  if (touch_enabled || max_touch_points > 0) {
+    AddWarning(warnings,
+               "Touch-enabled desktop personas are less common and may stand out.");
+  }
+  if (ua_ch_mobile && width >= 1024 && height >= 720) {
+    AddWarning(warnings,
+               "Mobile UA-CH metadata does not match a desktop screen size.");
+  }
+
+  return warnings;
+}
+
