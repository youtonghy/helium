+    bool dispatch_events) {
+  if (!PersonaSpoofingHelper::IsEnabled(window)) {
+    return;
+  }
+
+  display::ScreenInfos source_infos = prev_screen_infos_;
+  if (source_infos.screen_infos.empty()) {
+    LocalFrame* frame = window->GetFrame();
+    if (!frame) {
+      return;
+    }
+    source_infos = frame->GetChromeClient().GetScreenInfos(*frame);
+  }
+
+  const display::ScreenInfos persona_infos =
+      PersonaScreenInfosFor(window, source_infos);
+  if (screens_.size() == 1 && prev_screen_infos_ == persona_infos &&
+      current_display_id_ == persona_infos.current_display_id) {
+    return;
+  }
+
+  UpdateScreenInfosImpl(window, persona_infos, dispatch_events);
 }
 
