 namespace blink {
 
+namespace {
+
+display::ScreenInfos PersonaScreenInfosFor(
+    LocalDOMWindow* window,
+    const display::ScreenInfos& source_infos) {
+  if (!PersonaSpoofingHelper::IsEnabled(window)) {
+    return source_infos;
+  }
+
+  display::ScreenInfo info = source_infos.screen_infos.empty()
+                                 ? display::ScreenInfo()
+                                 : source_infos.current();
+  const int width = PersonaSpoofingHelper::ScreenWidth(window).value_or(
+      std::max(1, info.rect.width()));
+  const int height = PersonaSpoofingHelper::ScreenHeight(window).value_or(
+      std::max(1, info.rect.height()));
+  const int avail_width =
+      PersonaSpoofingHelper::ScreenAvailWidth(window).value_or(width);
+  const int avail_height =
+      PersonaSpoofingHelper::ScreenAvailHeight(window).value_or(height);
+  const double device_scale_factor =
+      PersonaSpoofingHelper::DeviceScaleFactor(window).value_or(1.0);
+  const unsigned color_depth =
+      PersonaSpoofingHelper::ScreenColorDepth(window).value_or(24u);
+
+  info.display_id = display::kDefaultDisplayId;
+  info.rect = gfx::Rect(0, 0, width, height);
+  info.available_rect = gfx::Rect(0, 0, avail_width, avail_height);
+  info.device_scale_factor = static_cast<float>(device_scale_factor);
+  info.depth = static_cast<int>(color_depth);
+  info.depth_per_component = 8;
+  info.is_monochrome = false;
+  info.is_extended = false;
+  info.is_primary = true;
+  info.is_internal = false;
+  info.label.clear();
+  info.display_frequency = 0.f;
+
+  display::ScreenInfos persona_infos(info);
+  persona_infos.current_display_id = info.display_id;
+  return persona_infos;
+}
