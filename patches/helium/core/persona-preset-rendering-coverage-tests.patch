+TEST(HeliumPersonaPrefsTest, BuiltinPresetsCoverCoreDeviceRegionPersonas) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+
+  struct ExpectedPreset {
+    std::string_view id;
+    std::string_view os;
+    std::string_view platform;
+    std::string_view timezone;
+    std::string_view locale;
+    std::string_view accept_language;
+  };
+
+  constexpr ExpectedPreset kExpectedPresets[] = {
+      {"preset-windows-11-en-us-new-york", "Windows 11", "Win32",
+       "America/New_York", "en-US", "en-US,en;q=0.9"},
+      {"preset-macos-en-au-melbourne", "macOS 15", "MacIntel",
+       "Australia/Melbourne", "en-AU", "en-AU,en;q=0.9"},
+      {"preset-windows-11-zh-cn-shanghai", "Windows 11", "Win32",
+       "Asia/Shanghai", "zh-CN", "zh-CN,zh;q=0.9,en;q=0.7"},
+      {"preset-linux-de-de-berlin", "Linux x86_64", "Linux x86_64",
+       "Europe/Berlin", "de-DE", "de-DE,de;q=0.9,en;q=0.7"},
+      {"preset-windows-11-ja-jp-tokyo", "Windows 11", "Win32",
+       "Asia/Tokyo", "ja-JP", "ja-JP,ja;q=0.9,en;q=0.7"},
+      {"preset-macos-en-gb-london", "macOS 15", "MacIntel",
+       "Europe/London", "en-GB", "en-GB,en;q=0.9"},
+      {"preset-linux-pt-pt-lisbon", "Linux x86_64", "Linux x86_64",
+       "Europe/Lisbon", "pt-PT", "pt-PT,pt;q=0.9,en;q=0.7"},
+      {"preset-windows-11-en-sg-singapore", "Windows 11", "Win32",
+       "Asia/Singapore", "en-SG", "en-SG,en;q=0.9"},
+  };
+
+  for (const ExpectedPreset& expected : kExpectedPresets) {
+    const base::Value::Dict* preset = FindProfileById(presets, expected.id);
+    ASSERT_TRUE(preset) << expected.id;
+    ExpectPresetRegion(expected.id, *preset, expected.os, expected.platform,
+                       expected.timezone, expected.locale,
+                       expected.accept_language);
+    EXPECT_TRUE(preset->FindString("userAgent"));
+    EXPECT_TRUE(preset->FindDict("uaCh"));
+    EXPECT_TRUE(preset->FindDict("gpu"));
+    EXPECT_TRUE(preset->FindDict("screen"));
+    EXPECT_TRUE(preset->FindDict("fonts"));
+    EXPECT_TRUE(preset->FindDict("fontRendering"));
+    EXPECT_TRUE(preset->FindDict("advanced"));
+  }
+}
