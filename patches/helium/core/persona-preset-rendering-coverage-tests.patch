+void ExpectPresetRegion(std::string_view id,
+                        const base::Value::Dict& preset,
+                        std::string_view expected_os,
+                        std::string_view expected_platform,
+                        std::string_view expected_timezone,
+                        std::string_view expected_locale,
+                        std::string_view expected_accept_language) {
+  SCOPED_TRACE(id);
+  EXPECT_EQ(std::string(expected_os), *preset.FindString("os"));
+  EXPECT_EQ(std::string(expected_platform), *preset.FindString("platform"));
+
+  const base::Value::Dict* region = preset.FindDict("region");
+  ASSERT_TRUE(region);
+  EXPECT_EQ(std::string(expected_timezone), *region->FindString("timezone"));
+  EXPECT_EQ(std::string(expected_locale), *region->FindString("locale"));
+  EXPECT_EQ(std::string(expected_accept_language),
+            *region->FindString("acceptLanguage"));
+
+  const base::Value::List* navigator_languages =
+      region->FindList("navigatorLanguages");
+  ASSERT_TRUE(navigator_languages);
+  ASSERT_FALSE(navigator_languages->empty());
+  EXPECT_EQ(std::string(expected_locale), (*navigator_languages)[0].GetString());
+}
