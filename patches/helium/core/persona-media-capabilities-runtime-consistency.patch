+bool IsPersonaStableMediaCapabilitiesMimeType(const String& mime_type) {
+  const String type = mime_type.DeprecatedLower();
+  return type == "audio/webm" || type == "video/webm" ||
+         type == "audio/ogg" || type == "video/ogg" ||
+         type == "audio/mp4" || type == "video/mp4" ||
+         type == "application/mp4" || type == "audio/mpeg" ||
+         type == "audio/wav" || type == "audio/opus" ||
+         type == "audio/pcmu" || type == "audio/pcma" ||
+         type == "video/vp8" || type == "video/vp9" ||
+         type == "video/h264" || type == "video/av1";
+}
+
+bool IsPersonaStableMediaCapabilitiesCodecToken(StringView codec_token) {
+  const String codec = codec_token.StripWhiteSpace().ToString().ToAsciiLower();
+  return codec == "opus" || codec == "vorbis" || codec == "vp8" ||
+         codec == "vp9" || codec == "vp09" || codec == "h264" ||
+         codec == "av1" || codec == "mp3" ||
+         codec.StartsWithIgnoringAsciiCase("vp09.") ||
+         codec.StartsWithIgnoringAsciiCase("avc1") ||
+         codec.StartsWithIgnoringAsciiCase("avc3") ||
+         codec.StartsWithIgnoringAsciiCase("av01") ||
+         codec.StartsWithIgnoringAsciiCase("mp4a");
+}
+
+bool IsPersonaStableMediaCapabilitiesContentType(const String& content_type) {
+  ParsedContentType parsed_content_type(content_type);
+  if (!parsed_content_type.IsValid() ||
+      parsed_content_type.GetParameters().HasDuplicatedNames()) {
+    return false;
+  }
+
+  if (!IsPersonaStableMediaCapabilitiesMimeType(
+          parsed_content_type.MimeType())) {
+    return false;
+  }
+
+  const String codecs =
+      parsed_content_type.ParameterValueForName(kCodecsMimeTypeParam);
+  if (codecs.empty()) {
+    return true;
+  }
+
+  for (StringView codec : StringView(codecs).Split(',')) {
+    if (!IsPersonaStableMediaCapabilitiesCodecToken(codec)) {
+      return false;
+    }
+  }
+
+  return true;
+}
+
+bool IsPersonaStableMediaCapabilitiesVideoShape(
+    const VideoConfiguration* video) {
+  if (!video) {
+    return true;
+  }
+
+  if (video->hasWidth() && video->width() > 3840) {
+    return false;
+  }
+  if (video->hasHeight() && video->height() > 2160) {
+    return false;
+  }
+  if (video->hasFramerate() && video->framerate() > 120) {
+    return false;
+  }
+  if (video->hasHdrMetadataType()) {
+    return false;
+  }
+  if (video->hasTransferFunction() &&
+      video->transferFunction().AsEnum() != V8TransferFunction::Enum::kSRGB) {
+    return false;
+  }
+
+  return true;
+}
+
+bool IsPersonaStableMediaDecodingConfiguration(
+    const MediaDecodingConfiguration* configuration) {
+  if (configuration->hasKeySystemConfiguration()) {
+    return false;
+  }
+  if (configuration->hasAudio() &&
+      !IsPersonaStableMediaCapabilitiesContentType(
+          configuration->audio()->contentType())) {
+    return false;
+  }
+  if (configuration->hasVideo() &&
+      (!IsPersonaStableMediaCapabilitiesContentType(
+           configuration->video()->contentType()) ||
+       !IsPersonaStableMediaCapabilitiesVideoShape(configuration->video()))) {
+    return false;
+  }
+  return true;
+}
+
+bool IsPersonaStableMediaEncodingConfiguration(
+    const MediaEncodingConfiguration* configuration) {
+  if (configuration->hasAudio() &&
+      !IsPersonaStableMediaCapabilitiesContentType(
+          configuration->audio()->contentType())) {
+    return false;
+  }
+  if (configuration->hasVideo() &&
+      (!IsPersonaStableMediaCapabilitiesContentType(
+           configuration->video()->contentType()) ||
+       !IsPersonaStableMediaCapabilitiesVideoShape(configuration->video()))) {
+    return false;
+  }
+  return true;
+}
