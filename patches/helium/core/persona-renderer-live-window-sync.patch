 void WebViewImpl::UpdateHeliumPersonaSnapshot(
     const HeliumPersonaSnapshot& snapshot) {
   page_->SetHeliumPersonaSnapshot(snapshot);
+  UpdateHeliumPersonaExecutionContexts(page_, nullptr, &snapshot);
   ApplyHeliumPersonaRuntimeOverride(snapshot);
   ApplyHeliumPersonaInputDeviceSettings(page_.Get(), snapshot);
 }
