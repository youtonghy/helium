+void UpdateHeliumPersonaExecutionContexts(
+    Page* page,
+    const HeliumNoiseTokenMap* noise_tokens,
+    const HeliumPersonaSnapshot* snapshot) {
+  if (!page || !page->MainFrame()) {
+    return;
+  }
+
+  for (Frame* frame = page->MainFrame(); frame;
+       frame = frame->Tree().TraverseNext()) {
+    auto* local_frame = DynamicTo<LocalFrame>(frame);
+    if (!local_frame || !local_frame->DomWindow()) {
+      continue;
+    }
+    if (noise_tokens) {
+      local_frame->DomWindow()->SetHeliumNoiseTokens(*noise_tokens);
+    }
+    if (snapshot) {
+      local_frame->DomWindow()->SetHeliumPersonaSnapshot(*snapshot);
+    }
+  }
+}
