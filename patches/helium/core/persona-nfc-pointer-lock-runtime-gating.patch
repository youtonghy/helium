diff --git a/content/browser/renderer_host/render_frame_host_impl.cc b/content/browser/renderer_host/render_frame_host_impl.cc
index 5cc0db5e..b15556db 100644
--- a/content/browser/renderer_host/render_frame_host_impl.cc
+++ b/content/browser/renderer_host/render_frame_host_impl.cc
@@ -14651,6 +14651,12 @@ void RenderFrameHostImpl::CreateDedicatedWorkerHostFactory(
 #if BUILDFLAG(IS_ANDROID) || (BUILDFLAG(IS_IOS) && !BUILDFLAG(IS_IOS_TVOS))
 void RenderFrameHostImpl::BindNFCReceiver(
     mojo::PendingReceiver<device::mojom::NFC> receiver) {
+  const blink::HeliumPersonaSnapshot& persona_snapshot =
+      GetPage().persona_snapshot();
+  if (persona_snapshot.IsEnabled() && !persona_snapshot.allow_web_nfc) {
+    return;
+  }
+
   delegate_->GetNFC(this, std::move(receiver));
 }
 #endif
diff --git a/content/browser/web_contents/web_contents_impl.cc b/content/browser/web_contents/web_contents_impl.cc
index 151f39f9..3f1afec3 100644
--- a/content/browser/web_contents/web_contents_impl.cc
+++ b/content/browser/web_contents/web_contents_impl.cc
@@ -5256,8 +5256,15 @@ void WebContentsImpl::RequestToLockPointer(
 
   bool widget_in_frame_tree = false;
   for (FrameTreeNode* node : primary_frame_tree_.Nodes()) {
-    if (node->current_frame_host()->GetRenderWidgetHost() ==
-        render_widget_host) {
+    RenderFrameHostImpl* frame_host = node->current_frame_host();
+    if (frame_host->GetRenderWidgetHost() == render_widget_host) {
+      const blink::HeliumPersonaSnapshot& persona_snapshot =
+          frame_host->GetPage().persona_snapshot();
+      if (persona_snapshot.IsEnabled() && !persona_snapshot.allow_pointer_lock) {
+        render_widget_host->GotResponseToPointerLockRequest(
+            blink::mojom::PointerLockResult::kPermissionDenied);
+        return;
+      }
       widget_in_frame_tree = true;
       break;
     }
