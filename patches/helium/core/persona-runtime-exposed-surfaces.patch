+  const bool is_windows = PersonaOsContains(context, "windows");
+  const bool is_macos =
+      PersonaOsContains(context, "macos") || PersonaOsContains(context, "mac");
+
+  if (lower_locale.starts_with("zh")) {
+    if (is_windows)
+      return "Microsoft Huihui Desktop";
+    if (is_macos)
+      return "Ting-Ting";
+    return "Helium Chinese";
+  }
+  if (lower_locale.starts_with("de")) {
+    if (is_windows)
+      return "Microsoft Hedda Desktop";
+    if (is_macos)
+      return "Anna";
+    return "Helium Deutsch";
+  }
+  if (lower_locale.starts_with("en-au")) {
+    if (is_windows)
+      return "Microsoft Catherine Desktop";
+    if (is_macos)
+      return "Karen";
+    return "Helium English Australia";
+  }
+  if (lower_locale.starts_with("en-gb")) {
+    if (is_windows)
+      return "Microsoft Hazel Desktop";
+    if (is_macos)
+      return "Daniel";
+    return "Helium English UK";
+  }
+  if (is_windows)
