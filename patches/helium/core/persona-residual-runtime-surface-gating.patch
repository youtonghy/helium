+bool HeliumPersonaAllowsDeviceApis(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_device_apis;
+}
+
+bool HeliumPersonaAllowsGamepads(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_gamepads;
+}
+
+bool HeliumPersonaAllowsMediaPerformanceMetrics(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() ||
+         (snapshot.allow_media_capture && !snapshot.reduce_system_info);
+}
+
