+  private shuffled_<T>(items: T[]): T[] {
+    const shuffled = [...items];
+    for (let i = shuffled.length - 1; i > 0; --i) {
+      const j = this.randomInt_(0, i);
+      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
+    }
+    return shuffled;
+  }
+
+  private chromeMajorVersion_(persona: PersonaRecord): number {
+    const ua = String(persona.userAgent || '');
+    const uaMatch = /(?:Chrome|Chromium)\/(\d+)/.exec(ua);
+    if (uaMatch) {
+      return Number(uaMatch[1]);
+    }
+    const uaCh = persona.uaCh || {};
+    const fullVersion = String(uaCh['fullVersion'] || '');
+    const uaChMatch = /^(\d+)/.exec(fullVersion);
+    if (uaChMatch) {
+      return Number(uaChMatch[1]);
+    }
+    return 149;
+  }
+
+  private makeRandomChromeFullVersion_(major: number): string {
+    const minor = 0;
+    const build = this.randomInt_(7600, 7899);
+    const patch = this.randomInt_(40, 180);
+    return `${major}.${minor}.${build}.${patch}`;
+  }
+
+  private chromeMajorOnlyVersion_(major: number): string {
+    return `${major}.0.0.0`;
+  }
+
+  private applyRandomUaVersion_(persona: PersonaRecord) {
+    persona.uaCh = persona.uaCh || {};
+    const major = this.chromeMajorVersion_(persona);
+    const fullVersion = this.makeRandomChromeFullVersion_(major);
+    const majorVersion = String(major);
+    const uaVersion = this.chromeMajorOnlyVersion_(major);
+    persona.userAgent = String(persona.userAgent || '')
+        .replace(/(Chrome|Chromium)\/[\d.]+/g, `$1/${uaVersion}`);
+    persona.uaCh['fullVersion'] = fullVersion;
+
+    const existingBrands =
+        (persona.uaCh['brands'] as Array<Record<string, unknown>>|undefined) ||
+        [];
+    const brandNames = existingBrands
+        .map(brand => String(brand['brand'] || '').trim())
+        .filter(Boolean);
+    const hasChromeBrand =
+        brandNames.some(name => this.contains_(name, 'chrome'));
+    const hasChromiumBrand =
+        brandNames.some(name => this.contains_(name, 'chromium'));
+    const hasGreaseBrand = brandNames.some(name => this.contains_(name, 'brand'));
+    const brands = [
+      ...(hasChromiumBrand ? [{brand: 'Chromium', version: majorVersion}] : []),
+      ...(hasChromeBrand ? [{brand: 'Google Chrome', version: majorVersion}] : []),
+      ...(hasGreaseBrand ? [{brand: 'Not_A Brand', version: '24'}] : []),
+    ];
+    persona.uaCh['brands'] = this.shuffled_(
+        brands.length ? brands : [
+          {brand: 'Chromium', version: majorVersion},
+          {brand: 'Google Chrome', version: majorVersion},
+          {brand: 'Not_A Brand', version: '24'},
+        ]);
+  }
