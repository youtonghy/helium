+TEST(HeliumPersonaPrefsTest,
+     BuiltinFontRenderingProfilesCoverPresetRenderingProfiles) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  base::Value::List profiles = GetBuiltinFontRenderingProfiles();
+
+  for (const base::Value& value : presets) {
+    const base::Value::Dict* preset = value.GetIfDict();
+    ASSERT_TRUE(preset);
+    if (preset->FindBool("passthrough").value_or(false)) {
+      continue;
+    }
+    const std::string* preset_id = preset->FindString("id");
+    const base::Value::Dict* font_rendering =
+        preset->FindDict("fontRendering");
+    ASSERT_TRUE(font_rendering);
+    const std::string* rendering_id = font_rendering->FindString("id");
+    ASSERT_TRUE(rendering_id);
+    EXPECT_TRUE(ProfilesContainId(profiles, *rendering_id))
+        << (preset_id ? *preset_id : "<missing preset id>") << " -> "
+        << *rendering_id;
+  }
+}
