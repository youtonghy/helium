 TEST(HeliumPersonaPrefsTest, ClonePresetPersistsAndBecomesActive) {
   sync_preferences::TestingPrefServiceSyncable prefs;
   RegisterTestPrefs(prefs);
 
   base::Value::Dict cloned = ClonePresetIntoProfile(
       prefs, "preset-windows-11-zh-cn-shanghai");
   const std::string* cloned_id = cloned.FindString("id");
   ASSERT_TRUE(cloned_id);
   EXPECT_EQ(*cloned_id, prefs.GetString(prefs::kHeliumActivePersonaId));
 
   const base::Value::List& personas =
       prefs.GetList(prefs::kHeliumPersonaRecords);
   ASSERT_EQ(1u, personas.size());
   EXPECT_EQ(*cloned_id, *DictAt(personas, 0).FindString("id"));
   ASSERT_TRUE(DictAt(personas, 0).FindString("noiseSeed"));
   EXPECT_NE(*cloned_id, *DictAt(personas, 0).FindString("noiseSeed"));
   EXPECT_EQ("preset-windows-11-zh-cn-shanghai",
             *DictAt(personas, 0).FindString("basePresetId"));
 
   base::Value::Dict active = GetActivePersona(prefs);
