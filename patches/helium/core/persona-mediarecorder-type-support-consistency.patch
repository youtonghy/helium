+bool IsPersonaStableRecorderMimeType(const String& mime_type) {
+  const String type = mime_type.DeprecatedLower();
+  return type == "audio/webm" || type == "video/webm" ||
+         type == "audio/ogg" || type == "video/mp4" ||
+         type == "audio/mp4";
+}
+
+bool IsPersonaStableRecorderCodecToken(StringView codec_token) {
+  const String codec = codec_token.StripWhiteSpace().ToString().ToAsciiLower();
+  return codec == "opus" || codec == "vp8" || codec == "vp9" ||
+         codec == "h264" || codec.StartsWithIgnoringAsciiCase("avc1") ||
+         codec.StartsWithIgnoringAsciiCase("avc3") ||
+         codec.StartsWithIgnoringAsciiCase("av01") ||
+         codec.StartsWithIgnoringAsciiCase("mp4a");
+}
+
+bool IsPersonaStableRecorderContentType(const ContentType& content_type) {
+  if (content_type.GetType().empty()) {
+    return true;
+  }
+
+  if (!IsPersonaStableRecorderMimeType(content_type.GetType())) {
+    return false;
+  }
+
+  const String codecs = content_type.Parameter("codecs");
+  if (codecs.empty()) {
+    return true;
+  }
+
+  for (StringView codec : StringView(codecs).Split(',')) {
+    if (!IsPersonaStableRecorderCodecToken(codec)) {
+      return false;
+    }
+  }
+
+  return true;
+}
