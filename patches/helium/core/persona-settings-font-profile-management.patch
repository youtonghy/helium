     }
   }
 
+  private profileId_(profile: Record<string, unknown>): string {
+    return String(profile['id'] || '');
+  }
+
+  private countPersonasUsingProfile_(
+      field: 'fonts'|'fontRendering', profileId: string): number {
+    if (!profileId) {
+      return 0;
+    }
+    const personas = [
+      ...(this.presets_ || []),
+      ...(this.personas_ || []),
+    ];
+    return personas.filter(persona => {
+      const profile = persona[field] as Record<string, unknown>|undefined;
+      return profile && String(profile['id'] || '') === profileId;
+    }).length;
+  }
+
+  private referenceLabel_(count: number): string {
+    if (count === 0) {
+      return 'not used by saved personas';
+    }
+    return count === 1 ? 'used by 1 persona' : `used by ${count} personas`;
+  }
+
+  private fontPackReferenceLabel_(profile: Record<string, unknown>): string {
+    return this.referenceLabel_(
+        this.countPersonasUsingProfile_('fonts', this.profileId_(profile)));
+  }
+
+  private fontRenderingReferenceLabel_(
+      profile: Record<string, unknown>): string {
+    return this.referenceLabel_(this.countPersonasUsingProfile_(
+        'fontRendering', this.profileId_(profile)));
+  }
+
   private isKnownDeviceMemoryBucket_(value: number): boolean {
     return [0.25, 0.5, 1, 2, 4, 8].includes(value);
