 bool HasNumericValue(const base::Value::Dict& dict, std::string_view key) {
   return dict.FindDouble(key).has_value() || dict.FindInt(key).has_value();
 }
 
+bool HasStringListValue(const base::Value::Dict& dict, std::string_view key) {
+  const base::Value::List* list = dict.FindList(key);
+  if (!list) {
+    return false;
+  }
+  for (const base::Value& value : *list) {
+    const std::string* item = value.GetIfString();
+    if (item && !item->empty()) {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool HasUaChBrandListValue(const base::Value::Dict& ua_ch) {
+  const base::Value::List* brands = ua_ch.FindList("brands");
+  if (!brands || brands->empty()) {
+    return false;
+  }
+  for (const base::Value& value : *brands) {
+    const base::Value::Dict* brand = value.GetIfDict();
+    const std::string* brand_name =
+        brand ? brand->FindString("brand") : nullptr;
+    const std::string* version =
+        brand ? brand->FindString("version") : nullptr;
+    if (!brand_name || brand_name->empty() || !version || version->empty()) {
+      return false;
+    }
+  }
+  return true;
+}
