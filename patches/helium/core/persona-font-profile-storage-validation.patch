+
+base::Value::List CopyStringListItems(const base::Value::Dict& profile,
+                                      const char* key) {
+  base::Value::List clean;
+  const base::Value::List* values = profile.FindList(key);
+  if (!values) {
+    return clean;
+  }
+  for (const base::Value& value : *values) {
+    const std::string* item = value.GetIfString();
+    if (item) {
+      std::string trimmed = TrimProfileString(*item);
+      if (!trimmed.empty()) {
+        clean.Append(std::move(trimmed));
+      }
+    }
+  }
+  return clean;
+}
