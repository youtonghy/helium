+TEST(HeliumPersonaPrefsTest, SaveFontPackProfileNormalizesStorageShape) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict custom;
+  custom.Set("id", " custom-mixed-fonts ");
+  custom.Set("displayName", " Mixed fonts ");
+  base::Value::List families;
+  families.Append(" Arial ");
+  families.Append(false);
+  families.Append("   ");
+  families.Append("Noto Sans");
+  custom.Set("families", std::move(families));
+  base::Value::List aliases;
+  aliases.Append(" sans-serif=Arial ");
+  aliases.Append(17);
+  aliases.Append("");
+  aliases.Append("system-ui=Noto Sans");
+  custom.Set("aliases", std::move(aliases));
+  custom.Set("unexpected", "drop me");
+  EXPECT_TRUE(SaveFontPackProfile(prefs, std::move(custom)));
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  const base::Value::Dict* profile =
+      FindProfileById(*state.FindList("fontPackProfiles"),
+                      "custom-mixed-fonts");
+  ASSERT_TRUE(profile);
+  EXPECT_EQ("Mixed fonts", *profile->FindString("displayName"));
+  const base::Value::List* saved_families = profile->FindList("families");
+  ASSERT_TRUE(saved_families);
+  ASSERT_EQ(2u, saved_families->size());
+  EXPECT_EQ("Arial", (*saved_families)[0].GetString());
+  EXPECT_EQ("Noto Sans", (*saved_families)[1].GetString());
+  const base::Value::List* saved_aliases = profile->FindList("aliases");
+  ASSERT_TRUE(saved_aliases);
+  ASSERT_EQ(2u, saved_aliases->size());
+  EXPECT_EQ("sans-serif=Arial", (*saved_aliases)[0].GetString());
+  EXPECT_EQ("system-ui=Noto Sans", (*saved_aliases)[1].GetString());
+  EXPECT_FALSE(profile->FindString("unexpected"));
+}
