+bool IsProfileAsciiWhitespace(char value) {
+  return value == ' ' || value == '\t' || value == '\n' ||
+         value == '\r' || value == '\f' || value == '\v';
+}
+
+std::string TrimProfileString(std::string_view value) {
+  size_t begin = 0;
+  while (begin < value.size() && IsProfileAsciiWhitespace(value[begin])) {
+    ++begin;
+  }
+  size_t end = value.size();
+  while (end > begin && IsProfileAsciiWhitespace(value[end - 1])) {
+    --end;
+  }
+  return std::string(value.substr(begin, end - begin));
+}
+
