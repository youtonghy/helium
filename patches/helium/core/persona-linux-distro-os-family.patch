@@ -438,6 +438,38 @@ TEST(HeliumPersonaPrefsTest, BuiltinPresetsContainCompleteSystemImage) {
 
   const base::Value::Dict& linux = DictAt(presets, 4);
   EXPECT_TRUE(linux.FindDict("uaCh")->FindString("platformVersion")->empty());
+
+  const base::Value::Dict* ubuntu =
+      FindProfileById(presets, "preset-linux-en-in-kolkata");
+  ASSERT_TRUE(ubuntu);
+  EXPECT_TRUE(ValidatePersona(*ubuntu).empty());
+}
+
+TEST(HeliumPersonaPrefsTest, LinuxDistributionOsNamesUseLinuxRules) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  const base::Value::Dict* preset =
+      FindProfileById(presets, "preset-linux-en-in-kolkata");
+  ASSERT_TRUE(preset);
+  EXPECT_EQ("Ubuntu 24.04", *preset->FindString("os"));
+
+  const base::Value::Dict* advanced = preset->FindDict("advanced");
+  ASSERT_TRUE(advanced);
+  EXPECT_EQ("English India", *advanced->FindString("speechVoiceName"));
+  EXPECT_TRUE(ValidatePersona(*preset).empty());
+
+  base::Value::Dict invalid = preset->Clone();
+  invalid.Set("userAgent",
+              "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
+              "AppleWebKit/537.36 (KHTML, like Gecko) "
+              "Chrome/149.0.0.0 Safari/537.36");
+  invalid.Set("platform", "Win32");
+  base::Value::List warnings = ValidatePersona(invalid);
+  EXPECT_TRUE(WarningsContain(warnings, "Linux personas should use"));
+
+  invalid = preset->Clone();
+  invalid.FindDict("gpu")->Set("driver", "D3D11");
+  warnings = ValidatePersona(invalid);
+  EXPECT_TRUE(WarningsContain(warnings, "Linux GPU data"));
 }
 
