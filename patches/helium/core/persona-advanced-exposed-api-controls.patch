+bool PersonaSpoofingHelper::ShouldBlockPermission(
+    const ExecutionContext* context,
+    mojom::blink::PermissionName permission_name) {
+  switch (permission_name) {
+    case mojom::blink::PermissionName::GEOLOCATION:
+    case mojom::blink::PermissionName::GEOLOCATION_APPROXIMATE:
+      return ShouldBlockGeolocation(context);
+    case mojom::blink::PermissionName::MIDI:
+      return ShouldBlockMidi(context);
+    case mojom::blink::PermissionName::AUDIO_CAPTURE:
+    case mojom::blink::PermissionName::VIDEO_CAPTURE:
+    case mojom::blink::PermissionName::SPEAKER_SELECTION:
+      return ShouldBlockMediaCapture(context);
+    case mojom::blink::PermissionName::SENSORS:
+      return ShouldBlockSensorApis(context);
+    case mojom::blink::PermissionName::NFC:
+      return ShouldBlockWebNfc(context);
+    case mojom::blink::PermissionName::WINDOW_MANAGEMENT:
+      return ShouldBlockWindowManagement(context);
+    case mojom::blink::PermissionName::LOCAL_FONTS:
+      return ShouldBlockLocalFonts(context);
+    case mojom::blink::PermissionName::DISPLAY_CAPTURE:
+    case mojom::blink::PermissionName::CAPTURED_SURFACE_CONTROL:
+      return ShouldBlockDisplayCapture(context);
+    case mojom::blink::PermissionName::KEYBOARD_LOCK:
+      return ShouldBlockKeyboardLayout(context);
+    case mojom::blink::PermissionName::LOCAL_NETWORK_ACCESS:
+    case mojom::blink::PermissionName::LOCAL_NETWORK:
+    case mojom::blink::PermissionName::LOOPBACK_NETWORK:
+      return ShouldBlockLocalNetworkApis(context);
+    case mojom::blink::PermissionName::VR:
+    case mojom::blink::PermissionName::AR:
+    case mojom::blink::PermissionName::HAND_TRACKING:
+      return ShouldBlockWebXr(context);
+    case mojom::blink::PermissionName::SMART_CARD:
+      return ShouldBlockDeviceApis(context);
+    default:
+      return false;
+  }
+}
