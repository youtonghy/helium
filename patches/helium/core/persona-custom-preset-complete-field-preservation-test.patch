+TEST(HeliumPersonaPrefsTest, CustomPersonaPresetPreservesCompleteManualSnapshot) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::List builtin_presets = GetBuiltinPersonaPresets();
+  base::Value::Dict preset = DictAt(builtin_presets, 1).Clone();
+  preset.Set("id", "");
+  preset.Set("name", "Complete manual preset");
+  preset.Set("source", "custom-preset");
+  preset.Set("builtin", false);
+  preset.Set("modified", true);
+
+  base::Value::Dict* media = preset.FindDict("mediaDevices");
+  ASSERT_TRUE(media);
+  media->Set("audioInputDeviceId", "manual-audio-input");
+  media->Set("videoInputDeviceId", "manual-video-input");
+  media->Set("audioOutputDeviceId", "manual-audio-output");
+  media->Set("inputGroupId", "manual-input-group");
+  media->Set("outputGroupId", "manual-output-group");
+  media->Set("audioInputLabel", "Manual Microphone");
+  media->Set("videoInputLabel", "Manual Camera");
+  media->Set("audioOutputLabel", "Manual Speakers");
+  media->Set("videoWidth", 1920);
+  media->Set("videoHeight", 1080);
+  media->Set("videoFrameRate", 59.94);
+  media->Set("audioSampleRate", 44100);
+  media->Set("audioSampleSize", 24);
+  media->Set("audioChannelCount", 1);
+  media->Set("audioLatency", 0.02);
+  media->Set("audioBaseLatency", 0.03);
+  media->Set("audioOutputLatency", 0.04);
+  media->Set("echoCancellation", false);
+  media->Set("autoGainControl", false);
+  media->Set("noiseSuppression", false);
+  media->Set("voiceIsolation", true);
+
+  base::Value::Dict* font_rendering = preset.FindDict("fontRendering");
+  ASSERT_TRUE(font_rendering);
+  font_rendering->Set("profileVersion", 7);
+
+  base::Value::Dict* advanced = preset.FindDict("advanced");
+  ASSERT_TRUE(advanced);
+  advanced->Set("allowWebSockets", false);
+  advanced->Set("allowWebTransport", false);
+  advanced->Set("allowAiApis", true);
+  advanced->Set("allowWebNn", true);
+  advanced->Set("allowPrivacySandboxApis", true);
+  advanced->Set("allowPrivateStateTokens", true);
+  advanced->Set("allowSpeechSynthesis", true);
+  advanced->Set("allowHandwritingRecognition", true);
+
+  base::Value::Dict saved = SavePersonaPreset(prefs, std::move(preset));
+  const std::string* saved_id = saved.FindString("id");
+  ASSERT_TRUE(saved_id);
+  const base::Value::Dict* saved_media = saved.FindDict("mediaDevices");
+  ASSERT_TRUE(saved_media);
+  EXPECT_EQ("manual-video-input",
+            *saved_media->FindString("videoInputDeviceId"));
+  EXPECT_EQ(1920, saved_media->FindInt("videoWidth").value_or(0));
+  EXPECT_EQ(59.94, saved_media->FindDouble("videoFrameRate").value_or(0));
+  EXPECT_FALSE(saved_media->FindBool("echoCancellation").value_or(true));
+  EXPECT_TRUE(saved_media->FindBool("voiceIsolation").value_or(false));
+  ASSERT_TRUE(saved.FindDict("fontRendering"));
+  EXPECT_EQ(7, saved.FindDict("fontRendering")
+                   ->FindInt("profileVersion")
+                   .value_or(0));
+  ASSERT_TRUE(saved.FindDict("advanced"));
+  EXPECT_FALSE(saved.FindDict("advanced")
+                   ->FindBool("allowWebSockets")
+                   .value_or(true));
+  EXPECT_TRUE(saved.FindDict("advanced")->FindBool("allowAiApis").value_or(false));
+
+  base::Value::Dict cloned = ClonePresetIntoProfile(prefs, *saved_id);
+  const base::Value::Dict* cloned_media = cloned.FindDict("mediaDevices");
+  ASSERT_TRUE(cloned_media);
+  EXPECT_EQ("manual-audio-input",
+            *cloned_media->FindString("audioInputDeviceId"));
+  EXPECT_EQ("manual-video-input",
+            *cloned_media->FindString("videoInputDeviceId"));
+  EXPECT_EQ(44100, cloned_media->FindInt("audioSampleRate").value_or(0));
+  EXPECT_EQ(24, cloned_media->FindInt("audioSampleSize").value_or(0));
+  EXPECT_EQ(1, cloned_media->FindInt("audioChannelCount").value_or(0));
+  EXPECT_TRUE(cloned_media->FindBool("voiceIsolation").value_or(false));
+  ASSERT_TRUE(cloned.FindDict("fontRendering"));
+  EXPECT_EQ(7, cloned.FindDict("fontRendering")
+                   ->FindInt("profileVersion")
+                   .value_or(0));
+
+  PersonaSnapshot snapshot = MakePersonaSnapshot(cloned);
+  EXPECT_EQ("manual-video-input", snapshot.media_video_input_device_id);
+  EXPECT_EQ(1920, snapshot.media_video_width);
+  EXPECT_EQ(1080, snapshot.media_video_height);
+  EXPECT_EQ(59.94, snapshot.media_video_frame_rate);
+  EXPECT_EQ(44100, snapshot.media_audio_sample_rate);
+  EXPECT_TRUE(snapshot.media_voice_isolation);
+  EXPECT_FALSE(snapshot.allow_web_sockets);
+  EXPECT_FALSE(snapshot.allow_web_transport);
+  EXPECT_TRUE(snapshot.allow_ai_apis);
+  EXPECT_TRUE(snapshot.allow_speech_synthesis);
+}
