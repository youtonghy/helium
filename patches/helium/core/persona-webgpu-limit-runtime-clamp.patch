@@ -87,6 +87,22 @@ bool RequiredLimitSupported(std::string_view name, T required, T supported) {
   }
   return required <= supported;
 }
+
+template <typename T>
+void ClampSupportedLimit(std::string_view name, T* target, T supported) {
+  if (supported == UndefinedLimitValue<T>()) {
+    return;
+  }
+  if (*target == UndefinedLimitValue<T>()) {
+    *target = supported;
+    return;
+  }
+  if (IsMinimumAlignmentLimit(name)) {
+    *target = std::max(*target, supported);
+  } else {
+    *target = std::min(*target, supported);
+  }
+}
