+      !persona_snapshot.font_metric_noise) {
+    return std::nullopt;
+  }
+
+  blink::HeliumNoiseTokenMap tokens = HeliumNoiseTokenData::GetTokens(
+      browser_context, origin, persona_snapshot);
+  auto token = tokens.find(feature);
+  if (token == tokens.end())
+    return std::nullopt;
+  return blink::NoiseToken(token->second.Value());
+}
