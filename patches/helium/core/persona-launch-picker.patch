+
+  static override get properties() {
+    return {
+      activePersonaId_: {type: String},
+      lastUsedPersonaId_: {type: String},
+      profiles_: {type: Array},
+      presets_: {type: Array},
+      selectedPersonaId_: {type: String},
+      rememberChoice_: {type: Boolean},
+    };
+  }
+
+  private accessor activePersonaId_: string = '';
+  private accessor lastUsedPersonaId_: string = '';
+  private accessor profiles_: any[] = [];
+  private accessor presets_: any[] = [];
+  private accessor selectedPersonaId_: string = '';
+  private accessor rememberChoice_: boolean = false;
+  private readonly browserProxy_: PersonaPickerBrowserProxy =
+      PersonaPickerBrowserProxyImpl.getInstance();
+
+  override connectedCallback() {
+    super.connectedCallback();
+    void this.load_();
+  }
+
+  override render() {
+    return html`
+      <div class="header">
+        <h1>Choose persona</h1>
+        <p>Select the persona to use for this browser startup.</p>
+      </div>
+      <div class="section">
+        <h2>Saved profiles</h2>
+        <div class="grid">
+          ${this.profiles_.map(profile => this.renderPersonaCard_(profile, false))}
+        </div>
+      </div>
+      <div class="section">
+        <h2>System presets</h2>
+        <div class="grid">
+          ${this.presets_.map(profile => this.renderPersonaCard_(profile, true))}
+        </div>
+      </div>
+      <div class="actions">
+        <div class="actions-left">
+          <cr-checkbox
+              .checked=${this.rememberChoice_}
+              @change=${this.onRememberChoiceChange_}>
+            Remember and use last selected persona next time
+          </cr-checkbox>
+        </div>
+        <div class="actions-right">
+          <cr-button @click=${this.onSkip_}>
+            Skip
+          </cr-button>
+          <cr-button class="action-button" @click=${this.onContinue_}>
+            Use Persona
+          </cr-button>
+        </div>
+      </div>
+    `;
+  }
+
+  private async load_() {
+    const response = await this.browserProxy_.getPersonaProfiles();
+    this.profiles_ = Array.isArray(response.profiles) ? response.profiles : [];
+    this.presets_ = Array.isArray(response.presets) ? response.presets : [];
+    this.activePersonaId_ = response.activePersonaId || '';
+    this.lastUsedPersonaId_ = response.lastUsedPersonaId || '';
+    this.selectedPersonaId_ = response.lastUsedPersonaId ||
+        response.activePersonaId ||
+        (this.profiles_[0]?.id || this.presets_[0]?.id || '');
+    this.rememberChoice_ = response.launchSelectionMode === 'use_last';
+  }
+
+  private onSelect_(personaId: string) {
+    this.selectedPersonaId_ = personaId;
+  }
+
+  private onRememberChoiceChange_(event: Event) {
+    const target = event.target as HTMLInputElement;
+    this.rememberChoice_ = !!target.checked;
+  }
+
+  private computeProfileSubtitle_(profile: any): string {
+    const platform = profile.platform || profile.uaCh?.platform ||
+        'Unknown platform';
+    const locale = profile.region?.locale || 'en-US';
+    return `${platform} | ${locale}`;
+  }
+
+  private computeProfileMeta_(profile: any): string {
+    const region = profile.region?.timezone || 'UTC';
+    const icon = profile.icon || 'default';
+    return `Icon: ${icon} | Timezone: ${region}`;
+  }
+
+  private computeLastUsedText_(lastUsedAt?: string): string {
+    if (!lastUsedAt) {
+      return 'Never';
+    }
+    return lastUsedAt;
+  }
+
+  private computeProfileStatus_(profile: any): string {
+    if (profile.id === this.selectedPersonaId_) {
+      return 'Selected';
+    }
+    if (profile.id === this.lastUsedPersonaId_) {
+      return 'Last used';
+    }
+    if (profile.id === this.activePersonaId_) {
+      return 'Active';
+    }
+    return 'Saved';
+  }
+
+  private renderPersonaCard_(profile: any, isPreset: boolean) {
+    return html`
+      <button class="card"
+          ?selected=${this.selectedPersonaId_ === (profile.id || '')}
+          @click=${() => this.onSelect_(profile.id || '')}>
+        <div class="card-header">
+          <div class="card-title">
+            <strong>${profile.displayName || profile.name || profile.id || 'Persona'}</strong>
+            <div class="card-subtitle">${this.computeProfileSubtitle_(profile)}</div>
+          </div>
+          <div class="card-status"
+              ?selected=${this.selectedPersonaId_ === (profile.id || '')}>
+            ${isPreset ? 'Preset' : this.computeProfileStatus_(profile)}
+          </div>
+        </div>
+        <div class="card-meta">
+          ${this.computeProfileMeta_(profile)}
+        </div>
+        <div class="card-footer">
+          ${isPreset ? 'Ready to clone into a session' :
+              `Last used: ${this.computeLastUsedText_(profile.lastUsedAt)}`}
+        </div>
+      </button>
+    `;
+  }
+
+  private async onSkip_() {
+    await this.browserProxy_.setLaunchSelectionMode(
+        this.rememberChoice_ ? 'use_last' : 'always_ask');
+    this.browserProxy_.skipPersonaForStartup();
+  }
+
+  private async onContinue_() {
+    await this.browserProxy_.setLaunchSelectionMode(
+        this.rememberChoice_ ? 'use_last' : 'always_ask');
+    this.browserProxy_.continueStartupWithPersona(this.selectedPersonaId_);
+  }
+}
+
+declare global {
+  interface HTMLElementTagNameMap {
+    'persona-picker-app': PersonaPickerAppElement;
+  }
+}
+
+customElements.define(PersonaPickerAppElement.is, PersonaPickerAppElement);
