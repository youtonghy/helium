+constexpr char kMessageGetPersonaProfiles[] = "getPersonaProfiles";
+constexpr char kMessageSetLaunchSelectionMode[] = "setLaunchSelectionMode";
+constexpr char kMessageContinueStartup[] = "continueStartupWithPersona";
+
+class PersonaPickerHandler : public content::WebUIMessageHandler {
+ public:
+  PersonaPickerHandler() = default;
+  ~PersonaPickerHandler() override = default;
+
+  void RegisterMessages() override {
+    web_ui()->RegisterMessageCallback(
+        kMessageGetPersonaProfiles,
+        base::BindRepeating(&PersonaPickerHandler::HandleGetPersonaProfiles,
+                            base::Unretained(this)));
+    web_ui()->RegisterMessageCallback(
+        kMessageSetLaunchSelectionMode,
+        base::BindRepeating(&PersonaPickerHandler::HandleSetLaunchSelectionMode,
+                            base::Unretained(this)));
+    web_ui()->RegisterMessageCallback(
+        kMessageContinueStartup,
+        base::BindRepeating(&PersonaPickerHandler::HandleContinueStartup,
+                            base::Unretained(this)));
+  }
+
+  void OnJavascriptAllowed() override {}
+
+ private:
+  void HandleGetPersonaProfiles(const base::ListValue& args) {
+    AllowJavascript();
+    CHECK_EQ(1U, args.size());
+    auto* service = helium_persona::PersonaServiceFactory::GetForProfile(
+        Profile::FromWebUI(web_ui()));
+    CHECK(service);
+    base::DictValue response = service->GetPersonaProfiles();
+    const base::DictValue state = service->GetPersonaState();
+    if (const base::ListValue* presets = state.FindList("presets")) {
+      response.Set("presets", presets->Clone());
+    } else {
+      response.Set("presets", base::ListValue());
+    }
+    ResolveJavascriptCallback(args[0], std::move(response));
+  }
+
+  void HandleSetLaunchSelectionMode(const base::ListValue& args) {
+    AllowJavascript();
+    CHECK_EQ(2U, args.size());
+    CHECK(args[1].is_string());
+
+    auto* service = helium_persona::PersonaServiceFactory::GetForProfile(
+        Profile::FromWebUI(web_ui()));
+    CHECK(service);
+    service->SetLaunchSelectionMode(args[1].GetString());
+    ResolveJavascriptCallback(args[0],
+                              base::Value(service->GetLaunchSelectionMode()));
+  }
+
+  void HandleContinueStartup(const base::ListValue& args) {
+    CHECK_EQ(1U, args.size());
+    CHECK(args[0].is_string());
+
+    Profile* profile = Profile::FromWebUI(web_ui());
+    pending_persona_id_ = args[0].GetString();
+
+    if (Browser* browser = chrome::FindBrowserWithTab(web_ui()->GetWebContents())) {
+      browser->window()->Close();
+      return;
+    }
+
+    ResumePendingLaunch();
+  }
+
+  void OnJavascriptDisallowed() override {
+    ResumePendingLaunch();
+  }
+
+  void ResumePendingLaunch() {
+    if (!pending_persona_id_) {
+      return;
+    }
+
+    std::string persona_id = *pending_persona_id_;
+    pending_persona_id_.reset();
+    StartupBrowserCreator::ResumePendingLaunchWithPersona(
+        Profile::FromWebUI(web_ui()), persona_id);
+  }
+
+  std::optional<std::string> pending_persona_id_;
+};
+
+void CreateAndAddPersonaPickerSource(Profile* profile) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kChromeUIPersonaPickerHost);
+  webui::SetupWebUIDataSource(source, kPersonaPickerResources,
+                              IDR_PERSONA_PICKER_PERSONA_PICKER_HTML);
+  source->UseStringsJs();
+}
+
+}  // namespace
