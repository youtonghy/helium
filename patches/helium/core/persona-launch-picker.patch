+struct PendingPersonaLaunchRequest {
+  base::CommandLine command_line;
+  base::FilePath cur_dir;
+  base::FilePath profile_path;
+  chrome::startup::IsProcessStartup process_startup =
+      chrome::startup::IsProcessStartup::kNo;
+  chrome::startup::IsFirstRun is_first_run = chrome::startup::IsFirstRun::kNo;
+  bool restore_tabbed_browser = true;
+  std::vector<GURL> first_run_tabs;
+};
+
+using PendingPersonaLaunchRequestMap =
+    std::map<base::FilePath, PendingPersonaLaunchRequest>;
+
+PendingPersonaLaunchRequestMap& GetPendingPersonaLaunchRequests() {
+  static base::NoDestructor<PendingPersonaLaunchRequestMap> requests;
+  return *requests;
+}
+
+bool ShouldShowPersonaPickerForProfile(Profile* profile) {
+  constexpr char kLaunchSelectionModeAlwaysAsk[] = "always_ask";
+  if (!profile || profile->IsOffTheRecord() || profile->IsGuestSession() ||
+      profile->IsSystemProfile()) {
+    return false;
+  }
+
+  auto* service = helium_persona::PersonaServiceFactory::GetForProfile(profile);
+  return service &&
+         service->GetLaunchSelectionMode() == kLaunchSelectionModeAlwaysAsk;
+}
+
+bool IsPresetPersonaId(Profile* profile, const std::string& persona_id) {
+  if (!profile || persona_id.empty()) {
+    return false;
+  }
+
+  auto* service = helium_persona::PersonaServiceFactory::GetForProfile(profile);
+  if (!service) {
+    return false;
+  }
+
+  const base::DictValue state = service->GetPersonaState();
+  const base::ListValue* presets = state.FindList("presets");
+  if (!presets) {
+    return false;
+  }
+
+  for (const auto& value : *presets) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const std::string* preset_id = value.GetDict().FindString("id");
+    if (preset_id && *preset_id == persona_id) {
+      return true;
+    }
+  }
+  return false;
+}
+
+GURL BuildPersonaPickerUrl() {
+  return GURL(chrome::kChromeUIPersonaPickerUrl);
+}
+
+void ApplyLastUsedPersonaOnStartup(Profile* profile) {
+  constexpr char kLaunchSelectionModeUseLast[] = "use_last";
+  if (!profile || profile->IsOffTheRecord() || profile->IsGuestSession() ||
+      profile->IsSystemProfile()) {
+    return;
+  }
+
+  auto* service = helium_persona::PersonaServiceFactory::GetForProfile(profile);
+  if (!service ||
+      service->GetLaunchSelectionMode() != kLaunchSelectionModeUseLast) {
+    return;
+  }
+
+  const std::string persona_id = service->GetLastUsedPersonaId();
+  if (!persona_id.empty()) {
+    service->SetActivePersona(persona_id);
+  }
+}
