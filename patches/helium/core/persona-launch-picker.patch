+// static
+bool StartupBrowserCreator::MaybeLaunchPersonaPickerOnStartup(
+    const base::CommandLine& command_line,
+    const base::FilePath& cur_dir,
+    chrome::startup::IsProcessStartup process_startup,
+    chrome::startup::IsFirstRun is_first_run,
+    Profile* profile,
+    bool restore_tabbed_browser,
+    const std::vector<GURL>& first_run_tabs) {
+  if (!ShouldShowPersonaPickerForProfile(profile)) {
+    return false;
+  }
+
+  auto& pending_requests = GetPendingPersonaLaunchRequests();
+  PendingPersonaLaunchRequest request;
+  request.command_line = command_line;
+  request.cur_dir = cur_dir;
+  request.profile_path = profile->GetPath();
+  request.process_startup = process_startup;
+  request.is_first_run = is_first_run;
+  request.restore_tabbed_browser = restore_tabbed_browser;
+  request.first_run_tabs = first_run_tabs;
+  pending_requests[request.profile_path] = std::move(request);
+
+  persona_picker::ShowPersonaPickerForStartup(profile, BuildPersonaPickerUrl());
+  return true;
+}
+
+// static
+void StartupBrowserCreator::ResumePendingLaunchWithPersona(
+    Profile* profile,
+    const std::string& persona_id) {
+  if (!profile) {
+    return;
+  }
+
+  auto& pending_requests = GetPendingPersonaLaunchRequests();
+  auto it = pending_requests.find(profile->GetPath());
+  if (it == pending_requests.end()) {
+    return;
+  }
+
+  PendingPersonaLaunchRequest request = std::move(it->second);
+  pending_requests.erase(it);
+
+  auto* service = helium_persona::PersonaServiceFactory::GetForProfile(profile);
+  if (service) {
+    if (persona_id.empty()) {
+      service->SetActivePersona(kDefaultPersonaId);
+    } else if (IsPresetPersonaId(profile, persona_id)) {
+      service->ClonePresetIntoProfile(persona_id);
+    } else {
+      service->SetActivePersona(persona_id);
+    }
+  }
+
+  StartupBrowserCreator browser_creator;
+  browser_creator.AddFirstRunTabs(request.first_run_tabs);
+  browser_creator.LaunchBrowser(request.command_line, profile, request.cur_dir,
+                                request.process_startup, request.is_first_run,
+                                request.restore_tabbed_browser);
+}
