+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import {chromeSend} from 'chrome://resources/js/cr.js';
+import {sendWithPromise} from 'chrome://resources/js/cr.js';
+
+export interface PersonaProfilesResponse {
+  profiles: any[];
+  presets?: any[];
+  activePersonaId: string;
+  lastUsedPersonaId?: string;
+  launchSelectionMode?: string;
+}
+
+export interface PersonaPickerBrowserProxy {
+  getPersonaProfiles(): Promise<PersonaProfilesResponse>;
+  setLaunchSelectionMode(mode: string): Promise<string>;
+  continueStartupWithPersona(personaId: string): void;
+  skipPersonaForStartup(): void;
+}
+
+let instance: PersonaPickerBrowserProxy|null = null;
+
+export class PersonaPickerBrowserProxyImpl
+    implements PersonaPickerBrowserProxy {
+  getPersonaProfiles() {
+    return sendWithPromise<PersonaProfilesResponse>('getPersonaProfiles');
+  }
+
+  setLaunchSelectionMode(mode: string) {
+    return sendWithPromise<string>('setLaunchSelectionMode', mode);
+  }
+
+  continueStartupWithPersona(personaId: string) {
+    chromeSend('continueStartupWithPersona', [personaId]);
+  }
+
+  skipPersonaForStartup() {
+    chromeSend('continueStartupWithPersona', ['']);
+  }
+
+  static getInstance(): PersonaPickerBrowserProxy {
+    return instance || (instance = new PersonaPickerBrowserProxyImpl());
+  }
+}
