+PersonaPickerUI::PersonaPickerUI(content::WebUI* web_ui)
+    : TopChromeWebUIController(web_ui, /*enable_chrome_send=*/true) {
+  Profile* profile = Profile::FromWebUI(web_ui);
+  web_ui->AddMessageHandler(std::make_unique<PersonaPickerHandler>());
+  CreateAndAddPersonaPickerSource(profile);
+}
