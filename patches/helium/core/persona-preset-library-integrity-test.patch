diff --git a/components/helium_persona/persona_prefs_unittest.cc b/components/helium_persona/persona_prefs_unittest.cc
--- a/components/helium_persona/persona_prefs_unittest.cc
+++ b/components/helium_persona/persona_prefs_unittest.cc
@@ -2656,5 +2656,111 @@ TEST(HeliumPersonaPrefsTest, ManualOverridesFlowIntoPersonaSnapshot) {
   EXPECT_TRUE(snapshot.reduce_system_info);
   EXPECT_FALSE(snapshot.canvas_noise);
 }
 
+TEST(HeliumPersonaPrefsTest, BuiltinPersonaLibraryHasRuntimeIntegrity) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  ASSERT_GT(presets.size(), 1u);
+
+  const auto value_seen_before = [](const base::Value::List& seen,
+                                    const std::string& candidate) {
+    for (const base::Value& value : seen) {
+      const std::string* item = value.GetIfString();
+      if (item && *item == candidate) {
+        return true;
+      }
+    }
+    return false;
+  };
+
+  base::Value::List seen_ids;
+  base::Value::List seen_noise_seeds;
+
+  for (const base::Value& value : presets) {
+    const base::Value::Dict* preset = value.GetIfDict();
+    ASSERT_TRUE(preset);
+    const std::string* id = preset->FindString("id");
+    ASSERT_TRUE(id);
+    ASSERT_FALSE(id->empty());
+    SCOPED_TRACE(*id);
+    EXPECT_FALSE(value_seen_before(seen_ids, *id));
+    seen_ids.Append(*id);
+    EXPECT_TRUE(preset->FindString("name"));
+
+    if (preset->FindBool("passthrough").value_or(false)) {
+      continue;
+    }
+
+    const std::string* noise_seed = preset->FindString("noiseSeed");
+    ASSERT_TRUE(noise_seed);
+    ASSERT_FALSE(noise_seed->empty());
+    EXPECT_FALSE(value_seen_before(seen_noise_seeds, *noise_seed));
+    seen_noise_seeds.Append(*noise_seed);
+
+    EXPECT_TRUE(PersonaHasRequiredFields(*preset));
+    PersonaSnapshot snapshot = MakePersonaSnapshot(*preset);
+    EXPECT_EQ(*id, snapshot.id);
+    EXPECT_EQ(*noise_seed, snapshot.noise_seed);
+    EXPECT_FALSE(snapshot.passthrough);
+    EXPECT_FALSE(snapshot.user_agent.empty());
+    EXPECT_FALSE(snapshot.platform.empty());
+    EXPECT_FALSE(snapshot.ua_ch_platform.empty());
+
+    const base::Value::Dict* region = preset->FindDict("region");
+    ASSERT_TRUE(region);
+    const std::string* locale = region->FindString("locale");
+    const std::string* accept_language = region->FindString("acceptLanguage");
+    const base::Value::List* navigator_languages =
+        region->FindList("navigatorLanguages");
+    ASSERT_TRUE(locale);
+    ASSERT_TRUE(accept_language);
+    ASSERT_TRUE(navigator_languages);
+    ASSERT_FALSE(locale->empty());
+    ASSERT_FALSE(accept_language->empty());
+    ASSERT_FALSE(navigator_languages->empty());
+    EXPECT_EQ(*locale, (*navigator_languages)[0].GetString());
+    EXPECT_EQ(0u, accept_language->find(*locale));
+    EXPECT_EQ(*locale, snapshot.locale);
+    EXPECT_EQ(*accept_language, snapshot.accept_language);
+    ASSERT_FALSE(snapshot.navigator_languages.empty());
+    EXPECT_EQ(*locale, snapshot.navigator_languages[0]);
+
+    EXPECT_FALSE(snapshot.gpu_renderer.empty());
+    EXPECT_GT(snapshot.screen_width, 0);
+    EXPECT_GT(snapshot.screen_height, 0);
+    EXPECT_GT(snapshot.device_scale_factor, 0);
+    EXPECT_GT(snapshot.color_depth, 0);
+    EXPECT_GT(snapshot.hardware_concurrency, 0);
+    EXPECT_GT(snapshot.device_memory, 0);
+    EXPECT_FALSE(snapshot.font_pack_id.empty());
+    EXPECT_FALSE(snapshot.font_families.empty());
+    EXPECT_FALSE(snapshot.font_rendering_id.empty());
+    EXPECT_GT(snapshot.font_rendering_profile_version, 0);
+    EXPECT_FALSE(snapshot.font_rendering_engine.empty());
+    EXPECT_FALSE(snapshot.font_rendering_hinting.empty());
+    EXPECT_FALSE(snapshot.media_video_input_device_id.empty());
+    EXPECT_FALSE(snapshot.media_audio_input_device_id.empty());
+    EXPECT_FALSE(snapshot.network_effective_type.empty());
+
+    base::Value::Dict round_tripped = PersonaSnapshotToValue(snapshot);
+    EXPECT_TRUE(PersonaHasRequiredFields(round_tripped));
+    const std::string* round_trip_id = round_tripped.FindString("id");
+    ASSERT_TRUE(round_trip_id);
+    EXPECT_EQ(*id, *round_trip_id);
+    const base::Value::Dict* round_trip_region =
+        round_tripped.FindDict("region");
+    ASSERT_TRUE(round_trip_region);
+    const std::string* round_trip_locale =
+        round_trip_region->FindString("locale");
+    ASSERT_TRUE(round_trip_locale);
+    EXPECT_EQ(*locale, *round_trip_locale);
+    const base::Value::Dict* round_trip_font_rendering =
+        round_tripped.FindDict("fontRendering");
+    ASSERT_TRUE(round_trip_font_rendering);
+    EXPECT_EQ(snapshot.font_rendering_profile_version,
+              round_trip_font_rendering->FindInt("profileVersion")
+                  .value_or(0));
+    EXPECT_TRUE(ValidatePersona(round_tripped).empty());
+  }
+}
+
 }  // namespace helium_persona
