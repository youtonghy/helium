+void EnsureMediaDevicesCompatibilityFields(base::Value::Dict& persona) {
+  if (!persona.FindDict("mediaDevices")) {
+    persona.Set("mediaDevices", MakeDefaultMediaDevicesProfile());
+    return;
+  }
+
+  base::Value::Dict* media = persona.FindDict("mediaDevices");
+  EnsureString(*media, "audioInputDeviceId", "persona-audio-input-default");
+  EnsureString(*media, "videoInputDeviceId", "persona-video-input-default");
+  EnsureString(*media, "audioOutputDeviceId", "persona-audio-output-default");
+  EnsureString(*media, "inputGroupId", "persona-media-group-input");
+  EnsureString(*media, "outputGroupId", "persona-media-group-output");
+  EnsureString(*media, "audioInputLabel", "Default Microphone");
+  EnsureString(*media, "videoInputLabel", "Integrated Camera");
+  EnsureString(*media, "audioOutputLabel", "Default Speakers");
+  if (!media->FindInt("videoWidth")) {
+    media->Set("videoWidth", 1280);
+  }
+  if (!media->FindInt("videoHeight")) {
+    media->Set("videoHeight", 720);
+  }
+  EnsureNumeric(*media, "videoFrameRate", 30.0);
+  if (!media->FindInt("audioSampleRate")) {
+    media->Set("audioSampleRate", 48000);
+  }
+  if (!media->FindInt("audioSampleSize")) {
+    media->Set("audioSampleSize", 16);
+  }
+  if (!media->FindInt("audioChannelCount")) {
+    media->Set("audioChannelCount", 2);
+  }
+  EnsureNumeric(*media, "audioLatency", 0.01);
+  EnsureNumeric(*media, "audioBaseLatency", 0.01);
+  EnsureNumeric(*media, "audioOutputLatency", 0.02);
+  EnsureBool(*media, "echoCancellation", true);
+  EnsureBool(*media, "autoGainControl", true);
+  EnsureBool(*media, "noiseSuppression", true);
+  EnsureBool(*media, "voiceIsolation", false);
+}
