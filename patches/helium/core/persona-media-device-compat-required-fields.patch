+TEST(HeliumPersonaPrefsTest, CompatibilityRepairsMissingMediaDeviceFields) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona =
+      ClonePresetIntoProfile(prefs, "preset-windows-11-en-us-new-york");
+  persona.Remove("mediaDevices");
+
+  SavePersona(prefs, std::move(persona));
+  base::Value::Dict active = GetActivePersona(prefs);
+  ASSERT_TRUE(active.FindDict("mediaDevices"));
+  EXPECT_TRUE(PersonaHasRequiredFields(active));
+}
+
+TEST(HeliumPersonaPrefsTest, ValidationRequiresMediaDeviceFields) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona =
+      ClonePresetIntoProfile(prefs, "preset-windows-11-en-us-new-york");
+  base::Value::Dict* media_devices = persona.FindDict("mediaDevices");
+  ASSERT_TRUE(media_devices);
+  media_devices->Remove("videoInputDeviceId");
+  media_devices->Remove("audioOutputLabel");
+  media_devices->Remove("videoWidth");
+  media_devices->Remove("audioSampleRate");
+  media_devices->Remove("audioLatency");
+  media_devices->Remove("echoCancellation");
+
+  EXPECT_FALSE(PersonaHasRequiredFields(persona));
+  base::Value::List warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "missing one or more required fields"));
+}
