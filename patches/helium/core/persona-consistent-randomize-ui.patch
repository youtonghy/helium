+  private makeScreenProfile_(
+      width: number, height: number, deviceScaleFactor: number,
+      refreshRate: number, reservedHeight: number): Record<string, unknown> {
+    const availHeight = Math.max(1, height - reservedHeight);
+    const outerWidth = this.randomInt_(
+        Math.max(1, Math.floor(width * 0.72)), width);
+    const outerHeight = this.randomInt_(
+        Math.max(1, Math.floor(availHeight * 0.72)), availHeight);
+    const maxX = Math.max(0, width - outerWidth);
+    const maxY = Math.max(0, availHeight - outerHeight);
+    return {
+      width,
+      height,
+      availLeft: 0,
+      availTop: 0,
+      availWidth: width,
+      availHeight,
+      outerWidth,
+      outerHeight,
+      windowScreenX: this.randomInt_(0, Math.min(160, maxX)),
+      windowScreenY: this.randomInt_(0, Math.min(120, maxY)),
+      deviceScaleFactor,
+      colorDepth: 24,
+      pixelDepth: 24,
+      refreshRate,
+      orientationType: 'landscape-primary',
+      orientationAngle: 0,
