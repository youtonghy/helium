+  private randomInt_(min: number, max: number): number {
+    const lower = Math.ceil(min);
+    const upper = Math.floor(max);
+    if (upper <= lower) {
+      return lower;
+    }
+    const range = upper - lower + 1;
+    const array = new Uint32Array(1);
+    if (window.crypto?.getRandomValues) {
+      window.crypto.getRandomValues(array);
+      return lower + array[0] % range;
+    }
+    return lower + Math.floor(Math.random() * range);
+  }
+
+  private randomFrom_<T>(items: T[], fallback: T): T {
+    if (!items.length) {
+      return fallback;
+    }
+    return items[this.randomInt_(0, items.length - 1)];
+  }
+
+  private personaOsFamily_(persona: PersonaRecord): string {
+    const surface = [
+      persona.os || '',
+      persona.platform || '',
+      persona.userAgent || '',
+    ].join(' ').toLowerCase();
+    if (surface.includes('mac')) {
+      return 'mac';
+    }
+    if (surface.includes('linux') || surface.includes('x11')) {
+      return 'linux';
+    }
+    return 'windows';
+  }
+
+  private pickRandomBasePersona_(): PersonaRecord|null {
+    const candidates = (this.presets_ || [])
+        .filter(item => !this.isPassthroughPersona_(item));
+    if (candidates.length) {
+      return this.randomFrom_(candidates, candidates[0]);
+    }
+    if (this.editablePersona_ &&
+        !this.isPassthroughPersona_(this.editablePersona_)) {
+      return this.editablePersona_;
+    }
+    return null;
+  }
+
+  private randomProfileByPrefix_(
+      profiles: Array<Record<string, unknown>>, prefixes: string[],
+      fallback: Record<string, unknown>): Record<string, unknown> {
+    for (const prefix of prefixes) {
+      const matches = (profiles || []).filter(profile => {
+        const id = String(profile['id'] || '');
+        return id.startsWith(prefix);
+      });
+      if (matches.length) {
+        return this.randomFrom_(matches, matches[0]);
+      }
+    }
+    return fallback;
+  }
+
+  private localeScopedFontPrefixes_(persona: PersonaRecord): string[] {
+    const osFamily = this.personaOsFamily_(persona);
+    const osPrefix = osFamily === 'mac' ? 'macos-' :
+        osFamily === 'linux' ? 'linux-' : 'windows-';
+    const region = persona.region || {};
+    const locale = String(region['locale'] || '')
+        .trim()
+        .toLowerCase()
+        .replace(/_/g, '-');
+    if (!locale) {
+      return [osPrefix];
+    }
+    const language = locale.split('-')[0];
+    return [
+      `${osPrefix}${locale}`,
+      language ? `${osPrefix}${language}` : '',
+      osPrefix,
+    ].filter(Boolean);
+  }
+
+  private applyConsistentRandomFonts_(persona: PersonaRecord) {
+    const osFamily = this.personaOsFamily_(persona);
+    const fontPackPrefixes = this.localeScopedFontPrefixes_(persona);
+    const renderingPrefixes = osFamily === 'mac' ? ['macos-'] :
+        osFamily === 'linux' ? ['linux-'] : ['windows-'];
+    const fontPack = this.randomProfileByPrefix_(
+        this.fontPackProfiles_, fontPackPrefixes, persona.fonts || {});
+    const rendering = this.randomProfileByPrefix_(
+        this.fontRenderingProfiles_, renderingPrefixes,
+        persona.fontRendering || {});
+    persona.fonts = JSON.parse(JSON.stringify(fontPack));
+    persona.fontRendering = JSON.parse(JSON.stringify(rendering));
+  }
