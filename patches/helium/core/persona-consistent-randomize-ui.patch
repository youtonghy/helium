+      reducedMotion: 'no-preference',
+      reducedTransparency: 'no-preference',
+      preferredContrast: 'no-preference',
+      forcedColors: 'none',
+      invertedColors: 'none',
+      colorGamut: deviceScaleFactor > 1 ? 'p3' : 'srgb',
+      dynamicRange: 'standard',
+      monochromeDepth: 0,
+    };
+  }
