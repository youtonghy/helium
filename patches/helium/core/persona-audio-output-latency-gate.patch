diff --git a/third_party/blink/renderer/modules/webaudio/audio_context.cc b/third_party/blink/renderer/modules/webaudio/audio_context.cc
--- a/third_party/blink/renderer/modules/webaudio/audio_context.cc
+++ b/third_party/blink/renderer/modules/webaudio/audio_context.cc
@@ -1159,6 +1159,11 @@ double AudioContext::outputLatency() const {
 
   DeferredTaskHandler::GraphAutoLocker locker(this);
 
+  if (!base::FeatureList::IsEnabled(blink::features::kHeliumNoiseAudio) ||
+      !PersonaSpoofingHelper::AudioNoiseEnabled(GetExecutionContext())) {
+    return output_position_.hardware_output_latency;
+  }
+
   double factor = GetOutputLatencyQuantizingFactor();
   return std::round(output_position_.hardware_output_latency / factor) * factor;
 }
