+void ApplyHeliumPersonaMediaPreferenceSettings(
+    WebViewImpl* web_view,
+    const HeliumPersonaSnapshot& snapshot,
+    bool clear_if_disabled) {
+  if (!web_view) {
+    return;
+  }
+
+  Page* page = web_view->GetPage();
+  if (!page) {
+    return;
+  }
+
+  if (!snapshot.IsEnabled()) {
+    if (clear_if_disabled) {
+      page->ClearMediaFeatureOverrides();
+      page->ClearPreferenceOverrides();
+    }
+    return;
+  }
+
+  const bool reduced_motion =
+      HeliumPersonaStringEquals(snapshot.reduced_motion, "reduce");
+  Settings& settings = page->GetSettings();
+  settings.SetPrefersReducedMotion(reduced_motion);
+  settings.SetPrefersReducedTransparency(
+      HeliumPersonaStringEquals(snapshot.reduced_transparency, "reduce"));
+  settings.SetInvertedColors(
+      HeliumPersonaStringEquals(snapshot.inverted_colors, "inverted"));
+  settings.SetInForcedColors(
+      HeliumPersonaStringEquals(snapshot.forced_colors, "active"));
+  if (HeliumPersonaStringEquals(snapshot.color_scheme, "dark")) {
+    settings.SetPreferredColorScheme(mojom::blink::PreferredColorScheme::kDark);
+  } else if (HeliumPersonaStringEquals(snapshot.color_scheme, "light")) {
+    settings.SetPreferredColorScheme(
+        mojom::blink::PreferredColorScheme::kLight);
+  }
+
+  page->SetPreferenceOverride(AtomicString("prefers-color-scheme"),
+                              String::FromUTF8(snapshot.color_scheme));
+  page->SetPreferenceOverride(AtomicString("prefers-reduced-motion"),
+                              String::FromUTF8(snapshot.reduced_motion));
+  page->SetPreferenceOverride(AtomicString("prefers-reduced-transparency"),
+                              String::FromUTF8(snapshot.reduced_transparency));
+  page->SetPreferenceOverride(AtomicString("prefers-contrast"),
+                              String::FromUTF8(snapshot.preferred_contrast));
+  page->SetMediaFeatureOverride(AtomicString("forced-colors"),
+                                String::FromUTF8(snapshot.forced_colors));
+  page->SetMediaFeatureOverride(AtomicString("inverted-colors"),
+                                String::FromUTF8(snapshot.inverted_colors));
+  page->SetMediaFeatureOverride(AtomicString("color-gamut"),
+                                String::FromUTF8(snapshot.color_gamut));
+  page->SetMediaFeatureOverride(AtomicString("dynamic-range"),
+                                String::FromUTF8(snapshot.dynamic_range));
+  page->SetMediaFeatureOverride(AtomicString("video-dynamic-range"),
+                                String::FromUTF8(snapshot.dynamic_range));
+  page->SetMediaFeatureOverride(
+      AtomicString("monochrome"),
+      String::Number(std::max(0, snapshot.monochrome_depth)));
+
+  ForEachFrameWidgetControlledByView(
+      *web_view, [reduced_motion](WebFrameWidgetImpl* widget) {
+        widget->SetPrefersReducedMotion(reduced_motion);
+      });
+}
