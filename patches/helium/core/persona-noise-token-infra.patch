+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef THIRD_PARTY_BLINK_PUBLIC_COMMON_HELIUM_NOISE_NOISE_TOKEN_H_
+#define THIRD_PARTY_BLINK_PUBLIC_COMMON_HELIUM_NOISE_NOISE_TOKEN_H_
+
+#include <cstdint>
+#include <map>
+
+namespace blink {
+
+enum class HeliumNoiseFeature {
+  kCanvas,
+  kAudio,
+  kHardware,
+  kFontMetric,
+};
+
+class HeliumNoiseToken {
+ public:
+  constexpr HeliumNoiseToken() = default;
+  explicit constexpr HeliumNoiseToken(uint64_t value) : value_(value) {}
+
+  constexpr uint64_t Value() const { return value_; }
+
+ private:
+  uint64_t value_ = 0;
+};
+
+using HeliumNoiseTokenMap = std::map<HeliumNoiseFeature, HeliumNoiseToken>;
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_PUBLIC_COMMON_HELIUM_NOISE_NOISE_TOKEN_H_
