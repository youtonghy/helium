@@ -159,6 +159,26 @@ void ExpectAdvancedExposedApiFields(const base::Value::Dict& advanced) {
   EXPECT_TRUE(advanced.FindString("speechVoiceUri"));
 }
 
+void ExpectPresetSpeechVoice(const base::Value::List& presets,
+                             std::string_view id,
+                             std::string_view expected_name,
+                             std::string_view expected_lang) {
+  SCOPED_TRACE(id);
+  const base::Value::Dict* preset = FindProfileById(presets, id);
+  ASSERT_TRUE(preset);
+  const base::Value::Dict* advanced = preset->FindDict("advanced");
+  ASSERT_TRUE(advanced);
+  const std::string* voice_name = advanced->FindString("speechVoiceName");
+  ASSERT_TRUE(voice_name);
+  const std::string* voice_lang = advanced->FindString("speechVoiceLang");
+  ASSERT_TRUE(voice_lang);
+  const std::string* voice_uri = advanced->FindString("speechVoiceUri");
+  ASSERT_TRUE(voice_uri);
+  EXPECT_EQ(std::string(expected_name), *voice_name);
+  EXPECT_EQ(std::string(expected_lang), *voice_lang);
+  EXPECT_EQ(std::string(expected_name), *voice_uri);
+}
+
 }  // namespace
 
