+TEST(HeliumPersonaPrefsTest,
+     ValidationWarnsForMacFontRenderingDisplayMismatch) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict retina_persona = ClonePresetIntoProfile(
+      prefs, "preset-macos-en-au-melbourne");
+  base::Value::Dict* screen = retina_persona.FindDict("screen");
+  ASSERT_TRUE(screen);
+  screen->Set("deviceScaleFactor", 2);
+  base::Value::Dict* font_rendering =
+      retina_persona.FindDict("fontRendering");
+  ASSERT_TRUE(font_rendering);
+  font_rendering->Set("id", "macos-coretext-non-retina");
+  font_rendering->Set("displayName", "macOS CoreText non-Retina");
+  font_rendering->Set("engine", "CoreText");
+
+  base::Value::List retina_warnings = ValidatePersona(retina_persona);
+  EXPECT_TRUE(WarningsContain(retina_warnings, "Retina macOS personas"));
+  EXPECT_TRUE(SavePersona(prefs, std::move(retina_persona)));
+
+  base::Value::Dict non_retina_persona = ClonePresetIntoProfile(
+      prefs, "preset-macos-en-au-melbourne");
+  screen = non_retina_persona.FindDict("screen");
+  ASSERT_TRUE(screen);
+  screen->Set("deviceScaleFactor", 1);
+  font_rendering = non_retina_persona.FindDict("fontRendering");
+  ASSERT_TRUE(font_rendering);
+  font_rendering->Set("id", "macos-coretext");
+  font_rendering->Set("displayName", "macOS CoreText Retina");
+  font_rendering->Set("engine", "CoreText");
+
+  base::Value::List non_retina_warnings = ValidatePersona(non_retina_persona);
+  EXPECT_TRUE(WarningsContain(non_retina_warnings,
+                              "Non-Retina macOS personas"));
+  EXPECT_TRUE(SavePersona(prefs, std::move(non_retina_persona)));
+}
