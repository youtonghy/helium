+  private displayScopedFontRenderingProfiles_(
+      persona: PersonaRecord,
+      profiles: Array<Record<string, unknown>>):
+      Array<Record<string, unknown>> {
+    if (this.personaOsFamily_(persona) !== 'mac') {
+      return profiles;
+    }
+    const macProfiles = (profiles || []).filter(profile =>
+        String(profile['id'] || '').startsWith('macos-'));
+    if (!macProfiles.length) {
+      return profiles;
+    }
+    const screen = persona.screen || {};
+    const dpr = this.numberValue_(screen['deviceScaleFactor']);
+    const preferred = dpr > 1 ?
+        macProfiles.filter(profile =>
+            !this.contains_(String(profile['id'] || ''), 'non-retina') &&
+            !this.contains_(
+                String(profile['displayName'] || ''), 'non-retina')) :
+        macProfiles.filter(profile => {
