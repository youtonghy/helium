+              this.contains_(displayName, 'non-retina') ||
+              this.contains_(id, 'legacy') ||
+              this.contains_(displayName, 'legacy') ||
+              this.contains_(id, 'external') ||
+              this.contains_(displayName, 'external');
+        });
+    return preferred.length ? preferred : macProfiles;
+  }
