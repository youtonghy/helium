+  AllowJavascript();
+  CHECK_EQ(2U, args.size());
+  const base::Value& callback_id = args[0];
+  CHECK(args[1].is_dict());
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(callback_id,
+                            service->SavePersona(args[1].GetDict()));
+}
+
+void PersonaHandler::HandleSetActivePersona(const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(2U, args.size());
+  const base::Value& callback_id = args[0];
+  CHECK(args[1].is_string());
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(
