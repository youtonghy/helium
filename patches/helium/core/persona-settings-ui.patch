+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+import {sendWithPromise} from 'chrome://resources/js/cr.js';
+
+export interface PersonaPageResponse {
+  ok: boolean;
+  state: any;
+  fieldErrors: any;
+}
+
+export interface PersonaBrowserProxy {
+  getPersonaState(): Promise<any>;
+  savePersona(persona: any): Promise<PersonaPageResponse>;
+  setActivePersona(personaId: string): Promise<PersonaPageResponse>;
+  clonePresetIntoProfile(presetId: string): Promise<PersonaPageResponse>;
+  deletePersona(personaId: string): Promise<PersonaPageResponse>;
+}
+
+let instance: PersonaBrowserProxy|null = null;
+
+export class PersonaBrowserProxyImpl implements PersonaBrowserProxy {
+  getPersonaState() { return sendWithPromise<any>('getPersonaState'); }
+  savePersona(persona: any) { return sendWithPromise<PersonaPageResponse>('savePersona', persona); }
+  setActivePersona(personaId: string) { return sendWithPromise<PersonaPageResponse>('setActivePersona', personaId); }
+  clonePresetIntoProfile(presetId: string) { return sendWithPromise<PersonaPageResponse>('clonePresetIntoProfile', presetId); }
+  deletePersona(personaId: string) { return sendWithPromise<PersonaPageResponse>('deletePersona', personaId); }
+  static getInstance(): PersonaBrowserProxy {
+    return instance || (instance = new PersonaBrowserProxyImpl());
+  }
+}
