+    };
+  }
+
+  connectedCallback() {
+    super.connectedCallback();
+    this.loadPersonaState_();
+  }
+
+  private async loadPersonaState_() {
+    const state = await PersonaBrowserProxyImpl.getInstance().getPersonaState();
+    this.applyPersonaState_(state);
+  }
+
+  private applyPersonaState_(state: any) {
+    const personas = Array.isArray(state.personas) ? state.personas : [];
+    const activePersona = personas.find((persona: any) => {
+      return persona && persona.id === state.activePersonaId;
+    }) || personas[0];
+    if (!activePersona) {
+      return;
+    }
+
+    this.editablePersona_ = {
+      ...this.editablePersona_,
+      ...activePersona,
+      advanced: {
+        ...this.editablePersona_.advanced,
+        ...(activePersona.advanced || {}),
+      },
+      region: {
+        ...this.editablePersona_.region,
+        ...(activePersona.region || {}),
+      },
+      uaCh: {
+        ...this.editablePersona_.uaCh,
+        ...(activePersona.uaCh || {}),
+      },
+    };
+  }
+
+  private applyPersonaResponse_(response: PersonaPageResponse) {
+    if (response.ok) {
