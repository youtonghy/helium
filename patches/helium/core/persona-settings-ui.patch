+}
+
+const Base = I18nMixin(PrefsMixin(PolymerElement));
+
+export class SettingsPersonaPageElement extends Base {
+  static get is() {
+    return 'settings-persona-page';
+  }
+
+  static get template() {
+    return getTemplate();
+  }
+
+  static get properties() {
+    return {
+      activePersonaId_: {type: String, value: ''},
+      editablePersona_: {type: Object, value: () => createEmptyPersona()},
+      lastUsedPersonaId_: {type: String, value: ''},
+      launchSelectionMode_: {type: String, value: 'always_ask'},
+      presets_: {type: Array, value: () => []},
+      profiles_: {type: Array, value: () => []},
+      routePath: String,
+      selectedPresetId_: {type: String, value: ''},
+      selectedProfileId_: {type: String, value: ''},
+      uaChBrandsText_: String,
+      uaChFullVersionListText_: String,
+      uaChFormFactorsText_: String,
+      navigatorLanguagesText_: String,
+      webgpuFeaturesText_: String,
+      fontFamiliesText_: String,
+      fontAliasesText_: String,
+    };
+  }
+
+  declare private activePersonaId_: string;
+  declare private editablePersona_: PersonaRecord;
+  declare private lastUsedPersonaId_: string;
+  declare private launchSelectionMode_: string;
+  declare private presets_: PersonaRecord[];
+  declare private profiles_: PersonaRecord[];
+  declare routePath: string;
+  declare private selectedPresetId_: string;
+  declare private selectedProfileId_: string;
+  declare private uaChBrandsText_: string;
+  declare private uaChFullVersionListText_: string;
+  declare private uaChFormFactorsText_: string;
+  declare private navigatorLanguagesText_: string;
+  declare private webgpuFeaturesText_: string;
+  declare private fontFamiliesText_: string;
+  declare private fontAliasesText_: string;
+
+  override connectedCallback() {
+    super.connectedCallback();
+    this.loadPersonaData_();
+  }
+
+  private async loadPersonaData_() {
+    const browserProxy = PersonaBrowserProxyImpl.getInstance();
+    const [state, profilesResponse, launchSelectionMode] = await Promise.all([
+      browserProxy.getPersonaState(),
+      browserProxy.getPersonaProfiles(),
+      browserProxy.getLaunchSelectionMode(),
+    ]);
+    this.launchSelectionMode_ = launchSelectionMode || 'always_ask';
+    this.applyPersonaState_(state, profilesResponse);
+  }
+
+  private applyPersonaState_(
+      state: any, profilesResponse?: PersonaProfilesResponse) {
+    this.presets_ = Array.isArray(state.presets) ? state.presets : [];
+    const profiles = Array.isArray(profilesResponse?.profiles) ?
+        profilesResponse.profiles :
+        (Array.isArray(state.personas) ? state.personas : []);
+    this.profiles_ = profiles;
+    this.activePersonaId_ = state.activePersonaId || profilesResponse?.activePersonaId || '';
+    this.lastUsedPersonaId_ =
+        state.lastUsedPersonaId || profilesResponse?.lastUsedPersonaId || '';
+    this.launchSelectionMode_ =
+        state.launchSelectionMode || profilesResponse?.launchSelectionMode ||
+        this.launchSelectionMode_;
+
+    const targetProfileId =
+        this.selectedProfileId_ || this.activePersonaId_ || this.lastUsedPersonaId_;
+    const selectedProfile = profiles.find((persona: PersonaRecord) => {
+      return persona && persona.id === targetProfileId;
+    }) || profiles.find((persona: PersonaRecord) => {
+      return persona && persona.id === this.activePersonaId_;
+    }) || profiles[0];
+    if (!selectedProfile) {
+      return;
+    }
+
+    this.selectedProfileId_ = selectedProfile.id;
+    this.editablePersona_ = this.mergePersona_(selectedProfile);
+    const matchingPreset = this.presets_.find((preset: PersonaRecord) => {
+      return preset && preset.name === selectedProfile.name;
+    });
+    this.selectedPresetId_ = matchingPreset?.id || '';
+  }
+
+  private mergePersona_(persona: PersonaRecord): PersonaRecord {
+    const basePersona = createEmptyPersona();
+    return {
+      ...basePersona,
+      ...persona,
+      advanced: {
+        ...basePersona.advanced,
+        ...(persona.advanced || {}),
+      },
+      region: {
+        ...basePersona.region,
+        ...(persona.region || {}),
+      },
+      uaCh: {
+        ...basePersona.uaCh,
+        ...(persona.uaCh || {}),
+      },
+      gpu: {
+        ...basePersona.gpu,
+        ...(persona.gpu || {}),
+        webglProfile: {
+          ...basePersona.gpu.webglProfile,
+          ...(persona.gpu?.webglProfile || {}),
+        },
+        webgl2Profile: {
+          ...basePersona.gpu.webgl2Profile,
+          ...(persona.gpu?.webgl2Profile || {}),
+        },
+        webgpuProfile: {
+          ...basePersona.gpu.webgpuProfile,
+          ...(persona.gpu?.webgpuProfile || {}),
+        },
+      },
+      hardware: {
+        ...basePersona.hardware,
+        ...(persona.hardware || {}),
+      },
+      screen: {
+        ...basePersona.screen,
+        ...(persona.screen || {}),
+      },
+      fonts: {
+        ...basePersona.fonts,
+        ...(persona.fonts || {}),
+      },
+      fontRendering: {
+        ...basePersona.fontRendering,
+        ...(persona.fontRendering || {}),
+      },
+      mediaDevices: {
+        ...basePersona.mediaDevices,
+        ...(persona.mediaDevices || {}),
+      },
+      network: {
+        ...basePersona.network,
+        ...(persona.network || {}),
+      },
+    };
+  }
+
+  private async refreshProfiles_() {
+    const browserProxy = PersonaBrowserProxyImpl.getInstance();
+    const [state, profilesResponse] = await Promise.all([
+      browserProxy.getPersonaState(),
+      browserProxy.getPersonaProfiles(),
+    ]);
+    this.applyPersonaState_(state, profilesResponse);
+  }
+
+  private applyPersonaResponse_(response: PersonaPageResponse) {
+    if (response.ok) {
+      this.applyPersonaState_(response.state);
+    }
+  }
+
+  private async onCreateProfileClick_() {
+    const response =
+        await PersonaBrowserProxyImpl.getInstance().createPersonaProfile(
+            'New Persona');
+    if (response.ok) {
+      this.selectedProfileId_ = response.state?.activePersonaId || '';
+    }
+    this.applyPersonaResponse_(response);
+  }
+
+  private onProfileCardClick_(event: Event) {
+    const profileId =
+        (event.currentTarget as HTMLElement).dataset['profileId'] || '';
+    if (!profileId) {
+      return;
+    }
+    const profile = this.profiles_.find((item: PersonaRecord) => {
+      return item && item.id === profileId;
+    });
+    if (!profile) {
+      return;
+    }
+    this.selectedProfileId_ = profileId;
+    this.editablePersona_ = this.mergePersona_(profile);
+  }
+
+  private async onActivateProfileClick_(event: Event) {
+    event.stopPropagation();
+    const profileId =
+        (event.currentTarget as HTMLElement).dataset['profileId'] || '';
+    if (!profileId) {
+      return;
+    }
+    const response =
+        await PersonaBrowserProxyImpl.getInstance().setActivePersona(profileId);
+    if (response.ok) {
+      this.selectedProfileId_ = profileId;
+    }
+    this.applyPersonaResponse_(response);
+  }
+
+  private async onDeleteProfileClick_(event: Event) {
+    event.stopPropagation();
+    const profileId =
+        (event.currentTarget as HTMLElement).dataset['profileId'] || '';
+    if (!profileId || !this.canDeleteProfile_(profileId)) {
+      return;
+    }
+    if (this.selectedProfileId_ === profileId) {
+      this.selectedProfileId_ = this.activePersonaId_;
+    }
+    this.applyPersonaResponse_(
+        await PersonaBrowserProxyImpl.getInstance().deletePersona(profileId));
+  }
+
+  private async onSavePersonaClick_() {
+    const personaId = this.editablePersona_?.id || '';
+    if (personaId) {
+      this.selectedProfileId_ = personaId;
+    }
+    this.applyPersonaResponse_(
+        await PersonaBrowserProxyImpl.getInstance().savePersona(
+            this.editablePersona_));
+  }
+
+  private onPresetChange_(event: Event) {
+    this.selectedPresetId_ = (event.target as HTMLSelectElement).value;
+  }
+
+  private async onApplyPresetClick_() {
+    if (!this.selectedPresetId_) {
+      return;
+    }
+
+    const response =
+        await PersonaBrowserProxyImpl.getInstance().clonePresetIntoProfile(
+            this.selectedPresetId_);
+    if (response.ok) {
+      this.selectedProfileId_ = response.state?.activePersonaId || '';
+    }
+    this.applyPersonaResponse_(response);
+  }
+
+  private async onLaunchSelectionModeChange_(event: Event) {
+    const mode = (event.target as HTMLSelectElement).value;
+    this.launchSelectionMode_ =
+        await PersonaBrowserProxyImpl.getInstance().setLaunchSelectionMode(
+            mode);
+    await this.refreshProfiles_();
+  }
+
+  private onUaChPlatformChange_(event: Event) {
+    this.set(
+        'editablePersona_.uaCh.platform',
+        (event.target as HTMLSelectElement).value);
+  }
+
+  private onTimezoneChange_(event: Event) {
+    this.set(
+        'editablePersona_.region.timezone',
+        (event.target as HTMLSelectElement).value);
+  }
+
+  private onLocaleChange_(event: Event) {
+    const locale = (event.target as HTMLSelectElement).value;
+    this.set('editablePersona_.region.locale', locale);
+    this.set('editablePersona_.region.acceptLanguage', `${locale},en;q=0.9`);
+  }
+
+  private isSelectedProfile_(personaId: string, selectedProfileId: string) {
+    return personaId === selectedProfileId;
+  }
+
+  private isActiveProfile_(personaId: string, activePersonaId: string) {
+    return personaId === activePersonaId;
+  }
+
+  private canDeleteProfile_(personaId: string) {
+    return personaId !== 'default';
+  }
+
+  private computeProfileStatus_(personaId: string, activePersonaId: string) {
+    return personaId === activePersonaId ? 'Active' : 'Saved';
+  }
+
+  private computeProfileSummary_(persona: PersonaRecord) {
+    const platform = persona?.platform || persona?.uaCh?.platform || 'Unknown';
+    const locale = persona?.region?.locale || 'en-US';
+    return `${platform} | ${locale}`;
+  }
+
+  private computeLastUsedText_(lastUsedAt: string) {
+    return lastUsedAt || 'Never';
+  }
+
+}
+
+declare global {
+  interface HTMLElementTagNameMap {
+    'settings-persona-page': SettingsPersonaPageElement;
+  }
+}
+
+customElements.define(SettingsPersonaPageElement.is, SettingsPersonaPageElement);
