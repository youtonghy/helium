+
+void PersonaHandler::HandleGetLaunchSelectionMode(
+    const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(1U, args.size());
+  const base::Value& callback_id = args[0];
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(callback_id, base::Value(service->GetLaunchSelectionMode()));
+}
+
+void PersonaHandler::HandleSetLaunchSelectionMode(
+    const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(2U, args.size());
+  const base::Value& callback_id = args[0];
+  CHECK(args[1].is_string());
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  service->SetLaunchSelectionMode(args[1].GetString());
+  ResolveJavascriptCallback(callback_id, base::Value(service->GetLaunchSelectionMode()));
