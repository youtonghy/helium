+#include "chrome/browser/ui/webui/settings/persona_handler.h"
+
+#include "base/check.h"
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/helium_persona/persona_service.h"
+#include "chrome/browser/helium_persona/persona_service_factory.h"
+#include "content/public/browser/web_ui.h"
+
+namespace settings {
+
+namespace {
+
+helium_persona::PersonaService* GetPersonaService(Profile* profile) {
+  return helium_persona::PersonaServiceFactory::GetForProfile(profile);
+}
+
+}  // namespace
+
+PersonaHandler::PersonaHandler(Profile* profile) : profile_(profile) {}
+PersonaHandler::~PersonaHandler() = default;
+
+void PersonaHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getPersonaState",
+      base::BindRepeating(&PersonaHandler::HandleGetPersonaState,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "getPersonaProfiles",
+      base::BindRepeating(&PersonaHandler::HandleGetPersonaProfiles,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "createPersonaProfile",
+      base::BindRepeating(&PersonaHandler::HandleCreatePersonaProfile,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "savePersona",
+      base::BindRepeating(&PersonaHandler::HandleSavePersona,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "setActivePersona",
+      base::BindRepeating(&PersonaHandler::HandleSetActivePersona,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "clonePresetIntoProfile",
+      base::BindRepeating(&PersonaHandler::HandleClonePresetIntoProfile,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "deletePersona",
+      base::BindRepeating(&PersonaHandler::HandleDeletePersona,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "getLaunchSelectionMode",
+      base::BindRepeating(&PersonaHandler::HandleGetLaunchSelectionMode,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "setLaunchSelectionMode",
+      base::BindRepeating(&PersonaHandler::HandleSetLaunchSelectionMode,
+                          base::Unretained(this)));
+}
+
+void PersonaHandler::OnJavascriptAllowed() {}
+
+void PersonaHandler::OnJavascriptDisallowed() {}
+
+void PersonaHandler::HandleGetPersonaState(const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(1U, args.size());
+  const base::Value& callback_id = args[0];
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(callback_id, service->GetPersonaState());
+}
+
+void PersonaHandler::HandleGetPersonaProfiles(const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(1U, args.size());
+  const base::Value& callback_id = args[0];
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(callback_id, service->GetPersonaProfiles());
+}
+
+void PersonaHandler::HandleCreatePersonaProfile(const base::ListValue& args) {
+  AllowJavascript();
+  CHECK_EQ(2U, args.size());
+  const base::Value& callback_id = args[0];
+  CHECK(args[1].is_string());
+
+  helium_persona::PersonaService* service = GetPersonaService(profile_);
+  CHECK(service);
+  ResolveJavascriptCallback(
+      callback_id, service->CreatePersonaProfile(args[1].GetString()));
+}
