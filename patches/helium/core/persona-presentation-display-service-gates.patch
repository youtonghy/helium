+void InvokeNewPresentationCallbackWithPersonaError(
+    PresentationServiceImpl::NewPresentationCallback callback,
+    PresentationErrorType error_type) {
+  std::move(callback).Run(
+      /** PresentationConnectionResultPtr */ nullptr,
+      PresentationError::New(
+          error_type,
+          "Presentation request is unavailable for the active browser "
+          "persona."));
+}
+
+const blink::HeliumPersonaSnapshot& GetPersonaSnapshot(
+    RenderFrameHost* render_frame_host) {
+  return static_cast<PageImpl&>(render_frame_host->GetPage())
+      .persona_snapshot();
+}
+
+bool IsRemotePlaybackPresentationUrl(const GURL& url) {
+  return url.SchemeIs(kRemotePlaybackPresentationUrlScheme);
+}
+
+bool IsPresentationUrlAllowedByPersona(
+    const blink::HeliumPersonaSnapshot& snapshot,
+    const GURL& url) {
+  if (!snapshot.IsEnabled())
+    return true;
+
+  return IsRemotePlaybackPresentationUrl(url)
+             ? snapshot.allow_remote_playback
+             : snapshot.allow_presentation_apis;
+}
+
+bool ArePresentationUrlsAllowedByPersona(
+    const blink::HeliumPersonaSnapshot& snapshot,
+    const std::vector<GURL>& urls) {
+  if (!snapshot.IsEnabled())
+    return true;
+
+  if (urls.empty())
+    return snapshot.allow_presentation_apis;
+
+  for (const GURL& url : urls) {
+    if (!IsPresentationUrlAllowedByPersona(snapshot, url))
+      return false;
+  }
+  return true;
+}
+
