+  private fallbackLanguage_(locale: string): string {
+    const language = locale.split('-')[0].trim().toLowerCase();
+    return language || 'en';
+  }
+
+  private acceptLanguageForLocale_(locale: string): string {
+    const normalizedLocale = this.stringValue_(locale) || 'en-US';
+    const language = this.fallbackLanguage_(normalizedLocale);
+    return language && language !== normalizedLocale.toLowerCase() ?
+        `${normalizedLocale},${language};q=0.9` : normalizedLocale;
+  }
+
+  private navigatorLanguagesForLocale_(locale: string): string[] {
+    const normalizedLocale = this.stringValue_(locale) || 'en-US';
+    const language = this.fallbackLanguage_(normalizedLocale);
+    return language && language !== normalizedLocale.toLowerCase() ?
+        [normalizedLocale, language] : [normalizedLocale];
+  }
+
+  private canonicalUaChBrandsForMajor_(
+      major: number): Array<Record<string, string>> {
+    const version = String(major || 149);
+    return [
+      {brand: 'Chromium', version},
+      {brand: 'Google Chrome', version},
+      {brand: 'Not_A Brand', version: '24'},
+    ];
+  }
+
+  private positiveNumberOr_(value: unknown, fallback: number): number {
+    const number = this.numberValueOr_(value, fallback);
+    return Number.isFinite(number) && number > 0 ? number : fallback;
+  }
+
+  private nonNegativeNumberOr_(value: unknown, fallback: number): number {
+    const number = this.numberValueOr_(value, fallback);
+    return Number.isFinite(number) && number >= 0 ? number : fallback;
+  }
