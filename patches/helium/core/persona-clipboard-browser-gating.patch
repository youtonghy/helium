@@ -1011,6 +1011,12 @@ blink::HeliumPersonaSnapshot GetHeliumPersonaSnapshotForBrowserContext(
       helium_persona::MakePersonaSnapshot(*profile->GetPrefs()));
 }
 
+bool HeliumPersonaAllowsClipboard(content::BrowserContext* browser_context) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshotForBrowserContext(browser_context);
+  return !snapshot.IsEnabled() || snapshot.allow_clipboard;
+}
