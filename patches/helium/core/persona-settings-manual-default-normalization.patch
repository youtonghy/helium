  private ensureGpuProfileDefaults_(
      profile: unknown, defaults: Record<string, number>):
      Record<string, unknown> {
    const shaped =
        profile && typeof profile === 'object' && !Array.isArray(profile) ?
        {...profile as Record<string, unknown>} :
        {};
    for (const [key, value] of Object.entries(defaults)) {
      if (shaped[key] === undefined || shaped[key] === null ||
          Number.isNaN(Number(shaped[key]))) {
        shaped[key] = value;
      }
    }
    return shaped;
  }

  private ensureObjectDefaults_(
      object: unknown, defaults: Record<string, unknown>):
      Record<string, unknown> {
    const shaped =
        object && typeof object === 'object' && !Array.isArray(object) ?
        {...object as Record<string, unknown>} :
        {};
    for (const [key, value] of Object.entries(defaults)) {
      if (shaped[key] === undefined || shaped[key] === null ||
          (Array.isArray(value) && !Array.isArray(shaped[key])) ||
          (typeof shaped[key] === 'string' && !String(shaped[key]).trim())) {
        shaped[key] = Array.isArray(value) ? [...value] : value;
      }
    }
    return shaped;
  }

