+    });
+
+std::optional<int> FunctionKeyNumber(ui::KeyboardCode key_code) {
+  if (key_code < ui::VKEY_F1 || key_code > ui::VKEY_F24) {
+    return std::nullopt;
+  }
+  return key_code - ui::VKEY_F1 + 1;
+}
+
+std::optional<ui::KeyboardCode> CodeToKey(std::string_view code) {
+  // Serialized shortcuts use DOM KeyboardEvent.code names so user prefs stay
+  // tied to a physical key position instead of the character produced by the
+  // current keyboard layout. ui::Accelerator ultimately dispatches through
+  // ui::KeyboardCode, so deserialize the small synthetic families first.
+  if (code.size() == 4 && code.starts_with("Key") && code[3] >= 'A' &&
+      code[3] <= 'Z') {
+    return static_cast<ui::KeyboardCode>(ui::VKEY_A + code[3] - 'A');
+  }
+  if (code.size() == 6 && code.starts_with("Digit") && code[5] >= '0' &&
+      code[5] <= '9') {
+    return static_cast<ui::KeyboardCode>(ui::VKEY_0 + code[5] - '0');
+  }
+
+  // Function keys are encoded directly as F1..F24, matching DOM code names and
+  // avoiding a long static table for a contiguous KeyboardCode range.
+  if (code.size() >= 2 && code.starts_with("F")) {
+    int number = 0;
+    if (base::StringToInt(code.substr(1), &number) && number >= 1 &&
+        number <= 24) {
+      return static_cast<ui::KeyboardCode>(ui::VKEY_F1 + number - 1);
+    }
+  }
+
+  // Remaining codes are either punctuation/navigation keys or numpad keys.
+  // Several DOM codes intentionally collapse to one ui::KeyboardCode where
+  // Chromium does not distinguish the physical key at accelerator dispatch.
+  const auto value = kCodeToKey.find(code);
+  if (value != kCodeToKey.end()) {
+    return value->second;
+  }
+  return std::nullopt;
+}
+
+std::optional<std::string> KeyToCode(ui::KeyboardCode key_code) {
+  if (key_code >= ui::VKEY_A && key_code <= ui::VKEY_Z) {
+    std::string code = "Key";
+    code.push_back(static_cast<char>('A' + key_code - ui::VKEY_A));
+    return code;
+  }
+  if (key_code >= ui::VKEY_0 && key_code <= ui::VKEY_9) {
+    std::string code = "Digit";
+    code.push_back(static_cast<char>('0' + key_code - ui::VKEY_0));
+    return code;
+  }
+  if (std::optional<int> number = FunctionKeyNumber(key_code)) {
+    return std::string("F") + base::NumberToString(*number);
+  }
+  for (const auto& [code, value] : kCodeToKey) {
+    if (value == key_code) {
+      return std::string(code);
+    }
+  }
+  return std::nullopt;
+}
+
+std::u16string FunctionKeyToDisplayString(ui::KeyboardCode key_code) {
+  std::optional<int> number = FunctionKeyNumber(key_code);
+  if (!number) {
+    return std::u16string();
+  }
+  return base::UTF8ToUTF16(std::string("F") + base::NumberToString(*number));
+}
+
+std::u16string ClearKeyDisplayString(ui::KeyboardCode key_code) {
+  switch (key_code) {
+    case ui::VKEY_OEM_PLUS:
+    case ui::VKEY_ADD:
+      return l10n_util::GetStringUTF16(IDS_APP_PLUS_KEY);
+    default:
+      return std::u16string();
+  }
+}
+
+std::u16string NumpadKeyDisplayString(ui::KeyboardCode key_code) {
+  std::u16string key;
+  if (key_code >= ui::VKEY_NUMPAD0 && key_code <= ui::VKEY_NUMPAD9) {
+    key = base::NumberToString16(key_code - ui::VKEY_NUMPAD0);
+  } else if (key_code == ui::VKEY_ADD) {
+    key = l10n_util::GetStringUTF16(IDS_APP_PLUS_KEY);
+  }
+  return key.empty() ? std::u16string()
+                     : l10n_util::GetStringFUTF16(IDS_APP_NUMPAD_KEY, key);
+}
+
+std::vector<std::u16string> ModifierDisplayStrings(int modifiers) {
+  std::vector<std::u16string> parts;
+  if (modifiers & ui::EF_COMMAND_DOWN) {
+#if BUILDFLAG(IS_MAC)
+    parts.push_back(u"⌘");
+#elif BUILDFLAG(IS_WIN)
+    parts.push_back(l10n_util::GetStringUTF16(IDS_APP_WINDOWS_KEY));
+#elif BUILDFLAG(IS_LINUX)
+    parts.push_back(l10n_util::GetStringUTF16(IDS_APP_SUPER_KEY));
+#endif
+  }
+  if (modifiers & ui::EF_ALT_DOWN) {
+#if BUILDFLAG(IS_MAC)
+    parts.push_back(u"⌥");
+#else
+    parts.push_back(l10n_util::GetStringUTF16(IDS_APP_ALT_KEY));
+#endif
+  }
+  if (modifiers & ui::EF_CONTROL_DOWN) {
+#if BUILDFLAG(IS_MAC)
+    parts.push_back(u"⌃");
+#else
+    parts.push_back(l10n_util::GetStringUTF16(IDS_APP_CTRL_KEY));
+#endif
+  }
+  if (modifiers & ui::EF_SHIFT_DOWN) {
+#if BUILDFLAG(IS_MAC)
+    parts.push_back(u"⇧");
+#else
+    parts.push_back(l10n_util::GetStringUTF16(IDS_APP_SHIFT_KEY));
+#endif
+  }
+  return parts;
+}
+
+std::u16string JoinDisplayShortcutParts(
+    const std::vector<std::u16string>& parts) {
+#if BUILDFLAG(IS_MAC)
+  return base::JoinString(parts, u"");
+#else
+  return base::JoinString(parts, u"+");
+#endif
+}
+
+std::u16string FunctionAcceleratorToDisplayString(
+    const ui::Accelerator& accelerator) {
+  std::u16string key = FunctionKeyToDisplayString(accelerator.key_code());
+  if (key.empty()) {
+    return std::u16string();
+  }
+
+  std::vector<std::u16string> parts =
+      ModifierDisplayStrings(accelerator.modifiers());
+  parts.push_back(std::move(key));
+  return JoinDisplayShortcutParts(parts);
+}
+
+bool AddModifier(int* modifiers, int modifier) {
+  if (*modifiers & modifier) {
+    return false;
+  }
+  *modifiers |= modifier;
+  return true;
+}
+
+}  // namespace
+
+std::optional<ui::Accelerator> AcceleratorFromString(
+    const std::string& serialized) {
+  int modifiers = ui::EF_NONE;
+  std::optional<ui::KeyboardCode> key_code;
+  for (std::string_view part : base::SplitStringPiece(
+           serialized, "+", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY)) {
+    if (part == "Shift") {
+      if (!AddModifier(&modifiers, ui::EF_SHIFT_DOWN)) {
+        return std::nullopt;
+      }
+    } else if (part == "Control") {
+      if (!AddModifier(&modifiers, ui::EF_CONTROL_DOWN)) {
+        return std::nullopt;
+      }
+    } else if (part == "Alt") {
+      if (!AddModifier(&modifiers, ui::EF_ALT_DOWN)) {
+        return std::nullopt;
+      }
+    } else if (part == "Meta") {
+      if (!AddModifier(&modifiers, ui::EF_COMMAND_DOWN)) {
+        return std::nullopt;
+      }
+    } else if (!key_code) {
+      key_code = CodeToKey(part);
+    } else {
+      return std::nullopt;
+    }
+  }
+  if (!key_code) {
+    return std::nullopt;
+  }
+  return ui::Accelerator(*key_code, modifiers);
+}
+
+std::string AcceleratorToString(const ui::Accelerator& accelerator) {
+  std::vector<std::string> parts;
+  const int modifiers = accelerator.modifiers() & kStoredModifierMask;
+  if (modifiers & ui::EF_CONTROL_DOWN) {
+    parts.push_back("Control");
+  }
+  if (modifiers & ui::EF_ALT_DOWN) {
+    parts.push_back("Alt");
+  }
+  if (modifiers & ui::EF_SHIFT_DOWN) {
+    parts.push_back("Shift");
+  }
+  if (modifiers & ui::EF_COMMAND_DOWN) {
+    parts.push_back("Meta");
+  }
+  std::optional<std::string> code = KeyToCode(accelerator.key_code());
+  if (!code) {
+    return std::string();
+  }
+  parts.push_back(*code);
+
+  return base::JoinString(parts, "+");
+}
+
+std::u16string AcceleratorToDisplayString(const ui::Accelerator& accelerator) {
+  std::u16string clear_key_text =
+      NumpadKeyDisplayString(accelerator.key_code());
+  if (clear_key_text.empty()) {
+    clear_key_text = ClearKeyDisplayString(accelerator.key_code());
+  }
+  if (!clear_key_text.empty()) {
+    std::vector<std::u16string> parts =
+        ModifierDisplayStrings(accelerator.modifiers());
+    parts.push_back(std::move(clear_key_text));
+    return JoinDisplayShortcutParts(parts);
+  }
+
+  std::u16string text = accelerator.GetShortcutText();
+  std::u16string function_key_text =
+      FunctionAcceleratorToDisplayString(accelerator);
+  if (!function_key_text.empty() &&
+      text.find(FunctionKeyToDisplayString(accelerator.key_code())) ==
+          std::u16string::npos) {
+    return function_key_text;
+  }
+  return text;
+}
+
+std::optional<std::string> NormalizeAcceleratorString(
+    const std::string& serialized) {
+  std::optional<ui::Accelerator> accelerator =
+      AcceleratorFromString(serialized);
+  if (!accelerator) {
+    return std::nullopt;
+  }
+  std::string normalized = AcceleratorToString(*accelerator);
+  if (normalized.empty()) {
+    return std::nullopt;
+  }
+  return normalized;
+}
+
+bool IsValidAcceleratorString(const std::string& serialized) {
+  return NormalizeAcceleratorString(serialized).has_value();
+}
