+namespace browser_shortcuts {
+
+namespace {
+
+using AcceleratorsByCommandId = std::map<int, ui::Accelerator>;
+
+bool KeyEquivalentRequiresShift(unichar key_equivalent) {
+  if (key_equivalent >= 'A' && key_equivalent <= 'Z') {
+    return true;
+  }
+
+  // Mirrors the shifted U.S. punctuation pairs accepted by
+  // ui::KeyboardCodeFromCharCode().
+  switch (key_equivalent) {
+    case ':':
+    case '+':
+    case '<':
+    case '_':
+    case '>':
+    case '?':
+    case '~':
+    case '{':
+    case '|':
+    case '}':
+    case '"':
+      return true;
+    default:
+      return false;
+  }
+}
+
+std::optional<ui::Accelerator> AcceleratorFromMenuItem(NSMenuItem* item) {
+  NSString* key_equivalent = item.keyEquivalent;
+  if (key_equivalent.length == 0) {
+    return std::nullopt;
+  }
+
+  unichar key = [key_equivalent characterAtIndex:0];
+  // This covers Chromium's standard menu accelerators and typical macOS App
+  // Shortcut remaps. AppKit key equivalents outside Chromium's character map
+  // are ignored here and may still be reserved by static non-menu shortcuts.
+  ui::KeyboardCode key_code = ui::KeyboardCodeFromCharCode(key);
+  if (key_code == ui::VKEY_UNKNOWN) {
+    return std::nullopt;
+  }
+
+  int modifiers = ui::EventFlagsFromModifiers(item.keyEquivalentModifierMask);
+  if (item.keyEquivalentModifierMask & NSEventModifierFlagFunction) {
+    modifiers |= ui::EF_FUNCTION_DOWN;
+  }
+  if (KeyEquivalentRequiresShift(key)) {
+    modifiers |= ui::EF_SHIFT_DOWN;
+  }
+  return ui::Accelerator(key_code, modifiers);
+}
+
+int CommandIdFromMenuItem(NSMenuItem* item) {
+  SEL action = [item action];
+  if ((action == @selector(commandDispatch:) ||
+       action == @selector(commandDispatchUsingKeyModifiers:)) &&
+      [item tag] > 0) {
+    return [item tag];
+  }
+  if (action == @selector(performClose:)) {
+    return IDC_CLOSE_WINDOW;
+  }
+  if (action == @selector(terminate:)) {
+    return IDC_EXIT;
+  }
+  return NO_COMMAND;
+}
+
+base::flat_set<int>& HeliumManagedMenuCommandIds() {
+  static base::NoDestructor<base::flat_set<int>> command_ids;
+  return *command_ids;
+}
+
+bool IsDynamicCloseCommand(int command_id) {
+  // AppController swaps Cmd+W/Cmd+Shift+W between Close Tab and Close Window at
+  // runtime based on the active window. Helium can expose these commands for
+  // additional shortcuts, but should not rewrite their menu-owned defaults.
+  return command_id == IDC_CLOSE_TAB || command_id == IDC_CLOSE_WINDOW;
+}
+
+bool IsMenuCommandHeliumModifiable(
+    int command_id,
+    const std::optional<ui::Accelerator>& accelerator) {
+  if (IsDynamicCloseCommand(command_id)) {
+    return false;
+  }
+
+  const ui::Accelerator* default_accelerator =
+      AcceleratorsCocoa::GetInstance()->GetAcceleratorForCommand(command_id);
+  if (!default_accelerator) {
+    return false;
+  }
+
+  if (!HeliumManagedMenuCommandIds().contains(command_id) &&
+      (!accelerator.has_value() || *default_accelerator != *accelerator)) {
+    return false;
+  }
+
+  return IsBrowserShortcutDefaultUserModifiable(command_id);
+}
+
+void AppendMenuItems(
+    NSMenu* menu,
+    std::vector<BrowserShortcutPlatformDefaultAccelerator>* defaults,
+    base::flat_set<int>* live_menu_command_ids) {
+  if (menu == NSApp.servicesMenu) {
+    return;
+  }
+
+  for (NSMenuItem* item in menu.itemArray) {
+    int command_id = CommandIdFromMenuItem(item);
+    if (command_id != NO_COMMAND) {
+      live_menu_command_ids->insert(command_id);
+    }
+    std::optional<ui::Accelerator> accelerator = AcceleratorFromMenuItem(item);
+    if (command_id != NO_COMMAND) {
+      const bool user_modifiable =
+          IsMenuCommandHeliumModifiable(command_id, accelerator);
+      const ui::Accelerator* default_accelerator =
+          user_modifiable
+              ? AcceleratorsCocoa::GetInstance()->GetAcceleratorForCommand(
+                    command_id)
+              : nullptr;
+      if (default_accelerator) {
+        defaults->push_back(
+            {command_id, *default_accelerator, user_modifiable});
+      } else if (accelerator.has_value()) {
+        defaults->push_back({command_id, *accelerator, user_modifiable});
+      }
+    }
+
+    if (item.submenu) {
+      AppendMenuItems(item.submenu, defaults, live_menu_command_ids);
+    }
+  }
+}
+
+void AppendShortcutData(
+    const std::vector<KeyboardShortcutAcceleratorData>& shortcuts,
+    std::vector<BrowserShortcutPlatformDefaultAccelerator>* defaults) {
+  for (const KeyboardShortcutAcceleratorData& shortcut : shortcuts) {
+    defaults->push_back({shortcut.chrome_command, shortcut.accelerator,
+                         /*user_modifiable=*/false});
+  }
+}
+
+bool ShouldManageMenuItem(NSMenuItem* item, int command_id) {
+  if (IsDynamicCloseCommand(command_id)) {
+    return false;
+  }
+
+  if (HeliumManagedMenuCommandIds().contains(command_id)) {
+    return true;
+  }
+
+  return IsMenuCommandHeliumModifiable(command_id, AcceleratorFromMenuItem(item));
+}
+
+void ApplyMenuItemAccelerator(
+    NSMenuItem* item,
+    const AcceleratorsByCommandId& accelerators_by_command_id,
+    int command_id) {
+  auto accelerator_it = accelerators_by_command_id.find(command_id);
+  if (accelerator_it == accelerators_by_command_id.end()) {
+    item.keyEquivalent = @"";
+    item.keyEquivalentModifierMask = 0;
+    return;
+  }
+
+  KeyEquivalentAndModifierMask* equivalent =
+      ui::GetKeyEquivalentAndModifierMaskFromAccelerator(
+          accelerator_it->second);
+  item.keyEquivalent = equivalent.keyEquivalent;
+  item.keyEquivalentModifierMask = equivalent.modifierMask;
+}
+
+void UpdateMenuItems(
+    NSMenu* menu,
+    const AcceleratorsByCommandId& accelerators_by_command_id) {
+  if (menu == NSApp.servicesMenu) {
+    return;
+  }
+
+  for (NSMenuItem* item in menu.itemArray) {
+    const int command_id = CommandIdFromMenuItem(item);
+    if (command_id != NO_COMMAND && ShouldManageMenuItem(item, command_id)) {
+      ApplyMenuItemAccelerator(item, accelerators_by_command_id, command_id);
+      HeliumManagedMenuCommandIds().insert(command_id);
+    }
+
+    if (item.submenu) {
+      UpdateMenuItems(item.submenu, accelerators_by_command_id);
+    }
+  }
+}
+
+}  // namespace
+
+std::vector<BrowserShortcutPlatformDefaultAccelerator>
+GetPlatformDefaultAccelerators() {
+  std::vector<BrowserShortcutPlatformDefaultAccelerator> defaults;
+  base::flat_set<int> live_menu_command_ids;
+
+  // The app menu is macOS' runtime shortcut owner, including user-remapped App
+  // Shortcuts. Static Chromium defaults below are only a fallback for commands
+  // missing from the live menu plus shortcuts dispatched outside the menu path.
+  if (NSApp.mainMenu) {
+    AppendMenuItems(NSApp.mainMenu, &defaults, &live_menu_command_ids);
+  }
+
+  AcceleratorsCocoa* accelerators = AcceleratorsCocoa::GetInstance();
+  for (auto it = accelerators->begin(); it != accelerators->end(); ++it) {
+    if (live_menu_command_ids.contains(it->first)) {
+      continue;
+    }
+    defaults.push_back({it->first, it->second, /*user_modifiable=*/false});
+  }
+
+  AppendShortcutData(GetShortcutSettingsAcceleratorsNotPresentInMainMenu(),
+                     &defaults);
+
+  return defaults;
+}
+
+void UpdatePlatformMenuAccelerators(
+    const std::vector<std::pair<ui::Accelerator, int>>& accelerators) {
+  if (!NSApp.mainMenu) {
+    return;
+  }
+
+  std::map<int, ui::Accelerator> accelerators_by_command_id;
+  for (const auto& [accelerator, command_id] : accelerators) {
+    accelerators_by_command_id.try_emplace(command_id, accelerator);
+  }
+
+  UpdateMenuItems(NSApp.mainMenu, accelerators_by_command_id);
+}
+
+}  // namespace browser_shortcuts
