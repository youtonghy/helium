+        {"PageUp", ui::VKEY_PRIOR},
+        {"Period", ui::VKEY_OEM_PERIOD},
+        {"Quote", ui::VKEY_OEM_7},
+        {"Semicolon", ui::VKEY_OEM_1},
+        {"Slash", ui::VKEY_OEM_2},
+        {"Space", ui::VKEY_SPACE},
+        {"Tab", ui::VKEY_TAB},
+        {"ArrowDown", ui::VKEY_DOWN},
+        {"ArrowLeft", ui::VKEY_LEFT},
