+constexpr int kStoredModifierMask = ui::EF_SHIFT_DOWN | ui::EF_CONTROL_DOWN |
+                                    ui::EF_ALT_DOWN | ui::EF_COMMAND_DOWN;
+
+constexpr auto kCodeToKey =
+    base::MakeFixedFlatMap<std::string_view, ui::KeyboardCode>({
+        {"Backquote", ui::VKEY_OEM_3},
+        {"Backslash", ui::VKEY_OEM_5},
+        {"Backspace", ui::VKEY_BACK},
+        {"BracketLeft", ui::VKEY_OEM_4},
+        {"BracketRight", ui::VKEY_OEM_6},
+        {"Comma", ui::VKEY_OEM_COMMA},
+        {"Delete", ui::VKEY_DELETE},
+        {"End", ui::VKEY_END},
+        {"Enter", ui::VKEY_RETURN},
+        {"Equal", ui::VKEY_OEM_PLUS},
+        {"Escape", ui::VKEY_ESCAPE},
+        {"Home", ui::VKEY_HOME},
+        {"Insert", ui::VKEY_INSERT},
+        {"Minus", ui::VKEY_OEM_MINUS},
+        {"Numpad0", ui::VKEY_NUMPAD0},
+        {"Numpad1", ui::VKEY_NUMPAD1},
+        {"Numpad2", ui::VKEY_NUMPAD2},
+        {"Numpad3", ui::VKEY_NUMPAD3},
+        {"Numpad4", ui::VKEY_NUMPAD4},
+        {"Numpad5", ui::VKEY_NUMPAD5},
+        {"Numpad6", ui::VKEY_NUMPAD6},
+        {"Numpad7", ui::VKEY_NUMPAD7},
+        {"Numpad8", ui::VKEY_NUMPAD8},
+        {"Numpad9", ui::VKEY_NUMPAD9},
