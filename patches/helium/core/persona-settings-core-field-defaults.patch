   private async onDeletePersonaClick_(event: Event) {
     const model = (event as CustomEvent).model;
     const persona = model.persona as PersonaRecord;
     if (!window.confirm(`Delete persona "${persona.name || persona.id}"?`)) {
       return;
     }
     this.clearStatus_();
     if (!await this.browserProxy_.deletePersona(persona.id)) {
       this.showStatus_('Could not delete persona.');
       return;
     }
     await this.loadState_();
   }
 
