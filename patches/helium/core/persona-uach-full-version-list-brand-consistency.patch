+  grease_brand.Set("brand", "Not_A Brand");
+  grease_brand.Set("version", "24");
+  full_versions.Append(std::move(grease_brand));
+  ua_ch->Set("fullVersionList", std::move(full_versions));
+
+  base::Value::List warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings,
+                              "UA-CH fullVersionList brands should match"));
