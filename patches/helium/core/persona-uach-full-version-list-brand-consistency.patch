+std::vector<std::string> NonGreaseUaChBrandNames(
+    const base::Value::List* brands) {
+  std::vector<std::string> names;
+  if (!brands) {
+    return names;
+  }
+  for (const base::Value& value : *brands) {
+    const base::Value::Dict* brand = value.GetIfDict();
+    const std::string* name = brand ? brand->FindString("brand") : nullptr;
+    if (!name || name->empty() || IsUaChGreaseBrand(*name)) {
+      continue;
+    }
+    names.push_back(*name);
+  }
+  return names;
+}
