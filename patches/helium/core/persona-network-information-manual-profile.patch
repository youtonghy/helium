+base::Value::Dict MakeDefaultNetworkProfile() {
+  base::Value::Dict network;
+  network.Set("type", "ethernet");
+  network.Set("effectiveType", "4g");
+  network.Set("rtt", 50);
+  network.Set("downlink", 10.0);
+  network.Set("downlinkMax", 0.0);
+  network.Set("saveData", false);
+  network.Set("online", true);
+  return network;
+}
+
+bool HasNumericValue(const base::Value::Dict& dict, std::string_view key) {
+  return dict.FindDouble(key).has_value() || dict.FindInt(key).has_value();
+}
+
+void EnsureNetworkCompatibilityFields(base::Value::Dict& persona) {
+  if (!persona.FindDict("network")) {
+    persona.Set("network", MakeDefaultNetworkProfile());
+    return;
+  }
+
+  base::Value::Dict* network = persona.FindDict("network");
+  if (!network->FindString("type")) {
+    network->Set("type", "ethernet");
+  }
+  if (!network->FindString("effectiveType")) {
+    network->Set("effectiveType", "4g");
+  }
+  if (!network->FindInt("rtt")) {
+    network->Set("rtt", 50);
+  }
+  if (!HasNumericValue(*network, "downlink")) {
+    network->Set("downlink", 10.0);
+  }
+  if (!HasNumericValue(*network, "downlinkMax")) {
+    network->Set("downlinkMax", 0.0);
+  }
+  if (!network->FindBool("saveData")) {
+    network->Set("saveData", false);
+  }
+  if (!network->FindBool("online")) {
+    network->Set("online", true);
+  }
+}
