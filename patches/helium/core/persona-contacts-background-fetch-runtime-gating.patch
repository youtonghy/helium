+blink::HeliumPersonaSnapshot GetHeliumPersonaSnapshot(
+    BrowserContext* browser_context) {
+  if (!browser_context) {
+    return blink::HeliumPersonaSnapshot();
+  }
+  return GetContentClient()->browser()->GetHeliumPersonaSnapshot(
+      browser_context);
+}
+
+bool HeliumPersonaAllowsContacts(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_contacts;
+}
+
+bool HeliumPersonaAllowsBackgroundFetch(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_background_sync;
+}
+
+bool HeliumPersonaAllowsBackgroundFetch(ServiceWorkerHost* host) {
+  if (!host) {
+    return true;
+  }
+  BrowserContext* browser_context =
+      host->version()->context()->wrapper()->browser_context();
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(browser_context);
+  return !snapshot.IsEnabled() || snapshot.allow_background_sync;
+}
+
