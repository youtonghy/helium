@@ -199,10 +199,53 @@ bool IsDisplayCaptureStreamType(blink::mojom::MediaStreamType stream_type) {
   return false;
 }
 
+bool IsDeviceCaptureStreamType(blink::mojom::MediaStreamType stream_type) {
+  switch (stream_type) {
+    case blink::mojom::MediaStreamType::DEVICE_AUDIO_CAPTURE:
+    case blink::mojom::MediaStreamType::DEVICE_VIDEO_CAPTURE:
+      return true;
+    case blink::mojom::MediaStreamType::NO_SERVICE:
+    case blink::mojom::MediaStreamType::GUM_TAB_AUDIO_CAPTURE:
+    case blink::mojom::MediaStreamType::GUM_TAB_VIDEO_CAPTURE:
+    case blink::mojom::MediaStreamType::GUM_DESKTOP_AUDIO_CAPTURE:
+    case blink::mojom::MediaStreamType::GUM_DESKTOP_VIDEO_CAPTURE:
+    case blink::mojom::MediaStreamType::DISPLAY_AUDIO_CAPTURE:
+    case blink::mojom::MediaStreamType::DISPLAY_VIDEO_CAPTURE:
+    case blink::mojom::MediaStreamType::DISPLAY_VIDEO_CAPTURE_THIS_TAB:
+    case blink::mojom::MediaStreamType::DISPLAY_VIDEO_CAPTURE_SET:
+    case blink::mojom::MediaStreamType::NUM_MEDIA_TYPES:
+      return false;
+  }
+  return false;
+}
+
+bool ControlsRequestMediaCapture(const blink::StreamControls& controls) {
+  return IsDeviceCaptureStreamType(controls.audio.stream_type) ||
+         IsDeviceCaptureStreamType(controls.video.stream_type);
+}
+
 bool ControlsRequestDisplayCapture(const blink::StreamControls& controls) {
   return controls.request_all_screens ||
          IsDisplayCaptureStreamType(controls.audio.stream_type) ||
          IsDisplayCaptureStreamType(controls.video.stream_type);
+}
+
+void CheckMediaCaptureAllowedOnUIThread(
+    GlobalRenderFrameHostId render_frame_host_id,
+    base::OnceCallback<void(bool)> callback) {
+  DCHECK_CURRENTLY_ON(BrowserThread::UI);
+
+  RenderFrameHostImpl* const render_frame_host =
+      RenderFrameHostImpl::FromID(render_frame_host_id);
+  if (!render_frame_host || !render_frame_host->IsActive()) {
+    std::move(callback).Run(false);
+    return;
+  }
+
+  const blink::HeliumPersonaSnapshot& persona_snapshot =
+      render_frame_host->GetPage().persona_snapshot();
+  std::move(callback).Run(!persona_snapshot.IsEnabled() ||
+                          persona_snapshot.allow_media_capture);
 }
 
