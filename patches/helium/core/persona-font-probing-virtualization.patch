+
+bool PersonaSpoofingHelper::IsFontFamilyExposed(
+    const ExecutionContext* context,
+    const String& family_name) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->font_families.empty() || family_name.empty()) {
+    return false;
+  }
+
+  for (const std::string& family : snapshot->font_families) {
+    if (!family.empty() && EqualIgnoringCase(family, family_name)) {
+      return true;
+    }
+  }
+
+  for (const std::string& alias : snapshot->font_aliases) {
+    auto parsed = ParseFontAlias(alias);
+    if (parsed && EqualIgnoringCase(parsed->second, family_name)) {
+      return true;
+    }
+  }
+
+  return false;
+}
+
+std::optional<String> PersonaSpoofingHelper::FontFamilyAlias(
+    const ExecutionContext* context,
+    const String& generic_family_name) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->font_families.empty() ||
+      generic_family_name.empty()) {
+    return std::nullopt;
+  }
+
+  for (const std::string& alias : snapshot->font_aliases) {
+    auto parsed = ParseFontAlias(alias);
+    if (parsed && EqualIgnoringCase(parsed->first, generic_family_name) &&
+        IsFontFamilyExposed(context, parsed->second)) {
+      return parsed->second;
+    }
+  }
+
+  return std::nullopt;
+}
