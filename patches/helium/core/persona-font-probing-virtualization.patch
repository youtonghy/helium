+std::optional<String> PersonaSpoofingHelper::FirstFontFamily(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return std::nullopt;
+  }
+  for (const std::string& family : snapshot->font_families) {
+    if (!family.empty()) {
+      return ToBlinkString(family);
+    }
+  }
+  return std::nullopt;
