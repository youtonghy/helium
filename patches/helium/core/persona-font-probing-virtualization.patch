+std::optional<std::pair<String, String>> ParseFontAlias(
+    const std::string& alias) {
+  const size_t separator = alias.find('=');
+  if (separator == std::string::npos) {
+    return std::nullopt;
+  }
+  std::string key = alias.substr(0, separator);
+  std::string value = alias.substr(separator + 1);
+  base::TrimWhitespaceASCII(key, base::TRIM_ALL, &key);
+  base::TrimWhitespaceASCII(value, base::TRIM_ALL, &value);
+  if (key.empty() || value.empty()) {
+    return std::nullopt;
+  }
+  return std::make_pair(String::FromUtf8(key), String::FromUtf8(value));
