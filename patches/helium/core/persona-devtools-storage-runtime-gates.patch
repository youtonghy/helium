+BrowserContext* GetPersonaBrowserContext(RenderFrameHostImpl* frame_host,
+                                         StoragePartition* storage_partition) {
+  if (frame_host) {
+    return frame_host->GetBrowserContext();
+  }
+  if (!storage_partition) {
+    return nullptr;
+  }
+  return static_cast<StoragePartitionImpl*>(storage_partition)
+      ->browser_context();
+}
+
+blink::HeliumPersonaSnapshot GetDevToolsPersonaSnapshot(
+    RenderFrameHostImpl* frame_host,
+    StoragePartition* storage_partition) {
+  ContentBrowserClient* browser_client = GetContentClient()->browser();
+  if (!browser_client) {
+    return blink::HeliumPersonaSnapshot();
+  }
+  return browser_client->GetHeliumPersonaSnapshot(
+      GetPersonaBrowserContext(frame_host, storage_partition));
+}
+
+bool HeliumPersonaAllowsDevToolsPrivateStateTokens(
+    RenderFrameHostImpl* frame_host,
+    StoragePartition* storage_partition) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetDevToolsPersonaSnapshot(frame_host, storage_partition);
+  return !snapshot.IsEnabled() || snapshot.allow_private_state_tokens;
+}
+
+bool HeliumPersonaAllowsDevToolsPrivacySandboxApis(
+    RenderFrameHostImpl* frame_host,
+    StoragePartition* storage_partition) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetDevToolsPersonaSnapshot(frame_host, storage_partition);
+  return !snapshot.IsEnabled() || snapshot.allow_privacy_sandbox_apis;
+}
+
+Response PersonaDevToolsDisabledResponse(const char* feature) {
+  return Response::ServerError(base::StrCat(
+      {feature, " is disabled by the active persona."}));
+}
+
+std::unique_ptr<protocol::Array<protocol::Storage::TrustTokens>>
+MakeEmptyTrustTokenList() {
+  return std::make_unique<
+      protocol::Array<protocol::Storage::TrustTokens>>();
+}
