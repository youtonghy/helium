+std::vector<PersonaUaChBrand> GetUaChBrands(const base::Value::Dict& persona) {
+  std::vector<PersonaUaChBrand> brands;
+  const base::Value::Dict* ua_ch = persona.FindDict("uaCh");
+  const base::Value::List* list = ua_ch ? ua_ch->FindList("brands") : nullptr;
+  if (!list) {
+    return brands;
+  }
+  for (const base::Value& value : *list) {
+    const base::Value::Dict* dict = value.GetIfDict();
+    if (!dict) {
+      continue;
+    }
+    const std::string* brand = dict->FindString("brand");
+    if (!brand || brand->empty()) {
+      continue;
+    }
+    PersonaUaChBrand entry;
+    entry.brand = *brand;
+    if (const std::string* version = dict->FindString("version")) {
+      entry.version = *version;
+    }
+    brands.push_back(std::move(entry));
+  }
+  return brands;
+}
+
+base::Value::List MakeUaChBrandList(const std::vector<PersonaUaChBrand>& brands) {
+  base::Value::List output;
+  for (const PersonaUaChBrand& brand : brands) {
+    base::Value::Dict value;
+    value.Set("brand", brand.brand);
+    value.Set("version", brand.version);
+    output.Append(std::move(value));
+  }
+  return output;
+}
