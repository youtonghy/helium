+  private formatUaChBrands_(brands: Array<Record<string, unknown>>): string {
+    return brands.map(brand => {
+      const name = String(brand['brand'] || '').trim();
+      const version = String(brand['version'] || '').trim();
+      return name && version ? `${name}:${version}` : name;
+    }).filter(Boolean).join(', ');
