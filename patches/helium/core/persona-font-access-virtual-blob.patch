+std::string MakePersonaPostscriptName(const std::string& family) {
+  std::string postscript_name;
+  for (char c : family) {
+    switch (c) {
+      case ' ':
+      case '-':
+      case '_':
+      case '.':
+      case ',':
+      case '(':
+      case ')':
+      case '[':
+      case ']':
+      case '{':
+      case '}':
+        break;
+      default:
+        postscript_name.push_back(c);
+        break;
+    }
+  }
+  if (postscript_name.empty()) {
+    return "SystemRegular";
+  }
+  return postscript_name + "-Regular";
+}
