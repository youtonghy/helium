+  private makeRandomNoiseSeed_(): string {
+    const array = new Uint32Array(2);
+    if (window.crypto?.getRandomValues) {
+      window.crypto.getRandomValues(array);
+    } else {
+      array[0] = Math.floor(Math.random() * 0xffffffff);
+      array[1] = Math.floor(Math.random() * 0xffffffff);
+    }
+    return 'seed-' + Array.from(array)
+        .map(value => value.toString(16).padStart(8, '0'))
+        .join('');
+  }
+
+  private onRegenerateNoiseSeedClick_() {
+    this.set('editablePersona_.noiseSeed', this.makeRandomNoiseSeed_());
+  }
