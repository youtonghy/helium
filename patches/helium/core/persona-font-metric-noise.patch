 namespace blink {

 constexpr int kHangingAsPercentOfAscent = 80;
+constexpr uint64_t kFnvPrime = 0x00000100000001b3;
+constexpr double kHeliumFontMetricNoiseDelta = 0.001;
+
+uint64_t MixHeliumFontMetricNoise(uint64_t hash, uint64_t value) {
+  hash ^= value;
+  hash *= kFnvPrime;
+  return hash;
+}
+
+double ApplyHeliumFontMetricNoise(double value,
+                                  uint64_t token_hash,
+                                  uint64_t field_index) {
+  if (!std::isfinite(value) || value == 0.0)
+    return value;
+  const uint64_t field_hash = MixHeliumFontMetricNoise(token_hash, field_index);
+  const double direction = (field_hash & 1) ? 1.0 : -1.0;
+  const double magnitude = 1.0 + static_cast<double>((field_hash >> 1) % 31);
+  return value + direction * magnitude * kHeliumFontMetricNoiseDelta;
+}

