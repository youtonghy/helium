+bool IsPersonaAsciiWhitespace(char value) {
+  return value == ' ' || value == '\t' || value == '\n' ||
+         value == '\r' || value == '\f' || value == '\v';
+}
+
+std::string TrimPersonaString(std::string_view value) {
+  size_t begin = 0;
+  while (begin < value.size() && IsPersonaAsciiWhitespace(value[begin])) {
+    ++begin;
+  }
+  size_t end = value.size();
+  while (end > begin && IsPersonaAsciiWhitespace(value[end - 1])) {
+    --end;
+  }
+  return std::string(value.substr(begin, end - begin));
+}
+
+base::Value::List CleanStringListValue(const base::Value::Dict& dict,
