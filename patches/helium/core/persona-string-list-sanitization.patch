+    if (!item) {
+      continue;
+    }
+    std::string trimmed = TrimPersonaString(*item);
+    if (!trimmed.empty()) {
+      clean.Append(std::move(trimmed));
     }
   }
-  return false;
+  return clean;
 }
 
