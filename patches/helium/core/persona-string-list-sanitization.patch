+TEST(HeliumPersonaPrefsTest, SavePersonaSanitizesStringLists) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona = ClonePresetIntoProfile(
+      prefs, "preset-windows-11-en-us-new-york");
+  ASSERT_FALSE(persona.empty());
+
+  base::Value::Dict* ua_ch = persona.FindDict("uaCh");
+  ASSERT_TRUE(ua_ch);
+  base::Value::List brands;
+  base::Value::Dict chromium_brand;
+  chromium_brand.Set("brand", " Chromium ");
+  chromium_brand.Set("version", " 149 ");
+  brands.Append(std::move(chromium_brand));
+  base::Value::Dict bad_brand;
+  bad_brand.Set("brand", " ");
+  bad_brand.Set("version", "149");
+  brands.Append(std::move(bad_brand));
+  brands.Append(false);
+  ua_ch->Set("brands", std::move(brands));
+  base::Value::List form_factors;
+  form_factors.Append(" Desktop ");
+  form_factors.Append("");
+  form_factors.Append(17);
+  ua_ch->Set("formFactors", std::move(form_factors));
+
+  base::Value::Dict* region = persona.FindDict("region");
+  ASSERT_TRUE(region);
+  base::Value::List languages;
+  languages.Append(" en-US ");
+  languages.Append(" ");
+  languages.Append(false);
+  languages.Append("en");
+  region->Set("navigatorLanguages", std::move(languages));
+
+  base::Value::Dict* gpu = persona.FindDict("gpu");
+  ASSERT_TRUE(gpu);
+  base::Value::List features;
+  features.Append(" texture-compression-bc ");
+  features.Append("");
+  features.Append(3);
+  gpu->Set("webgpuFeatures", std::move(features));
+
+  base::Value::Dict* fonts = persona.FindDict("fonts");
+  ASSERT_TRUE(fonts);
+  base::Value::List families;
+  families.Append(" Arial ");
+  families.Append(" ");
+  families.Append(false);
+  families.Append("Segoe UI");
+  fonts->Set("families", std::move(families));
+  base::Value::List aliases;
+  aliases.Append(" sans-serif=Arial ");
+  aliases.Append("");
+  aliases.Append(false);
+  fonts->Set("aliases", std::move(aliases));
+
+  EXPECT_TRUE(SavePersona(prefs, std::move(persona)));
+  base::Value::Dict active = GetActivePersona(prefs);
+
+  const base::Value::List* saved_brands =
+      active.FindDict("uaCh")->FindList("brands");
+  ASSERT_TRUE(saved_brands);
+  ASSERT_EQ(1u, saved_brands->size());
+  EXPECT_EQ("Chromium", *DictAt(*saved_brands, 0).FindString("brand"));
+  EXPECT_EQ("149", *DictAt(*saved_brands, 0).FindString("version"));
+
+  const base::Value::List* saved_form_factors =
+      active.FindDict("uaCh")->FindList("formFactors");
+  ASSERT_TRUE(saved_form_factors);
+  ASSERT_EQ(1u, saved_form_factors->size());
+  EXPECT_EQ("Desktop", (*saved_form_factors)[0].GetString());
+
+  const base::Value::List* saved_languages =
+      active.FindDict("region")->FindList("navigatorLanguages");
+  ASSERT_TRUE(saved_languages);
+  ASSERT_EQ(2u, saved_languages->size());
+  EXPECT_EQ("en-US", (*saved_languages)[0].GetString());
+  EXPECT_EQ("en", (*saved_languages)[1].GetString());
+
+  const base::Value::List* saved_features =
+      active.FindDict("gpu")->FindList("webgpuFeatures");
+  ASSERT_TRUE(saved_features);
+  ASSERT_EQ(1u, saved_features->size());
+  EXPECT_EQ("texture-compression-bc", (*saved_features)[0].GetString());
+
+  const base::Value::List* saved_families =
+      active.FindDict("fonts")->FindList("families");
+  ASSERT_TRUE(saved_families);
+  ASSERT_EQ(2u, saved_families->size());
+  EXPECT_EQ("Arial", (*saved_families)[0].GetString());
+  EXPECT_EQ("Segoe UI", (*saved_families)[1].GetString());
+
+  const base::Value::List* saved_aliases =
+      active.FindDict("fonts")->FindList("aliases");
+  ASSERT_TRUE(saved_aliases);
+  ASSERT_EQ(1u, saved_aliases->size());
+  EXPECT_EQ("sans-serif=Arial", (*saved_aliases)[0].GetString());
+}
