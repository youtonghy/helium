+bool ProfilesContainId(const base::Value::List& profiles,
+                       std::string_view expected_id) {
+  for (const base::Value& profile : profiles) {
+    const base::Value::Dict* dict = profile.GetIfDict();
+    const std::string* id = dict ? dict->FindString("id") : nullptr;
+    if (id && *id == expected_id) {
+      return true;
+    }
+  }
+  return false;
+}
