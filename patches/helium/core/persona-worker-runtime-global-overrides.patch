diff --git a/third_party/blink/renderer/core/helium_persona/persona_runtime_override.cc b/third_party/blink/renderer/core/helium_persona/persona_runtime_override.cc
new file mode 100644
index 0000000..33be804
--- /dev/null
+++ b/third_party/blink/renderer/core/helium_persona/persona_runtime_override.cc
@@ -0,0 +1,140 @@
+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "third_party/blink/renderer/core/helium_persona/persona_runtime_override.h"
+
+#include <map>
+#include <memory>
+#include <string>
+
+#include "third_party/blink/renderer/core/inspector/locale_controller.h"
+#include "third_party/blink/renderer/core/timezone/timezone_controller.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+#include "third_party/blink/renderer/platform/wtf/thread_specific.h"
+
+namespace blink {
+
+namespace {
+
+struct GlobalOverrideState {
+  std::map<const void*, std::string> requested_timezones;
+  std::map<const void*, std::string> requested_locales;
+  std::unique_ptr<TimeZoneController::TimeZoneOverride> timezone_override;
+  std::string active_timezone;
+  std::string active_locale;
+  bool locale_override_active = false;
+};
+
+GlobalOverrideState& GetGlobalOverrideState() {
+  // Timezone and locale overrides are bound to the current renderer thread's
+  // runtime state. Keep a request coordinator per thread instead of sharing
+  // timezone handles across workers and the main thread.
+  DEFINE_THREAD_SAFE_STATIC_LOCAL(ThreadSpecific<GlobalOverrideState>, state,
+                                  ());
+  return *state;
+}
+
+std::string PreferredRequestedValue(
+    const std::map<const void*, std::string>& requests,
+    const std::string& active_value) {
+  if (!active_value.empty()) {
+    for (const auto& entry : requests) {
+      if (entry.second == active_value) {
+        return active_value;
+      }
+    }
+  }
+  for (const auto& entry : requests) {
+    if (!entry.second.empty()) {
+      return entry.second;
+    }
+  }
+  return std::string();
+}
+
+void ReconcileTimezone(GlobalOverrideState& state) {
+  const std::string timezone =
+      PreferredRequestedValue(state.requested_timezones, state.active_timezone);
+  if (timezone.empty()) {
+    state.timezone_override.reset();
+    state.active_timezone.clear();
+    return;
+  }
+  if (timezone == state.active_timezone) {
+    return;
+  }
+
+  String blink_timezone = String::FromUTF8(timezone);
+  if (state.timezone_override) {
+    state.timezone_override->change(blink_timezone);
+    state.active_timezone = timezone;
+    return;
+  }
+
+  auto result = TimeZoneController::SetTimeZoneOverride(blink_timezone);
+  if (result.status == TimeZoneController::TimeZoneOverrideStatus::kSuccess) {
+    state.timezone_override = std::move(result.handle);
+    state.active_timezone = timezone;
+  }
+}
+
+void ReconcileLocale(GlobalOverrideState& state) {
+  const std::string locale =
+      PreferredRequestedValue(state.requested_locales, state.active_locale);
+  if (locale.empty()) {
+    if (state.locale_override_active) {
+      LocaleController::instance().SetLocaleOverride(String(), false);
+      state.locale_override_active = false;
+    }
+    state.active_locale.clear();
+    return;
+  }
+  if (locale == state.active_locale) {
+    return;
+  }
+
+  String blink_locale = String::FromUTF8(locale);
+  String error = LocaleController::instance().SetLocaleOverride(
+      blink_locale, !state.locale_override_active);
+  if (error.empty()) {
+    state.locale_override_active = true;
+    state.active_locale = locale;
+  }
+}
+
+void ReconcileGlobalOverrides(GlobalOverrideState& state) {
+  ReconcileTimezone(state);
+  ReconcileLocale(state);
+}
+
+}  // namespace
+
+void PersonaRuntimeOverride::ApplyGlobal(
+    const void* owner,
+    const HeliumPersonaSnapshot& snapshot) {
+  if (!owner) {
+    return;
+  }
+
+  GlobalOverrideState& state = GetGlobalOverrideState();
+  if (snapshot.IsEnabled() && !snapshot.timezone.empty()) {
+    state.requested_timezones[owner] = snapshot.timezone;
+  } else {
+    state.requested_timezones.erase(owner);
+  }
+  if (snapshot.IsEnabled() && !snapshot.locale.empty()) {
+    state.requested_locales[owner] = snapshot.locale;
+  } else {
+    state.requested_locales.erase(owner);
+  }
+  ReconcileGlobalOverrides(state);
+}
+
+void PersonaRuntimeOverride::ClearGlobal(const void* owner) {
+  if (!owner) {
+    return;
+  }
+
+  GlobalOverrideState& state = GetGlobalOverrideState();
+  state.requested_timezones.erase(owner);
+  state.requested_locales.erase(owner);
+  ReconcileGlobalOverrides(state);
+}
+
+}  // namespace blink
