+TEST(HeliumPersonaPrefsTest,
+     CompatibilityRepairsMissingFontRenderingProfileVersion) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona =
+      ClonePresetIntoProfile(prefs, "preset-windows-11-en-us-new-york");
+  base::Value::Dict* font_rendering = persona.FindDict("fontRendering");
+  ASSERT_TRUE(font_rendering);
+  font_rendering->Remove("profileVersion");
+
+  SavePersona(prefs, std::move(persona));
+  base::Value::Dict active = GetActivePersona(prefs);
+  const base::Value::Dict* active_font_rendering =
+      active.FindDict("fontRendering");
+  ASSERT_TRUE(active_font_rendering);
+  EXPECT_EQ(1, active_font_rendering->FindInt("profileVersion").value_or(0));
+  EXPECT_TRUE(PersonaHasRequiredFields(active));
+}
+
+TEST(HeliumPersonaPrefsTest, ValidationRequiresFontRenderingProfileVersion) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona =
+      ClonePresetIntoProfile(prefs, "preset-windows-11-en-us-new-york");
+  base::Value::Dict* font_rendering = persona.FindDict("fontRendering");
+  ASSERT_TRUE(font_rendering);
+  font_rendering->Remove("profileVersion");
+
+  EXPECT_FALSE(PersonaHasRequiredFields(persona));
+  base::Value::List warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "missing one or more required fields"));
+}
