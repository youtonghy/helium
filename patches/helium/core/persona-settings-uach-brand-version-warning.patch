+  private uaChHasNonGreaseBrandWithoutVersion_(brands: unknown): boolean {
+    if (!Array.isArray(brands)) {
+      return false;
+    }
+    return brands.some(brand => {
+      if (!brand || typeof brand !== 'object' || Array.isArray(brand)) {
+        return false;
+      }
+      const record = brand as Record<string, unknown>;
+      const name = this.stringValue_(record['brand']);
+      if (!name || this.contains_(name, 'not')) {
+        return false;
+      }
+      return !this.stringValue_(record['version']);
+    });
+  }
