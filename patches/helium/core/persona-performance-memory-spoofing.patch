+// static
+HeapInfo MemoryInfo::ForPersonaDeviceMemory(double device_memory_gb) {
+  const double normalized_device_memory =
+      std::max(0.25, std::min(device_memory_gb, 8.0));
+  const size_t persona_bytes =
+      static_cast<size_t>(normalized_device_memory * kBytesPerGib);
+
+  HeapInfo info;
+  info.js_heap_size_limit = QuantizeMemorySize(
+      std::max<size_t>(256 * 1024 * 1024, persona_bytes / 2));
+  info.total_js_heap_size =
+      QuantizeMemorySize(std::max<size_t>(16 * 1024 * 1024,
+                                          info.js_heap_size_limit / 8));
+  info.used_js_heap_size =
+      QuantizeMemorySize(std::max<size_t>(8 * 1024 * 1024,
+                                          info.total_js_heap_size / 2));
+  return info;
 }
 
