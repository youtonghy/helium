 namespace blink {
 
+namespace {
+
+constexpr int64_t kPersonaMiB = 1024 * 1024;
+constexpr int64_t kPersonaGiB = 1024 * kPersonaMiB;
+
+int64_t RoundPersonaStorageUsage(int64_t usage_in_bytes) {
+  if (usage_in_bytes <= 0) {
+    return 0;
+  }
+  return ((usage_in_bytes + kPersonaMiB - 1) / kPersonaMiB) * kPersonaMiB;
+}
+
+int64_t PersonaStorageQuota(ExecutionContext* context, int64_t fallback_quota) {
+  const HeliumPersonaSnapshot* snapshot = PersonaSpoofingHelper::Get(context);
+  if (!snapshot) {
+    return fallback_quota;
+  }
+  if (snapshot->device_memory >= 8) {
+    return 120 * kPersonaGiB;
+  }
+  if (snapshot->device_memory >= 4) {
+    return 80 * kPersonaGiB;
+  }
+  return snapshot->device_memory >= 2 ? 40 * kPersonaGiB : 20 * kPersonaGiB;
+}
+
