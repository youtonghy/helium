+TEST(HeliumPersonaPrefsTest, StateIncludesIndependentFontPackProfiles) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  const base::Value::List* profiles = state.FindList("fontPackProfiles");
+  ASSERT_TRUE(profiles);
+  const size_t builtin_profile_count = GetBuiltinFontPackProfiles().size();
+  ASSERT_EQ(builtin_profile_count, profiles->size());
+  EXPECT_TRUE(ProfilesContainId(*profiles, "windows-11-core"));
+  EXPECT_TRUE(ProfilesContainId(*profiles, "macos-core"));
+  EXPECT_TRUE(ProfilesContainId(*profiles, "linux-core"));
+  ASSERT_TRUE(DictAt(*profiles, 0).FindBool("builtin").value_or(false));
+
+  base::Value::Dict custom;
+  custom.Set("id", "custom-cjk");
+  custom.Set("displayName", "Custom CJK fonts");
+  base::Value::List families;
+  families.Append("Noto Sans");
+  families.Append("Noto Sans CJK SC");
+  custom.Set("families", std::move(families));
+  base::Value::List aliases;
+  aliases.Append("sans-serif=Noto Sans");
+  aliases.Append("system-ui=Noto Sans CJK SC");
+  custom.Set("aliases", std::move(aliases));
+  EXPECT_TRUE(SaveFontPackProfile(prefs, std::move(custom)));
+
+  state = GetPersonaState(prefs);
+  profiles = state.FindList("fontPackProfiles");
+  ASSERT_TRUE(profiles);
+  ASSERT_EQ(builtin_profile_count + 1, profiles->size());
+  const base::Value::Dict& custom_profile =
+      DictAt(*profiles, builtin_profile_count);
+  EXPECT_EQ("custom-cjk", *custom_profile.FindString("id"));
+  EXPECT_FALSE(custom_profile.FindBool("builtin").value_or(true));
+
+  base::Value::Dict copied_builtin = DictAt(*profiles, 0).Clone();
+  copied_builtin.Set("displayName", "Copied Windows fonts");
+  EXPECT_TRUE(SaveFontPackProfile(prefs, std::move(copied_builtin)));
+  state = GetPersonaState(prefs);
+  profiles = state.FindList("fontPackProfiles");
+  ASSERT_TRUE(profiles);
+  ASSERT_EQ(builtin_profile_count + 2, profiles->size());
+  EXPECT_EQ("windows-11-core", *DictAt(*profiles, 0).FindString("id"));
+  EXPECT_TRUE(ProfilesContainId(*profiles, "custom-windows-11-core"));
+
+  EXPECT_TRUE(DeleteFontPackProfile(prefs, "custom-cjk"));
+  state = GetPersonaState(prefs);
+  profiles = state.FindList("fontPackProfiles");
+  ASSERT_TRUE(profiles);
+  EXPECT_EQ(builtin_profile_count + 1, profiles->size());
+  EXPECT_TRUE(ProfilesContainId(*profiles, "custom-windows-11-core"));
+  EXPECT_FALSE(ProfilesContainId(*profiles, "custom-cjk"));
+}
+
+TEST(HeliumPersonaPrefsTest, SaveFontPackProfileCreatesIdWhenEmpty) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict custom;
+  custom.Set("id", "");
+  custom.Set("displayName", "Manual font pack");
+  base::Value::List families;
+  families.Append("Arial");
+  custom.Set("families", std::move(families));
+  EXPECT_TRUE(SaveFontPackProfile(prefs, std::move(custom)));
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  EXPECT_TRUE(ProfilesContainId(*state.FindList("fontPackProfiles"),
+                                "custom-font-pack"));
+}
