+bool HeliumPersonaAllowsMidi(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_midi;
