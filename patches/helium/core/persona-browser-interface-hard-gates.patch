+
+bool HeliumPersonaAllowsRealBatteryStatus(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_real_battery_status;
+}
+
+bool HeliumPersonaAllowsWebXr(RenderFrameHost* host) {
+  blink::HeliumPersonaSnapshot snapshot =
+      GetHeliumPersonaSnapshot(host ? host->GetBrowserContext() : nullptr);
+  return !snapshot.IsEnabled() || snapshot.allow_web_xr;
