+  private applyRandomDisplayPreferences_(persona: PersonaRecord) {
+    persona.screen = persona.screen || {};
+    const colorScheme = this.randomInt_(1, 100) <= 28 ? 'dark' : 'light';
+    const reduceMotion = this.randomInt_(1, 100) <= 3;
+    const reduceTransparency = reduceMotion && this.randomInt_(1, 100) <= 35;
+    const highContrast = this.randomInt_(1, 100) <= 2;
+    const forcedColors = highContrast && this.randomInt_(1, 100) <= 35;
+    const invertedColors = this.randomInt_(1, 100) <= 1;
+    const dpr = this.numberValue_(persona.screen['deviceScaleFactor']);
+    const colorDepth = this.numberValue_(persona.screen['colorDepth']);
+    persona.screen['colorScheme'] = colorScheme;
+    persona.screen['reducedMotion'] =
+        reduceMotion ? 'reduce' : 'no-preference';
+    persona.screen['reducedTransparency'] =
+        reduceTransparency ? 'reduce' : 'no-preference';
+    persona.screen['preferredContrast'] =
+        highContrast ? 'more' : 'no-preference';
+    persona.screen['forcedColors'] = forcedColors ? 'active' : 'none';
+    persona.screen['invertedColors'] = invertedColors ? 'inverted' : 'none';
+    persona.screen['colorGamut'] = dpr > 1 || colorDepth >= 30 ? 'p3' : 'srgb';
+    persona.screen['dynamicRange'] =
+        persona.screen['colorGamut'] === 'p3' && this.randomInt_(1, 100) <= 12 ?
+        'high' : 'standard';
+    persona.screen['monochromeDepth'] = 0;
+  }
