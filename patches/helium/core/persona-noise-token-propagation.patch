+std::optional<blink::NoiseToken> GetHeliumNoiseToken(
+    BrowserContext* browser_context,
+    const url::Origin& origin,
+    const blink::HeliumPersonaSnapshot& persona_snapshot,
+    blink::HeliumNoiseFeature feature) {
+  if (!browser_context || !persona_snapshot.IsEnabled())
+    return std::nullopt;
+  if (feature == blink::HeliumNoiseFeature::kCanvas &&
+      !persona_snapshot.canvas_noise) {
+    return std::nullopt;
+  }
+  if (feature == blink::HeliumNoiseFeature::kAudio &&
+      !persona_snapshot.audio_noise) {
+    return std::nullopt;
+  }
+  if (feature == blink::HeliumNoiseFeature::kFontMetric &&
+      !persona_snapshot.font_metric_noise) {
+    return std::nullopt;
+  }
+
+  blink::HeliumNoiseTokenMap tokens = HeliumNoiseTokenData::GetTokens(
+      browser_context, origin, persona_snapshot);
+  auto token = tokens.find(feature);
+  if (token == tokens.end())
+    return std::nullopt;
+  return blink::NoiseToken(token->second.Value());
+}
