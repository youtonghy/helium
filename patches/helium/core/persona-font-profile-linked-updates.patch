+TEST(HeliumPersonaPrefsTest, UpdatingFontRenderingPropagatesLinkedPersonas) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict rendering;
+  rendering.Set("id", "custom-follow-rendering");
+  rendering.Set("displayName", "Follow rendering");
+  rendering.Set("engine", "Skia");
+  rendering.Set("hinting", "medium");
+  rendering.Set("antialiasing", true);
+  rendering.Set("subpixelRendering", false);
+  rendering.Set("subpixelPositioning", false);
+  rendering.Set("lcdText", false);
+  rendering.Set("useAutohinter", false);
+  rendering.Set("useBitmaps", false);
+  rendering.Set("textGamma", 1.4);
+  rendering.Set("textContrast", 0.0);
+  EXPECT_TRUE(SaveFontRenderingProfile(prefs, rendering.Clone()));
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  const base::Value::Dict* saved_rendering = FindProfileById(
+      *state.FindList("fontRenderingProfiles"), "custom-follow-rendering");
+  ASSERT_TRUE(saved_rendering);
+
+  base::Value::Dict linked = ClonePresetIntoProfile(
+      prefs, "preset-windows-11-en-us-new-york");
+  ASSERT_FALSE(linked.empty());
+  const std::string linked_id = *linked.FindString("id");
+  linked.Set("fontRendering", saved_rendering->Clone());
+  EXPECT_TRUE(SavePersona(prefs, std::move(linked)));
+
+  base::Value::Dict detached = ClonePresetIntoProfile(
+      prefs, "preset-windows-11-en-us-new-york");
+  ASSERT_FALSE(detached.empty());
+  const std::string detached_id = *detached.FindString("id");
+  base::Value::Dict detached_rendering = saved_rendering->Clone();
+  detached_rendering.Set("textGamma", 1.9);
+  detached.Set("fontRendering", std::move(detached_rendering));
+  EXPECT_TRUE(SavePersona(prefs, std::move(detached)));
+
+  rendering.Set("displayName", "Follow rendering updated");
+  rendering.Set("hinting", "full");
+  rendering.Set("textGamma", 1.6);
+  EXPECT_TRUE(SaveFontRenderingProfile(prefs, std::move(rendering)));
+
+  state = GetPersonaState(prefs);
+  const base::Value::List* personas = state.FindList("personas");
+  ASSERT_TRUE(personas);
+  const base::Value::Dict* linked_persona =
+      FindProfileById(*personas, linked_id);
+  ASSERT_TRUE(linked_persona);
+  const base::Value::Dict* linked_rendering =
+      linked_persona->FindDict("fontRendering");
+  ASSERT_TRUE(linked_rendering);
+  EXPECT_EQ("Follow rendering updated",
+            *linked_rendering->FindString("displayName"));
+  EXPECT_EQ("full", *linked_rendering->FindString("hinting"));
+  EXPECT_EQ(1.6, linked_rendering->FindDouble("textGamma").value_or(0));
+
+  const base::Value::Dict* detached_persona =
+      FindProfileById(*personas, detached_id);
+  ASSERT_TRUE(detached_persona);
+  const base::Value::Dict* detached_rendering_saved =
+      detached_persona->FindDict("fontRendering");
+  ASSERT_TRUE(detached_rendering_saved);
+  EXPECT_EQ(1.9,
+            detached_rendering_saved->FindDouble("textGamma").value_or(0));
+}
