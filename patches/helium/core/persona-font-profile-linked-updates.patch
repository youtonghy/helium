+bool IsStringListEqual(const base::Value::List* first,
+                       const base::Value::List* second) {
+  if (!first || !second || first->size() != second->size()) {
+    return false;
+  }
+  for (size_t index = 0; index < first->size(); ++index) {
+    const std::string* first_value = (*first)[index].GetIfString();
+    const std::string* second_value = (*second)[index].GetIfString();
+    if (!first_value || !second_value || *first_value != *second_value) {
+      return false;
+    }
+  }
+  return true;
+}
+
+bool FontPackProfileMatches(const base::Value::Dict& persona_profile,
+                            const base::Value::Dict& reference_profile) {
+  const std::string* display_name = persona_profile.FindString("displayName");
+  const std::string* reference_display_name =
+      reference_profile.FindString("displayName");
+  return display_name && reference_display_name &&
+         *display_name == *reference_display_name &&
+         IsStringListEqual(persona_profile.FindList("families"),
+                           reference_profile.FindList("families")) &&
+         IsStringListEqual(persona_profile.FindList("aliases"),
+                           reference_profile.FindList("aliases"));
+}
+
+bool FontRenderingProfileMatches(const base::Value::Dict& persona_profile,
+                                 const base::Value::Dict& reference_profile) {
+  const std::string* display_name = persona_profile.FindString("displayName");
+  const std::string* reference_display_name =
+      reference_profile.FindString("displayName");
+  const std::string* engine = persona_profile.FindString("engine");
+  const std::string* reference_engine = reference_profile.FindString("engine");
+  const std::string* hinting = persona_profile.FindString("hinting");
+  const std::string* reference_hinting = reference_profile.FindString("hinting");
+  return display_name && reference_display_name &&
+         *display_name == *reference_display_name && engine &&
+         reference_engine && *engine == *reference_engine && hinting &&
+         reference_hinting && *hinting == *reference_hinting &&
+         persona_profile.FindBool("antialiasing") ==
+             reference_profile.FindBool("antialiasing") &&
+         persona_profile.FindBool("subpixelRendering") ==
+             reference_profile.FindBool("subpixelRendering") &&
+         persona_profile.FindBool("subpixelPositioning") ==
+             reference_profile.FindBool("subpixelPositioning") &&
+         persona_profile.FindBool("lcdText") ==
+             reference_profile.FindBool("lcdText") &&
+         persona_profile.FindBool("useAutohinter") ==
+             reference_profile.FindBool("useAutohinter") &&
+         persona_profile.FindBool("useBitmaps") ==
+             reference_profile.FindBool("useBitmaps") &&
+         GetProfileNumber(persona_profile, "textGamma", 1.4) ==
+             GetProfileNumber(reference_profile, "textGamma", 1.4) &&
+         GetProfileNumber(persona_profile, "textContrast", 0.0) ==
+             GetProfileNumber(reference_profile, "textContrast", 0.0);
+}
+
+void StripProfileListMetadata(base::Value::Dict& profile) {
+  profile.Remove("builtin");
+  profile.Remove("modified");
+  profile.Remove("updated");
+}
+
+void PropagateFontPackProfileToLinkedPersonas(
+    PrefService& pref_service,
+    const base::Value::Dict& previous_profile,
+    const base::Value::Dict& updated_profile) {
+  const std::string profile_id = GetProfileId(updated_profile);
+  if (profile_id.empty()) {
+    return;
+  }
+  base::Value::Dict persona_profile = updated_profile.Clone();
+  StripProfileListMetadata(persona_profile);
+  base::Value::List personas = CloneUserPersonas(pref_service);
+  bool changed = false;
+  for (base::Value& entry : personas) {
+    base::Value::Dict* persona = entry.GetIfDict();
+    base::Value::Dict* fonts = persona ? persona->FindDict("fonts") : nullptr;
+    if (!fonts || GetProfileId(*fonts) != profile_id ||
+        !FontPackProfileMatches(*fonts, previous_profile)) {
+      continue;
+    }
+    persona->Set("fonts", persona_profile.Clone());
+    persona->Set("updated", base::Time::Now().InMillisecondsFSinceUnixEpoch());
+    changed = true;
+  }
+  if (changed) {
+    pref_service.SetList(prefs::kHeliumPersonaRecords, std::move(personas));
+  }
+}
+
+void PropagateFontRenderingProfileToLinkedPersonas(
+    PrefService& pref_service,
+    const base::Value::Dict& previous_profile,
+    const base::Value::Dict& updated_profile) {
+  const std::string profile_id = GetProfileId(updated_profile);
+  if (profile_id.empty()) {
+    return;
+  }
+  base::Value::Dict persona_profile = updated_profile.Clone();
+  StripProfileListMetadata(persona_profile);
+  base::Value::List personas = CloneUserPersonas(pref_service);
+  bool changed = false;
+  for (base::Value& entry : personas) {
+    base::Value::Dict* persona = entry.GetIfDict();
+    base::Value::Dict* rendering =
+        persona ? persona->FindDict("fontRendering") : nullptr;
+    if (!rendering || GetProfileId(*rendering) != profile_id ||
+        !FontRenderingProfileMatches(*rendering, previous_profile)) {
+      continue;
+    }
+    persona->Set("fontRendering", persona_profile.Clone());
+    persona->Set("updated", base::Time::Now().InMillisecondsFSinceUnixEpoch());
+    changed = true;
+  }
+  if (changed) {
+    pref_service.SetList(prefs::kHeliumPersonaRecords, std::move(personas));
+  }
+}
