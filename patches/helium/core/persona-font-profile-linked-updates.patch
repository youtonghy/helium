+TEST(HeliumPersonaPrefsTest, UpdatingFontPackProfilePropagatesLinkedPersonas) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict pack;
+  pack.Set("id", "custom-follow-fonts");
+  pack.Set("displayName", "Follow fonts");
+  base::Value::List families;
+  families.Append("Arial");
+  pack.Set("families", std::move(families));
+  base::Value::List aliases;
+  aliases.Append("sans-serif=Arial");
+  pack.Set("aliases", std::move(aliases));
+  EXPECT_TRUE(SaveFontPackProfile(prefs, pack.Clone()));
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  const base::Value::Dict* saved_pack = FindProfileById(
+      *state.FindList("fontPackProfiles"), "custom-follow-fonts");
+  ASSERT_TRUE(saved_pack);
+
+  base::Value::Dict linked = ClonePresetIntoProfile(
+      prefs, "preset-windows-11-en-us-new-york");
+  ASSERT_FALSE(linked.empty());
+  const std::string linked_id = *linked.FindString("id");
+  linked.Set("fonts", saved_pack->Clone());
+  EXPECT_TRUE(SavePersona(prefs, std::move(linked)));
+
+  base::Value::Dict detached = ClonePresetIntoProfile(
+      prefs, "preset-windows-11-en-us-new-york");
+  ASSERT_FALSE(detached.empty());
+  const std::string detached_id = *detached.FindString("id");
+  base::Value::Dict detached_fonts = saved_pack->Clone();
+  base::Value::List detached_families;
+  detached_families.Append("Manual Sans");
+  detached_fonts.Set("families", std::move(detached_families));
+  detached.Set("fonts", std::move(detached_fonts));
+  EXPECT_TRUE(SavePersona(prefs, std::move(detached)));
+
+  pack.Set("displayName", "Follow fonts updated");
+  base::Value::List updated_families;
+  updated_families.Append("Arial");
+  updated_families.Append("Noto Sans");
+  pack.Set("families", std::move(updated_families));
+  EXPECT_TRUE(SaveFontPackProfile(prefs, std::move(pack)));
+
+  state = GetPersonaState(prefs);
+  const base::Value::List* personas = state.FindList("personas");
+  ASSERT_TRUE(personas);
+  const base::Value::Dict* linked_persona =
+      FindProfileById(*personas, linked_id);
+  ASSERT_TRUE(linked_persona);
+  const base::Value::Dict* linked_fonts = linked_persona->FindDict("fonts");
+  ASSERT_TRUE(linked_fonts);
+  EXPECT_EQ("Follow fonts updated", *linked_fonts->FindString("displayName"));
+  ASSERT_TRUE(linked_fonts->FindList("families"));
+  EXPECT_EQ(2u, linked_fonts->FindList("families")->size());
+
+  const base::Value::Dict* detached_persona =
+      FindProfileById(*personas, detached_id);
+  ASSERT_TRUE(detached_persona);
+  const base::Value::Dict* detached_fonts_saved =
+      detached_persona->FindDict("fonts");
+  ASSERT_TRUE(detached_fonts_saved);
+  ASSERT_TRUE(detached_fonts_saved->FindList("families"));
+  ASSERT_EQ(1u, detached_fonts_saved->FindList("families")->size());
+  EXPECT_EQ("Manual Sans",
+            (*detached_fonts_saved->FindList("families"))[0].GetString());
+}
 
