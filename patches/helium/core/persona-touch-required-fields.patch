+TEST(HeliumPersonaPrefsTest, ValidationRequiresManualTouchFields) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::Dict persona =
+      ClonePresetIntoProfile(prefs, "preset-macos-en-au-melbourne");
+  base::Value::Dict* hardware = persona.FindDict("hardware");
+  ASSERT_TRUE(hardware);
+  hardware->Remove("touchEnabled");
+  hardware->Remove("maxTouchPoints");
+
+  EXPECT_FALSE(PersonaHasRequiredFields(persona));
+  base::Value::List warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "missing one or more required fields"));
+}
