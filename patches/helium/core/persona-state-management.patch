+namespace mojo {
+
+template <>
+struct StructTraits<blink::mojom::HeliumPersonaUaChBrandDataView,
+                    ::blink::HeliumPersonaUaChBrand> {
+  static const std::string& brand(
+      const ::blink::HeliumPersonaUaChBrand& data) {
+    return data.brand;
+  }
+
+  static const std::string& version(
+      const ::blink::HeliumPersonaUaChBrand& data) {
+    return data.version;
+  }
+
+  static bool Read(blink::mojom::HeliumPersonaUaChBrandDataView data,
+                   ::blink::HeliumPersonaUaChBrand* out) {
+    return data.ReadBrand(&out->brand) && data.ReadVersion(&out->version);
+  }
+};
+
+template <>
+struct StructTraits<blink::mojom::HeliumPersonaSnapshotDataView,
+                    ::blink::HeliumPersonaSnapshot> {
+  static bool enabled(const ::blink::HeliumPersonaSnapshot& data) {
+    return data.enabled;
+  }
+
+  static bool client_hints_enabled(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.client_hints_enabled;
+  }
+
+  static bool allow_background_sync(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.allow_background_sync;
+  }
+
+  static bool allow_contacts(const ::blink::HeliumPersonaSnapshot& data) {
+    return data.allow_contacts;
+  }
+
+  static bool allow_privacy_sandbox_apis(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.allow_privacy_sandbox_apis;
+  }
+
+  static bool ua_ch_mobile(const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_mobile;
+  }
+
+  static bool ua_ch_wow64(const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_wow64;
+  }
+
+  static const std::string& user_agent(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.user_agent;
+  }
+
+  static const std::string& accept_language(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.accept_language;
+  }
+
+  static const std::string& ua_ch_platform(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_platform;
+  }
+
+  static const std::string& ua_ch_platform_version(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_platform_version;
+  }
+
+  static const std::string& ua_ch_architecture(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_architecture;
+  }
+
+  static const std::string& ua_ch_model(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_model;
+  }
+
+  static const std::string& ua_ch_bitness(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_bitness;
+  }
+
+  static const std::string& ua_ch_full_version(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_full_version;
+  }
+
+  static const std::vector<std::string>& ua_ch_form_factors(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_form_factors;
+  }
+
+  static const std::vector<::blink::HeliumPersonaUaChBrand>& ua_ch_brands(
+      const ::blink::HeliumPersonaSnapshot& data) {
+    return data.ua_ch_brands;
+  }
+
+  static bool Read(blink::mojom::HeliumPersonaSnapshotDataView data,
+                   ::blink::HeliumPersonaSnapshot* out) {
+    out->enabled = data.enabled();
+    out->client_hints_enabled = data.client_hints_enabled();
+    out->allow_background_sync = data.allow_background_sync();
+    out->allow_contacts = data.allow_contacts();
+    out->allow_privacy_sandbox_apis = data.allow_privacy_sandbox_apis();
+    out->ua_ch_mobile = data.ua_ch_mobile();
+    out->ua_ch_wow64 = data.ua_ch_wow64();
+    return data.ReadUserAgent(&out->user_agent) &&
+           data.ReadAcceptLanguage(&out->accept_language) &&
+           data.ReadUaChPlatform(&out->ua_ch_platform) &&
+           data.ReadUaChPlatformVersion(&out->ua_ch_platform_version) &&
+           data.ReadUaChArchitecture(&out->ua_ch_architecture) &&
+           data.ReadUaChModel(&out->ua_ch_model) &&
+           data.ReadUaChBitness(&out->ua_ch_bitness) &&
+           data.ReadUaChFullVersion(&out->ua_ch_full_version) &&
+           data.ReadUaChFormFactors(&out->ua_ch_form_factors) &&
+           data.ReadUaChBrands(&out->ua_ch_brands);
+  }
+};
+
+}  // namespace mojo
