+
+bool IsValidLaunchSelectionMode(std::string_view mode) {
+  return mode == kLaunchSelectionModeAlwaysAsk ||
+         mode == kLaunchSelectionModeUseLast;
+}
+
+std::string ResolvePersonaPlatform(const base::DictValue& persona);
+
+const base::DictValue* FindPersonaInList(const base::ListValue* personas,
+                                         const std::string& persona_id) {
+  if (!personas) {
+    return nullptr;
+  }
+
+  for (const auto& value : *personas) {
+    if (!value.is_dict()) {
+      continue;
+    }
+
+    const base::DictValue& persona = value.GetDict();
+    const std::string* id = persona.FindString("id");
+    if (id && *id == persona_id) {
+      return &persona;
+    }
+  }
+  return nullptr;
+}
+
+std::string GetActivePersonaId(const base::DictValue& state) {
+  const std::string* active_id = state.FindString("activePersonaId");
+  return active_id && !active_id->empty() ? *active_id : kDefaultPersonaId;
+}
+
+std::string GetPersonaDisplayName(const base::DictValue& persona) {
+  if (const std::string* display_name = persona.FindString("displayName");
+      display_name && !display_name->empty()) {
+    return *display_name;
+  }
+  if (const std::string* name = persona.FindString("name");
+      name && !name->empty()) {
+    return *name;
+  }
+  return "Custom Persona";
+}
+
+base::DictValue NormalizePersona(const base::DictValue& payload,
+                                 const std::string& fallback_id) {
+  base::DictValue persona = payload.Clone();
+  const std::string timestamp = MakeIsoTimestamp();
+
+  const std::string* id = persona.FindString("id");
+  if (!id || id->empty()) {
+    persona.Set("id", fallback_id.empty() ? kDefaultPersonaId : fallback_id);
+  }
+
+  const std::string* name = persona.FindString("name");
+  if (!name || name->empty()) {
+    persona.Set("name", "Custom Persona");
+  }
+  if (const std::string* display_name = persona.FindString("displayName");
+      !display_name || display_name->empty()) {
+    persona.Set("displayName", GetPersonaDisplayName(persona));
+  }
+
+  const std::string platform = ResolvePersonaPlatform(persona);
+  persona.Set("platform", platform);
+  if (const std::string* icon = persona.FindString("icon");
+      !icon || icon->empty()) {
+    persona.Set("icon", GetPersonaIconForPlatform(platform));
+  }
+
+  const std::string* created_at = persona.FindString("createdAt");
+  if (!created_at || created_at->empty()) {
+    persona.Set("createdAt", timestamp);
+  }
+  persona.Set("modifiedAt", timestamp);
+  if (!persona.FindString("lastUsedAt")) {
+    persona.Set("lastUsedAt", "");
+  }
+
+  if (!persona.FindBool("enabled").has_value()) {
+    persona.Set("enabled", true);
+  }
+
+  if (!persona.FindString("userAgent")) {
+    persona.Set("userAgent", "");
+  }
+
+  base::DictValue* region = persona.EnsureDict("region");
+  if (!region->FindString("timezone")) {
+    region->Set("timezone", "UTC");
+  }
+  if (!region->FindString("locale")) {
+    region->Set("locale", "en-US");
+  }
+  if (!region->FindString("acceptLanguage")) {
+    region->Set("acceptLanguage", "en-US,en;q=0.9");
+  }
+
+  base::DictValue* ua_ch = persona.EnsureDict("uaCh");
+  if (!ua_ch->FindString("platform")) {
+    ua_ch->Set("platform", "macOS");
+  }
+  if (!ua_ch->FindString("platformVersion")) {
+    ua_ch->Set("platformVersion", "");
+  }
+  if (!ua_ch->FindString("architecture")) {
+    ua_ch->Set("architecture", "arm");
+  }
+  if (!ua_ch->FindString("model")) {
+    ua_ch->Set("model", "");
+  }
+  if (!ua_ch->FindString("bitness")) {
+    ua_ch->Set("bitness", "64");
+  }
+  if (!ua_ch->FindString("fullVersion")) {
+    ua_ch->Set("fullVersion", "");
+  }
+  if (!ua_ch->FindBool("mobile").has_value()) {
+    ua_ch->Set("mobile", false);
+  }
+  if (!ua_ch->FindBool("wow64").has_value()) {
+    ua_ch->Set("wow64", false);
+  }
+
+  base::DictValue* advanced = persona.EnsureDict("advanced");
+  if (!advanced->FindBool("clientHintsEnabled").has_value()) {
+    advanced->Set("clientHintsEnabled", true);
+  }
+  if (!advanced->FindBool("allowBackgroundSync").has_value()) {
+    advanced->Set("allowBackgroundSync", false);
+  }
+  if (!advanced->FindBool("allowContacts").has_value()) {
+    advanced->Set("allowContacts", false);
+  }
+  if (!advanced->FindBool("allowPrivacySandboxApis").has_value()) {
+    advanced->Set("allowPrivacySandboxApis", true);
+  }
+  if (!advanced->FindBool("canvasNoise").has_value()) {
+    advanced->Set("canvasNoise", true);
+  }
+  if (!advanced->FindBool("audioNoise").has_value()) {
+    advanced->Set("audioNoise", true);
+  }
+  if (!advanced->FindBool("fontMetricNoise").has_value()) {
+    advanced->Set("fontMetricNoise", false);
+  }
+
+  return persona;
+}
