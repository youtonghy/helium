+
+base::DictValue PersonaService::CreatePersonaProfile(
+    const std::string& display_name) {
+  base::DictValue state = ReadState();
+  base::DictValue persona = NormalizePersona(
+      MakeNewProfile(display_name), MakePersonaId());
+  persona.Set("lastUsedAt", MakeIsoTimestamp());
+  const std::string* persona_id = persona.FindString("id");
+  state.Set("personas", UpsertPersona(state.FindList("personas"), persona));
+  if (persona_id) {
+    state.Set("activePersonaId", *persona_id);
+    state.Set("lastUsedPersonaId", *persona_id);
+    SetLastUsedPersonaId(*persona_id);
+  }
+  WriteState(state.Clone());
+  return MakeResponse(true, std::move(state));
+}
+
+base::DictValue PersonaService::SavePersona(const base::DictValue& payload) {
+  base::DictValue state = ReadState();
+  base::DictValue persona = NormalizePersona(payload, GetActivePersonaId(state));
+  const std::string* persona_id = persona.FindString("id");
+  if (persona_id && !persona_id->empty()) {
+    persona.Set("lastUsedAt", MakeIsoTimestamp());
+  }
+  state.Set("personas", UpsertPersona(state.FindList("personas"), persona));
+  const std::string active_persona_id =
+      persona_id ? *persona_id : kDefaultPersonaId;
+  state.Set("activePersonaId", active_persona_id);
+  state.Set("lastUsedPersonaId", active_persona_id);
+  SetLastUsedPersonaId(active_persona_id);
+  WriteState(state.Clone());
+  return MakeResponse(true, std::move(state));
+}
+
+base::DictValue PersonaService::ClonePresetIntoProfile(const std::string& preset_id) {
+  base::DictValue state = ReadState();
+  const base::DictValue* preset =
+      FindPersonaInList(state.FindList("presets"), preset_id);
+  if (!preset) {
+    base::DictValue errors;
+    errors.Set("presetId", "Unknown preset");
+    return MakeResponse(false, std::move(state), std::move(errors));
+  }
+
+  base::DictValue persona = NormalizePersona(*preset, MakePersonaId());
+  persona.Set("id", MakePersonaId());
+  const std::string* preset_name = preset->FindString("name");
+  if (preset_name && !preset_name->empty()) {
+    persona.Set("name", *preset_name + " Copy");
+    persona.Set("displayName", *preset_name + " Copy");
+  }
+  const std::string* persona_id = persona.FindString("id");
+  persona.Set("lastUsedAt", MakeIsoTimestamp());
+  state.Set("personas", UpsertPersona(state.FindList("personas"), persona));
+  if (persona_id) {
+    state.Set("activePersonaId", *persona_id);
+    state.Set("lastUsedPersonaId", *persona_id);
+    SetLastUsedPersonaId(*persona_id);
+  }
+  WriteState(state.Clone());
+  return MakeResponse(true, std::move(state));
+}
+
+base::DictValue PersonaService::SetActivePersona(const std::string& persona_id) {
+  base::DictValue state = ReadState();
+  const base::DictValue* current_persona =
+      FindPersonaInList(state.FindList("personas"), persona_id);
+  if (!current_persona) {
+    base::DictValue errors;
+    errors.Set("personaId", "Unknown persona");
+    return MakeResponse(false, std::move(state), std::move(errors));
+  }
+
+  base::DictValue persona = current_persona->Clone();
+  persona.Set("lastUsedAt", MakeIsoTimestamp());
+  state.Set("personas", UpsertPersona(state.FindList("personas"), persona));
+  state.Set("activePersonaId", persona_id);
+  state.Set("lastUsedPersonaId", persona_id);
+  SetLastUsedPersonaId(persona_id);
+  WriteState(state.Clone());
+  return MakeResponse(true, std::move(state));
+}
+
+base::DictValue PersonaService::DeletePersona(const std::string& persona_id) {
+  base::DictValue state = ReadState();
+  if (persona_id == kDefaultPersonaId) {
+    base::DictValue errors;
+    errors.Set("personaId", "Default persona cannot be deleted");
+    return MakeResponse(false, std::move(state), std::move(errors));
+  }
+
+  base::ListValue personas;
+  const base::ListValue* existing = state.FindList("personas");
+  if (existing) {
+    for (const auto& value : *existing) {
+      if (!value.is_dict()) {
+        continue;
+      }
+
+      const base::DictValue& persona = value.GetDict();
+      const std::string* id = persona.FindString("id");
+      if (!id || *id != persona_id) {
+        personas.Append(persona.Clone());
+      }
+    }
+  }
+
+  if (personas.empty()) {
+    personas.Append(MakeDefaultPersona());
+  }
+
+  std::string active_id = GetActivePersonaId(state);
+  if (active_id == persona_id) {
+    const base::DictValue& first_persona = personas.front().GetDict();
+    const std::string* first_id = first_persona.FindString("id");
+    active_id = first_id ? *first_id : kDefaultPersonaId;
+  }
+
+  state.Set("personas", std::move(personas));
+  state.Set("activePersonaId", active_id);
+  if (GetLastUsedPersonaId() == persona_id) {
+    SetLastUsedPersonaId(active_id);
+  }
+  WriteState(state.Clone());
+  return MakeResponse(true, std::move(state));
+}
+
+std::string PersonaService::GetLastUsedPersonaId() const {
+  if (!prefs_) {
+    return kDefaultPersonaId;
+  }
+  const std::string last_used = prefs_->GetString(kPersonaLastUsedIdPref);
+  return last_used.empty() ? kDefaultPersonaId : last_used;
+}
