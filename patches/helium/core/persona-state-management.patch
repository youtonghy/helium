+  screen.Set("dynamicRange", "standard");
+  screen.Set("monochromeDepth", 0);
+
+  base::DictValue fonts;
+  fonts.Set("id", fonts_id);
+
+  base::DictValue font_rendering;
+  font_rendering.Set("profileVersion", font_profile_version);
+  font_rendering.Set("engine", platform == "Windows" ? "directwrite"
+                                                      : "coretext");
+  font_rendering.Set("textGamma", 2.2);
+  font_rendering.Set("useAutohinter", platform == "Linux");
+
+  base::DictValue media_devices;
+  media_devices.Set("audioInputDeviceId", media_device_id);
+  media_devices.Set("videoWidth", video_width);
+  media_devices.Set("videoFrameRate", 30);
+  media_devices.Set("audioBaseLatency", audio_base_latency);
+  media_devices.Set("audioOutputLatency", audio_base_latency * 2);
+  media_devices.Set("voiceIsolation", platform == "macOS");
+
+  base::DictValue network;
+  network.Set("type", network_type);
+  network.Set("downlinkMax", network_downlink_max);
+  network.Set("saveData", false);
+  network.Set("online", true);
+
+  return base::DictValue()
+      .Set("id", id)
+      .Set("name", name)
+      .Set("displayName", name)
+      .Set("icon", GetPersonaIconForPlatform(platform))
+      .Set("createdAt", created_at)
+      .Set("modifiedAt", created_at)
+      .Set("lastUsedAt", "")
+      .Set("enabled", true)
+      .Set("userAgent", user_agent)
+      .Set("platform", platform)
+      .Set("navigatorVendor", "Google Inc.")
+      .Set("navigatorProductSub", "20030107")
+      .Set("region", std::move(region))
+      .Set("uaCh", std::move(ua_ch))
+      .Set("gpu", std::move(gpu))
+      .Set("hardware", std::move(hardware))
+      .Set("screen", std::move(screen))
+      .Set("fonts", std::move(fonts))
+      .Set("fontRendering", std::move(font_rendering))
+      .Set("mediaDevices", std::move(media_devices))
+      .Set("network", std::move(network))
+      .Set("advanced", MakeAdvancedDefaults());
+}
