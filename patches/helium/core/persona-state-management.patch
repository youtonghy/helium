+      const std::string* brand = brand_dict.FindString("brand");
+      const std::string* version = brand_dict.FindString("version");
+      if (brand && version) {
+        snapshot.ua_ch_brands.push_back({*brand, *version});
+      }
+    }
+  }
+
+  return snapshot;
+}
+
+base::DictValue PersonaService::ReadState() const {
+  if (!prefs_) {
+    base::DictValue state = MakeDefaultState();
+    state.Set("lastUsedPersonaId", kDefaultPersonaId);
+    state.Set("launchSelectionMode", kLaunchSelectionModeAlwaysAsk);
+    return state;
+  }
+
+  base::DictValue state = prefs_->GetDict(kPersonaStatePref).Clone();
+  if (!state.FindList("personas")) {
+    state = MakeDefaultState();
+  } else {
+    state.Set("personas",
+              NormalizePersonaList(state.FindList("personas"), true));
+  }
+  if (!state.FindList("presets")) {
+    state.Set("presets", MakePresetList());
+  } else {
+    state.Set("presets", NormalizePersonaList(state.FindList("presets"), false));
+  }
+  if (!state.FindString("activePersonaId")) {
+    state.Set("activePersonaId", kDefaultPersonaId);
+  }
+  state.Set("lastUsedPersonaId", GetLastUsedPersonaId());
+  state.Set("launchSelectionMode", GetLaunchSelectionMode());
+  return state;
+}
+
+void PersonaService::WriteState(base::DictValue state) {
+  if (prefs_) {
+    prefs_->SetDict(kPersonaStatePref, std::move(state));
+  }
+}
