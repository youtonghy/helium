+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+#include "chrome/browser/helium_persona/persona_service.h"
+
+#include "components/prefs/pref_service.h"
+
+namespace helium_persona {
+
+PersonaService::PersonaService(PrefService* prefs) : prefs_(prefs) {}
+PersonaService::~PersonaService() = default;
+
+base::Value::Dict PersonaService::GetPersonaState() const {
+  return base::Value::Dict();
+}
+
+base::Value::Dict PersonaService::SavePersona(const base::Value::Dict& payload) {
+  return payload.Clone();
+}
+
+base::Value::Dict PersonaService::ClonePresetIntoProfile(const std::string& preset_id) {
+  base::Value::Dict result;
+  result.Set("presetId", preset_id);
+  return result;
+}
+
+base::Value::Dict PersonaService::SetActivePersona(const std::string& persona_id) {
+  base::Value::Dict result;
+  result.Set("activePersonaId", persona_id);
+  return result;
+}
+
+base::Value::Dict PersonaService::DeletePersona(const std::string& persona_id) {
+  base::Value::Dict result;
+  result.Set("deletedPersonaId", persona_id);
+  return result;
+}
+
+blink::HeliumPersonaSnapshot PersonaService::GetActiveSnapshot() const {
+  return blink::HeliumPersonaSnapshot();
+}
+
+}  // namespace helium_persona
