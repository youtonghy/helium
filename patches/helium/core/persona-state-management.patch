+base::DictValue MakeResponse(bool ok,
+                             base::DictValue state,
+                             base::DictValue field_errors = base::DictValue()) {
+  if (!state.FindString("lastUsedPersonaId")) {
+    state.Set("lastUsedPersonaId", kDefaultPersonaId);
+  }
+  if (!state.FindString("launchSelectionMode")) {
+    state.Set("launchSelectionMode", kLaunchSelectionModeAlwaysAsk);
+  }
+  return base::DictValue()
+      .Set("ok", ok)
+      .Set("state", std::move(state))
+      .Set("fieldErrors", std::move(field_errors));
+}
+
+base::ListValue UpsertPersona(const base::ListValue* existing,
+                              const base::DictValue& persona) {
+  base::ListValue personas;
+  const std::string* persona_id = persona.FindString("id");
+  bool replaced = false;
+
+  if (existing) {
+    for (const auto& value : *existing) {
+      if (!value.is_dict()) {
+        continue;
+      }
+
+      const base::DictValue& current = value.GetDict();
+      const std::string* current_id = current.FindString("id");
+      if (persona_id && current_id && *current_id == *persona_id) {
+        personas.Append(persona.Clone());
+        replaced = true;
+      } else {
+        personas.Append(current.Clone());
+      }
+    }
+  }
+
+  if (!replaced) {
+    personas.Append(persona.Clone());
+  }
+
+  return personas;
+}
+
+base::ListValue NormalizePersonaList(const base::ListValue* existing,
+                                     bool ensure_default) {
+  base::ListValue personas;
+  bool has_default = false;
+
+  if (existing) {
+    for (const auto& value : *existing) {
+      if (!value.is_dict()) {
+        continue;
+      }
+      base::DictValue normalized =
+          NormalizePersona(value.GetDict(), MakePersonaId());
+      const std::string* id = normalized.FindString("id");
+      has_default |= id && *id == kDefaultPersonaId;
+      personas.Append(std::move(normalized));
+    }
+  }
+
+  if (ensure_default && !has_default) {
+    personas.Append(MakeDefaultPersona());
+  }
+  return personas;
+}
+
+base::DictValue MakeNewProfile(std::string_view display_name) {
+  const std::string timestamp = MakeIsoTimestamp();
+  const std::string resolved_display_name =
+      display_name.empty() ? "New Persona" : std::string(display_name);
+  return base::DictValue()
+      .Set("id", MakePersonaId())
+      .Set("name", resolved_display_name)
+      .Set("displayName", resolved_display_name)
+      .Set("icon", "default")
+      .Set("createdAt", timestamp)
+      .Set("modifiedAt", timestamp)
+      .Set("lastUsedAt", "")
+      .Set("enabled", true)
+      .Set("userAgent", "")
+      .Set("platform", "macOS")
+      .Set("navigatorVendor", "Google Inc.")
+      .Set("navigatorProductSub", "20030107")
+      .Set("region", MakeRegionDefaults())
+      .Set("uaCh", MakeUaChDefaults())
+      .Set("advanced", MakeAdvancedDefaults());
+}
+
+const std::string* FindNestedString(const base::DictValue& persona,
+                                    std::string_view dict_key,
+                                    std::string_view key) {
+  const base::DictValue* dict = persona.FindDict(dict_key);
+  return dict ? dict->FindString(key) : nullptr;
+}
+
+std::optional<bool> FindNestedBool(const base::DictValue& persona,
+                                   std::string_view dict_key,
+                                   std::string_view key) {
+  const base::DictValue* dict = persona.FindDict(dict_key);
+  return dict ? dict->FindBool(key) : std::nullopt;
+}
+
+std::optional<int> FindNestedInt(const base::DictValue& persona,
+                                 std::string_view dict_key,
+                                 std::string_view key) {
+  const base::DictValue* dict = persona.FindDict(dict_key);
+  return dict ? dict->FindInt(key) : std::nullopt;
+}
+
+std::optional<double> FindNestedDouble(const base::DictValue& persona,
+                                       std::string_view dict_key,
+                                       std::string_view key) {
+  const base::DictValue* dict = persona.FindDict(dict_key);
+  return dict ? dict->FindDouble(key) : std::nullopt;
+}
+
+std::vector<std::string> DeriveNavigatorLanguages(std::string_view locale) {
+  std::vector<std::string> languages;
+  if (locale.empty()) {
+    return languages;
+  }
+
+  languages.emplace_back(locale);
+  const size_t separator = locale.find('-');
+  if (separator != std::string_view::npos && separator > 0) {
+    languages.emplace_back(locale.substr(0, separator));
+  }
+  return languages;
+}
+
+std::string ResolvePersonaPlatform(const base::DictValue& persona) {
+  if (const std::string* platform = persona.FindString("platform");
+      platform && !platform->empty()) {
+    return *platform;
+  }
+  if (const std::string* platform =
+          FindNestedString(persona, "uaCh", "platform");
+      platform && !platform->empty()) {
+    return *platform;
+  }
+  return "macOS";
+}
+
+base::DictValue BuildProfilesResponse(const base::DictValue& state) {
+  base::DictValue response;
+  if (const base::ListValue* personas = state.FindList("personas")) {
+    response.Set("profiles", personas->Clone());
+  } else {
+    response.Set("profiles", base::ListValue());
+  }
+  response.Set("activePersonaId", GetActivePersonaId(state));
+  if (const std::string* last_used_id = state.FindString("lastUsedPersonaId")) {
+    response.Set("lastUsedPersonaId", *last_used_id);
+  }
+  if (const std::string* launch_mode = state.FindString("launchSelectionMode")) {
+    response.Set("launchSelectionMode", *launch_mode);
+  }
+  return response;
+}
