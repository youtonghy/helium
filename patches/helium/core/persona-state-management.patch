+  }
+  if (const std::string* accept_language =
+          FindNestedString(*persona, "region", "acceptLanguage")) {
+    snapshot.accept_language = *accept_language;
+  }
+  if (const std::string* value = FindNestedString(*persona, "uaCh", "platform")) {
+    snapshot.ua_ch_platform = *value;
+  }
+  if (const std::string* value =
+          FindNestedString(*persona, "uaCh", "platformVersion")) {
+    snapshot.ua_ch_platform_version = *value;
