+TEST(HeliumPersonaPrefsTest, CustomPersonaPresetCanBeSavedClonedAndDeleted) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+
+  base::Value::List builtin_presets = GetBuiltinPersonaPresets();
+  base::Value::Dict preset = DictAt(builtin_presets, 1).Clone();
+  preset.Set("id", "");
+  preset.Set("name", "Manual preset template");
+  preset.Set("source", "custom-preset");
+  preset.Set("builtin", false);
+  preset.Set("modified", true);
+
+  base::Value::Dict saved = SavePersonaPreset(prefs, std::move(preset));
+  const std::string* saved_id = saved.FindString("id");
+  ASSERT_TRUE(saved_id);
+  EXPECT_EQ(0u, saved_id->rfind("custom-preset-", 0));
+  EXPECT_EQ("custom-preset", *saved.FindString("source"));
+  EXPECT_FALSE(saved.FindBool("builtin").value_or(true));
+  EXPECT_EQ(*saved_id, prefs.GetString(prefs::kHeliumActivePersonaId));
+
+  base::Value::Dict state = GetPersonaState(prefs);
+  const base::Value::List* presets = state.FindList("presets");
+  ASSERT_TRUE(presets);
+  const base::Value::Dict* stored = FindProfileById(*presets, *saved_id);
+  ASSERT_TRUE(stored);
+  EXPECT_EQ("Manual preset template", *stored->FindString("name"));
+
+  base::Value::Dict cloned = ClonePresetIntoProfile(prefs, *saved_id);
+  const std::string* cloned_id = cloned.FindString("id");
+  ASSERT_TRUE(cloned_id);
+  EXPECT_EQ(0u, cloned_id->rfind("persona-", 0));
+  EXPECT_EQ(*saved_id, *cloned.FindString("basePresetId"));
+  EXPECT_EQ("Manual preset template", *cloned.FindString("basePresetName"));
+  EXPECT_EQ(*cloned_id, prefs.GetString(prefs::kHeliumActivePersonaId));
+
+  ASSERT_TRUE(DeletePersonaPreset(prefs, *saved_id));
+  EXPECT_FALSE(SetActivePersona(prefs, *saved_id));
