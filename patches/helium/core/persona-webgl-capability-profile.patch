+WebGLShaderPrecisionFormat* PersonaShaderPrecisionFormat(
+    GLenum precision_type) {
+  switch (precision_type) {
+    case GL_LOW_FLOAT:
+    case GL_MEDIUM_FLOAT:
+    case GL_HIGH_FLOAT:
+      return MakeGarbageCollected<WebGLShaderPrecisionFormat>(127, 127, 23);
+    case GL_LOW_INT:
+    case GL_MEDIUM_INT:
+    case GL_HIGH_INT:
+      return MakeGarbageCollected<WebGLShaderPrecisionFormat>(31, 30, 0);
+    default:
+      return nullptr;
+  }
+}
