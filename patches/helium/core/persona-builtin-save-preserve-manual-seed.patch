+TEST(HeliumPersonaPrefsTest, SaveBuiltinIdPreservesManualNoiseSeed) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  base::Value::Dict persona = DictAt(presets, 1).Clone();
+  const std::string original_id = *persona.FindString("id");
+  persona.Set("noiseSeed", "manual-seed");
+
+  EXPECT_TRUE(SavePersona(prefs, std::move(persona)));
+  base::Value::Dict active = GetActivePersona(prefs);
+  EXPECT_NE(original_id, *active.FindString("id"));
+  EXPECT_EQ("manual-seed", *active.FindString("noiseSeed"));
+  EXPECT_EQ(original_id, *active.FindString("basePresetId"));
+}
