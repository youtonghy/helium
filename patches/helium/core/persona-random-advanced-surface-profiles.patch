+void ApplyPresetAdvancedDefaults(std::string_view os,
+                                 const base::Value::Dict& region,
+                                 const base::Value::Dict& hardware,
+                                 base::Value::Dict& advanced) {
+  const std::string* locale = region.FindString("locale");
+  if (!locale || locale->empty())
+    return;
+
+  const std::string_view locale_view(*locale);
+  const std::string_view voice_name = LocaleSpeechVoiceName(os, locale_view);
+  advanced.Set("storageQuotaGb", PersonaStorageQuotaGb(hardware));
+  advanced.Set("speechVoiceName", voice_name);
+  advanced.Set("speechVoiceLang", locale_view);
+  advanced.Set("speechVoiceUri", voice_name);
+  advanced.Set("speechVoiceLocalService", true);
+  advanced.Set("speechVoiceDefault", true);
+}
