+  private applyRandomAdvancedSurface_(persona: PersonaRecord) {
+    persona.advanced = persona.advanced || {};
+    const memory = Number((persona.hardware || {})['deviceMemory'] || 8);
+    const quotaProfiles = memory >= 16 ? [128, 192, 256, 512] :
+        memory >= 8 ? [64, 96, 120, 160, 256] : [20, 40, 64, 80];
+    const voiceProfiles = this.speechVoiceProfiles_(persona);
+    const voiceProfile = this.randomFrom_(voiceProfiles, voiceProfiles[0]);
+    Object.assign(persona.advanced, {
+      clientHintsEnabled: true,
+      reduceSystemInfo: false,
+      canvasNoise: true,
+      audioNoise: true,
+      fontMetricNoise: true,
+      pdfViewerEnabled: true,
+      cookieEnabled: true,
+      virtualMediaDevices: true,
+      storageQuotaGb: this.randomFrom_(quotaProfiles, quotaProfiles[0]),
+      doNotTrackEnabled: this.randomInt_(1, 100) <= 4,
+    }, voiceProfile);
+  }
