+double PersonaStorageQuotaGb(const base::Value::Dict& hardware) {
+  const double memory_gb = hardware.FindDouble("deviceMemory").value_or(
+      hardware.FindInt("deviceMemory").value_or(8));
+  if (memory_gb >= 16)
+    return 256;
+  if (memory_gb >= 8)
+    return 120;
+  if (memory_gb >= 4)
+    return 80;
+  return 20;
+}
