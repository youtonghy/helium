+void EnsureNumericProfileField(base::Value::Dict& profile,
+                               const base::Value::Dict& defaults,
+                               std::string_view key) {
+  if (HasNumericValue(profile, key)) {
+    return;
+  }
+  if (std::optional<int> default_int = defaults.FindInt(key)) {
+    profile.Set(key, *default_int);
+    return;
+  }
+  if (std::optional<double> default_double = defaults.FindDouble(key)) {
+    profile.Set(key, *default_double);
+  }
+}
