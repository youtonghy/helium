+TEST(HeliumPersonaPrefsTest, SavePersonaRepairsPartialGpuProfiles) {
+  sync_preferences::TestingPrefServiceSyncable prefs;
+  RegisterTestPrefs(prefs);
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  base::Value::Dict persona = DictAt(presets, 1).Clone();
+  persona.Set("id", "partial-gpu-persona");
+  persona.Set("source", "custom");
+  persona.Set("builtin", false);
+
+  base::Value::Dict* gpu = persona.FindDict("gpu");
+  ASSERT_TRUE(gpu);
+  base::Value::Dict* webgl_profile = gpu->FindDict("webglProfile");
+  ASSERT_TRUE(webgl_profile);
+  webgl_profile->Remove("maxTextureSize");
+  webgl_profile->Remove("maxAnisotropy");
+  base::Value::Dict* webgl2_profile = gpu->FindDict("webgl2Profile");
+  ASSERT_TRUE(webgl2_profile);
+  webgl2_profile->Remove("maxDrawBuffers");
+  webgl2_profile->Remove("maxTextureLodBias");
+  base::Value::Dict* webgpu_profile = gpu->FindDict("webgpuProfile");
+  ASSERT_TRUE(webgpu_profile);
+  webgpu_profile->Remove("maxTextureDimension2D");
+  webgpu_profile->Remove("maxBufferSize");
+  webgpu_profile->Remove("maxComputeWorkgroupsPerDimension");
+
+  EXPECT_TRUE(SavePersona(prefs, std::move(persona)));
+  base::Value::Dict active = GetActivePersona(prefs);
+  ASSERT_TRUE(active.FindDict("gpu"));
+  webgl_profile = active.FindDict("gpu")->FindDict("webglProfile");
+  ASSERT_TRUE(webgl_profile);
+  EXPECT_EQ(16384, webgl_profile->FindInt("maxTextureSize").value_or(0));
+  EXPECT_EQ(16.0, webgl_profile->FindDouble("maxAnisotropy").value_or(0.0));
+  webgl2_profile = active.FindDict("gpu")->FindDict("webgl2Profile");
+  ASSERT_TRUE(webgl2_profile);
+  EXPECT_EQ(8, webgl2_profile->FindInt("maxDrawBuffers").value_or(0));
+  EXPECT_EQ(15.0,
+            webgl2_profile->FindDouble("maxTextureLodBias").value_or(0.0));
+  webgpu_profile = active.FindDict("gpu")->FindDict("webgpuProfile");
+  ASSERT_TRUE(webgpu_profile);
+  EXPECT_EQ(8192,
+            webgpu_profile->FindInt("maxTextureDimension2D").value_or(0));
+  EXPECT_EQ(268435456, webgpu_profile->FindInt("maxBufferSize").value_or(0));
+  EXPECT_EQ(65535, webgpu_profile->FindInt("maxComputeWorkgroupsPerDimension")
+                       .value_or(0));
+}
