+base::ReadOnlySharedMemoryRegion SerializeFontEnumerationTable(
+    const blink::FontEnumerationTable& table) {
+  base::MappedReadOnlyRegion region =
+      base::ReadOnlySharedMemoryRegion::Create(table.ByteSizeLong());
+  if (!region.mapping.IsValid()) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+
+  base::span<uint8_t> font_mem(region.mapping);
+  if (!table.SerializeToArray(font_mem.data(), font_mem.size())) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+  return std::move(region.region);
+}
+
+std::optional<base::ReadOnlySharedMemoryRegion> FilterFontEnumerationData(
+    base::ReadOnlySharedMemoryRegion region,
+    const blink::HeliumPersonaSnapshot& snapshot,
+    bool* has_filtered_fonts) {
+  std::set<std::string> allowed_families(snapshot.font_families.begin(),
+                                        snapshot.font_families.end());
+  allowed_families.insert(snapshot.font_aliases.begin(),
+                          snapshot.font_aliases.end());
+
+  blink::FontEnumerationTable table;
+  base::ReadOnlySharedMemoryMapping mapping = region.Map();
+  if (mapping.size() > INT_MAX) {
+    return std::nullopt;
+  }
+  if (!mapping.IsValid() ||
+      !table.ParseFromArray(mapping.memory(),
+                            static_cast<int>(mapping.size()))) {
+    return std::nullopt;
+  }
+
+  blink::FontEnumerationTable filtered_table;
+  for (const auto& font : table.fonts()) {
+    if (allowed_families.contains(font.family())) {
+      *filtered_table.add_fonts() = font;
+    }
+  }
+  *has_filtered_fonts = !filtered_table.fonts().empty();
+  if (!*has_filtered_fonts) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+
+  base::ReadOnlySharedMemoryRegion filtered_region =
+      SerializeFontEnumerationTable(filtered_table);
+  if (!filtered_region.IsValid()) {
+    return std::nullopt;
+  }
+  return filtered_region;
+}
