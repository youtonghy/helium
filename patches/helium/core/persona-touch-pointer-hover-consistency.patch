+void ApplyHeliumPersonaInputDeviceSettings(
+    Page* page,
+    const HeliumPersonaSnapshot& snapshot) {
+  if (!page || !snapshot.IsEnabled()) {
+    return;
+  }
+
+  Settings& settings = page->GetSettings();
+  if (snapshot.touch_enabled) {
+    const int max_touch_points = std::max(1, snapshot.max_touch_points);
+    settings.SetForceTouchEventFeatureDetectionForInspector(true);
+    settings.SetMaxTouchPoints(max_touch_points);
+    settings.SetAvailablePointerTypes(
+        static_cast<int>(mojom::blink::PointerType::kPointerCoarseType));
+    settings.SetPrimaryPointerType(
+        mojom::blink::PointerType::kPointerCoarseType);
+    settings.SetAvailableHoverTypes(
+        static_cast<int>(mojom::blink::HoverType::kHoverNone));
+    settings.SetPrimaryHoverType(mojom::blink::HoverType::kHoverNone);
+    return;
+  }
+
+  settings.SetForceTouchEventFeatureDetectionForInspector(false);
+  settings.SetMaxTouchPoints(0);
+  settings.SetAvailablePointerTypes(
+      static_cast<int>(mojom::blink::PointerType::kPointerFineType));
+  settings.SetPrimaryPointerType(mojom::blink::PointerType::kPointerFineType);
+  settings.SetAvailableHoverTypes(
+      static_cast<int>(mojom::blink::HoverType::kHoverHoverType));
+  settings.SetPrimaryHoverType(mojom::blink::HoverType::kHoverHoverType);
+}
