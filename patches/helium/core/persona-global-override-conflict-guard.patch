+bool HasConflictingRequestedValues(
+    const std::map<const void*, std::string>& requests) {
+  std::string first_value;
+  for (const auto& entry : requests) {
+    if (entry.second.empty()) {
+      continue;
+    }
+    if (first_value.empty()) {
+      first_value = entry.second;
+      continue;
+    }
+    if (entry.second != first_value) {
+      return true;
+    }
+  }
+  return false;
+}
