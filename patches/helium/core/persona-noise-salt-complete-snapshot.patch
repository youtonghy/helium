+void AppendSaltPart(std::string& salt, std::string_view value) {
+  salt.append("|");
+  salt.append(base::NumberToString(static_cast<uint64_t>(value.size())));
+  salt.append(":");
+  salt.append(value);
+}
+
+void AppendSaltPart(std::string& salt, const std::string& value) {
+  AppendSaltPart(salt, std::string_view(value));
+}
+
+void AppendSaltPart(std::string& salt, const char* value) {
+  AppendSaltPart(salt, std::string_view(value));
+}
+
+void AppendSaltPart(std::string& salt, bool value) {
+  AppendSaltPart(salt, value ? "1" : "0");
+}
+
+void AppendSaltPart(std::string& salt, int value) {
+  AppendSaltPart(salt, base::NumberToString(value));
+}
+
+void AppendSaltPart(std::string& salt, double value) {
+  AppendSaltPart(salt, base::NumberToString(value));
+}
+
+void AppendSaltList(std::string& salt,
+                    const std::vector<std::string>& values) {
+  AppendSaltPart(salt, "[");
+  for (const std::string& value : values) {
+    AppendSaltPart(salt, value);
+  }
+  AppendSaltPart(salt, "]");
+}
+
+void AppendSaltUaChBrands(
+    std::string& salt,
+    const std::vector<blink::HeliumPersonaUaChBrand>& brands) {
+  AppendSaltPart(salt, "[");
+  for (const blink::HeliumPersonaUaChBrand& brand : brands) {
+    AppendSaltPart(salt, brand.brand);
+    AppendSaltPart(salt, brand.version);
+  }
+  AppendSaltPart(salt, "]");
+}
