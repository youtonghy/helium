+#include "chrome/browser/ui/views/persona/persona_indicator_button.h"
+
+#include <string_view>
+
+#include "base/strings/utf_string_conversions.h"
+#include "base/values.h"
+#include "chrome/app/vector_icons/vector_icons.h"
+#include "chrome/browser/helium_persona/persona_service.h"
+#include "chrome/browser/helium_persona/persona_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/view_ids.h"
+#include "chrome/browser/ui/views/persona/persona_indicator_menu_model.h"
+#include "ui/base/menu_source_utils.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/views/accessibility/view_accessibility.h"
+#include "ui/views/controls/button/menu_button_controller.h"
+#include "ui/views/controls/menu/menu_runner.h"
+
+namespace {
+
+constexpr size_t kMaxPersonaButtonLabelLength = 10;
+constexpr char kDefaultPersonaId[] = "default";
+
+struct PersonaIndicatorState {
+  const gfx::VectorIcon* icon = &kGlobeIcon;
+  std::u16string short_label = u"Default";
+  std::u16string full_label = u"Default persona";
+};
+
+std::u16string MakeShortPersonaLabel(std::string_view label) {
+  if (label.empty()) {
+    return u"Default";
+  }
+
+  const size_t separator = label.find_first_of(" -_/");
+  std::string short_label(
+      label.substr(0, separator == std::string_view::npos ? label.size()
+                                                          : separator));
+  if (short_label.empty()) {
+    short_label = std::string(label);
+  }
+  if (short_label.size() > kMaxPersonaButtonLabelLength) {
+    short_label.resize(kMaxPersonaButtonLabelLength);
+  }
+  return base::UTF8ToUTF16(short_label);
+}
+
+const gfx::VectorIcon& GetPersonaIcon(std::string_view icon_name) {
+  if (icon_name == "android") {
+    return kSmartphoneIcon;
+  }
+  if (icon_name == "windows") {
+    return kDesktopWindowsChromeRefreshIcon;
+  }
+  if (icon_name == "linux" || icon_name == "macos" ||
+      icon_name == "chromeos") {
+    return kLaptopIcon;
+  }
+  if (icon_name == "default") {
+    return kGlobeIcon;
+  }
+  return kAccountCircleChromeRefreshIcon;
+}
+
+std::string GetPersonaDisplayName(const base::DictValue& persona) {
+  if (const std::string* display_name = persona.FindString("displayName");
+      display_name && !display_name->empty()) {
+    return *display_name;
+  }
+  if (const std::string* name = persona.FindString("name");
+      name && !name->empty()) {
+    return *name;
+  }
+  return "Default";
+}
+
+PersonaIndicatorState GetPersonaIndicatorState(Browser* browser) {
+  auto* service =
+      helium_persona::PersonaServiceFactory::GetForProfile(browser->profile());
+  if (!service) {
+    return {};
+  }
+
+  base::DictValue response = service->GetPersonaProfiles();
+  const std::string* active_persona_id = response.FindString("activePersonaId");
+  const base::ListValue* profiles = response.FindList("profiles");
+  if (!active_persona_id || !profiles) {
+    return {};
+  }
+
+  for (const base::Value& value : *profiles) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const base::DictValue& persona = value.GetDict();
+    const std::string* persona_id = persona.FindString("id");
+    if (!persona_id || *persona_id != *active_persona_id) {
+      continue;
+    }
+
+    const std::optional<bool> enabled = persona.FindBool("enabled");
+    if (*persona_id == kDefaultPersonaId || (enabled.has_value() && !*enabled)) {
+      return {};
+    }
+
+    const std::string full_label = GetPersonaDisplayName(persona);
+    const std::string* icon_name = persona.FindString("icon");
+    return {
+        .icon = &(icon_name ? GetPersonaIcon(*icon_name) : kGlobeIcon),
+        .short_label = MakeShortPersonaLabel(full_label),
+        .full_label = base::UTF8ToUTF16(full_label),
+    };
+  }
+
+  return {};
+}
+
+}  // namespace
+
+PersonaIndicatorButton::PersonaIndicatorButton(Browser* browser)
+    : ToolbarButton(views::Button::PressedCallback()), browser_(browser) {
+  SetID(VIEW_ID_PERSONA_INDICATOR);
+  SetVectorIcon(kAccountCircleChromeRefreshIcon);
+  GetViewAccessibility().SetHasPopup(ax::mojom::HasPopup::kMenu);
+  SetButtonController(std::make_unique<views::MenuButtonController>(
+      this,
+      base::BindRepeating(&PersonaIndicatorButton::ButtonPressed,
+                          base::Unretained(this)),
+      std::make_unique<views::Button::DefaultButtonControllerDelegate>(this)));
+  Refresh();
+}
+
+PersonaIndicatorButton::~PersonaIndicatorButton() = default;
+
+void PersonaIndicatorButton::Refresh() {
+  const PersonaIndicatorState state = GetPersonaIndicatorState(browser_);
+  SetVectorIcon(*state.icon);
+  SetText(state.short_label);
+  SetTooltipText(state.full_label);
+  GetViewAccessibility().SetName(state.full_label);
+}
+
+void PersonaIndicatorButton::ButtonPressed(const ui::Event& event) {
+  if (menu_runner_ && menu_runner_->IsRunning()) {
+    menu_runner_->Cancel();
+    return;
+  }
+
+  menu_model_ = std::make_unique<PersonaIndicatorMenuModel>(browser_);
+  menu_runner_ =
+      std::make_unique<views::MenuRunner>(menu_model_.get(),
+                                          views::MenuRunner::HAS_MNEMONICS);
+  menu_runner_->RunMenuAt(
+      GetWidget(),
+      static_cast<views::MenuButtonController*>(button_controller()),
+      GetAnchorBoundsInScreen(), views::MenuAnchorPosition::kTopLeft,
+      ui::GetMenuSourceTypeForEvent(event));
+  Refresh();
+}
+
+BEGIN_METADATA(PersonaIndicatorButton)
+END_METADATA
