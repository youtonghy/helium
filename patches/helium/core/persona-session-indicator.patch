+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/views/persona/persona_indicator_menu_model.h"
+
+#include "base/strings/utf_string_conversions.h"
+#include "base/values.h"
+#include "chrome/browser/helium_persona/persona_service.h"
+#include "chrome/browser/helium_persona/persona_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/browser_window/public/profile_browser_collection.h"
+#include "chrome/browser/ui/chrome_pages.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/reload_type.h"
+
+namespace {
+
+constexpr int kPersonaCommandBase = 56000;
+constexpr int kCommandOpenPersonaSettings = kPersonaCommandBase;
+constexpr int kCommandPersonaGroupBase = kPersonaCommandBase + 100;
+
+std::string GetDisplayName(const base::DictValue& persona) {
+  if (const std::string* display_name = persona.FindString("displayName");
+      display_name && !display_name->empty()) {
+    return *display_name;
+  }
+  if (const std::string* name = persona.FindString("name");
+      name && !name->empty()) {
+    return *name;
+  }
+  if (const std::string* id = persona.FindString("id")) {
+    return *id;
+  }
+  return "Persona";
+}
+
+}  // namespace
+
+PersonaIndicatorMenuModel::PersonaIndicatorMenuModel(Browser* browser)
+    : ui::SimpleMenuModel(this), browser_(browser) {
+  Build();
+}
+
+PersonaIndicatorMenuModel::~PersonaIndicatorMenuModel() = default;
+
+void PersonaIndicatorMenuModel::Build() {
+  AddPersonaItems();
+  if (!persona_commands_.empty()) {
+    AddSeparator(ui::NORMAL_SEPARATOR);
+  }
+  AddItem(kCommandOpenPersonaSettings, u"Manage personas");
+}
+
+void PersonaIndicatorMenuModel::AddPersonaItems() {
+  auto* service = GetPersonaService();
+  if (!service) {
+    return;
+  }
+
+  base::DictValue response = service->GetPersonaProfiles();
+  const base::ListValue* profiles = response.FindList("profiles");
+  if (!profiles) {
+    return;
+  }
+
+  int next_command_id = kCommandPersonaGroupBase;
+  for (const base::Value& value : *profiles) {
+    if (!value.is_dict()) {
+      continue;
+    }
+    const base::DictValue& persona = value.GetDict();
+    const std::string* persona_id = persona.FindString("id");
+    if (!persona_id || persona_id->empty()) {
+      continue;
+    }
+
+    AddCheckItem(next_command_id,
+                 base::UTF8ToUTF16(GetDisplayName(persona)));
+    persona_commands_.push_back(
+        {.command_id = next_command_id, .persona_id = *persona_id});
+    ++next_command_id;
+  }
+}
+
+void PersonaIndicatorMenuModel::SetActivePersonaAndReload(
+    const std::string& persona_id) {
+  auto* service = GetPersonaService();
+  if (!service) {
+    return;
+  }
+
+  service->SetActivePersona(persona_id);
+
+  if (auto* collection = ProfileBrowserCollection::GetForProfile(
+          browser_->profile())) {
+    collection->ForEach([](BrowserWindowInterface* browser_interface) {
+      auto* browser = browser_interface->GetBrowserForMigrationOnly();
+      if (!browser) {
+        return true;
+      }
+
+      TabStripModel* tab_strip_model = browser->tab_strip_model();
+      for (int index = 0; index < tab_strip_model->count(); ++index) {
+        content::WebContents* contents =
+            tab_strip_model->GetWebContentsAt(index);
+        if (!contents) {
+          continue;
+        }
+        contents->GetController().Reload(content::ReloadType::NORMAL, true);
+      }
+      return true;
+    });
+  }
+}
+
+std::optional<std::string> PersonaIndicatorMenuModel::GetActivePersonaId()
+    const {
+  auto* service = GetPersonaService();
+  if (!service) {
+    return std::nullopt;
+  }
+
+  base::DictValue response = service->GetPersonaProfiles();
+  const std::string* active_persona_id = response.FindString("activePersonaId");
+  if (!active_persona_id || active_persona_id->empty()) {
+    return std::nullopt;
+  }
+  return *active_persona_id;
+}
+
+helium_persona::PersonaService* PersonaIndicatorMenuModel::GetPersonaService()
+    const {
+  return helium_persona::PersonaServiceFactory::GetForProfile(
+      browser_->profile());
+}
+
+bool PersonaIndicatorMenuModel::IsCommandIdChecked(int command_id) const {
+  auto active_persona_id = GetActivePersonaId();
+  if (!active_persona_id) {
+    return false;
+  }
+
+  for (const PersonaCommand& command : persona_commands_) {
+    if (command.command_id == command_id) {
+      return command.persona_id == *active_persona_id;
+    }
+  }
+  return false;
+}
+
+bool PersonaIndicatorMenuModel::IsCommandIdEnabled(int command_id) const {
+  if (command_id == kCommandOpenPersonaSettings) {
+    return true;
+  }
+
+  for (const PersonaCommand& command : persona_commands_) {
+    if (command.command_id == command_id) {
+      return true;
+    }
+  }
+  return false;
+}
+
+void PersonaIndicatorMenuModel::ExecuteCommand(int command_id,
+                                               int /*event_flags*/) {
+  if (command_id == kCommandOpenPersonaSettings) {
+    chrome::ShowSettingsSubPage(browser_, "persona");
+    return;
+  }
+
+  for (const PersonaCommand& command : persona_commands_) {
+    if (command.command_id == command_id) {
+      SetActivePersonaAndReload(command.persona_id);
+      return;
+    }
+  }
+}
