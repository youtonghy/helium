+
+#ifndef CHROME_BROWSER_UI_VIEWS_PERSONA_PERSONA_INDICATOR_MENU_MODEL_H_
+#define CHROME_BROWSER_UI_VIEWS_PERSONA_PERSONA_INDICATOR_MENU_MODEL_H_
+
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/memory/raw_ptr.h"
+#include "ui/menus/simple_menu_model.h"
+
+class Browser;
+
+namespace helium_persona {
+class PersonaService;
+}
+
+class PersonaIndicatorMenuModel : public ui::SimpleMenuModel,
+                                  public ui::SimpleMenuModel::Delegate {
+ public:
+  explicit PersonaIndicatorMenuModel(Browser* browser);
+  PersonaIndicatorMenuModel(const PersonaIndicatorMenuModel&) = delete;
+  PersonaIndicatorMenuModel& operator=(const PersonaIndicatorMenuModel&) =
+      delete;
+  ~PersonaIndicatorMenuModel() override;
+
+ private:
+  struct PersonaCommand {
+    int command_id = 0;
+    std::string persona_id;
+  };
+
+  void Build();
+  void AddPersonaItems();
+  void SetActivePersonaAndReload(const std::string& persona_id);
+
+  std::optional<std::string> GetActivePersonaId() const;
+  helium_persona::PersonaService* GetPersonaService() const;
+
+  // ui::SimpleMenuModel::Delegate:
+  bool IsCommandIdChecked(int command_id) const override;
+  bool IsCommandIdEnabled(int command_id) const override;
+  void ExecuteCommand(int command_id, int event_flags) override;
+
+  raw_ptr<Browser> browser_;
+  std::vector<PersonaCommand> persona_commands_;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_PERSONA_PERSONA_INDICATOR_MENU_MODEL_H_
