 namespace {
 
+bool IsPersonaStableMediaSourceMimeType(const String& mime_type) {
+  const String type = mime_type.DeprecatedLower();
+  return type == "audio/webm" || type == "video/webm" ||
+         type == "audio/mp4" || type == "video/mp4" ||
+         type == "application/mp4";
+}
+
+bool IsPersonaStableMediaSourceCodecToken(StringView codec_token) {
+  const String codec = codec_token.StripWhiteSpace().ToString().ToAsciiLower();
+  return codec == "opus" || codec == "vorbis" || codec == "vp8" ||
+         codec == "vp09" || codec == "vp9" ||
+         codec.StartsWithIgnoringAsciiCase("vp09.") ||
+         codec.StartsWithIgnoringAsciiCase("avc1") ||
+         codec.StartsWithIgnoringAsciiCase("avc3") ||
+         codec.StartsWithIgnoringAsciiCase("av01") ||
+         codec.StartsWithIgnoringAsciiCase("mp4a");
+}
+
+bool IsPersonaStableMediaSourceContentType(const ContentType& content_type) {
+  if (!IsPersonaStableMediaSourceMimeType(content_type.GetType())) {
+    return false;
+  }
+
+  const String codecs = content_type.Parameter("codecs");
+  if (codecs.empty()) {
+    return true;
+  }
+
+  for (StringView codec : StringView(codecs).Split(',')) {
+    if (!IsPersonaStableMediaSourceCodecToken(codec)) {
+      return false;
+    }
+  }
+
+  return true;
+}
+
