+    metadata.bitness = snapshot.ua_ch_bitness;
+  if (!snapshot.ua_ch_full_version.empty())
+    metadata.full_version = snapshot.ua_ch_full_version;
+
+  metadata.mobile = snapshot.ua_ch_mobile;
+  metadata.wow64 = snapshot.ua_ch_wow64;
+
+  if (!snapshot.ua_ch_form_factors.empty())
+    metadata.form_factors = snapshot.ua_ch_form_factors;
+
+  if (!snapshot.ua_ch_brands.empty()) {
+    metadata.brand_version_list.clear();
+    metadata.brand_full_version_list.clear();
+    for (const auto& brand : snapshot.ua_ch_brands) {
+      metadata.brand_version_list.emplace_back(brand.brand, brand.version);
+      metadata.brand_full_version_list.emplace_back(brand.brand,
+                                                    brand.version);
+    }
+  }
+
+  return metadata;
+}
