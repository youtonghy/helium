+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "third_party/blink/public/web/web_time_zone_override.h"
+
+#include <utility>
+
+#include "base/containers/span.h"
+#include "third_party/blink/renderer/core/timezone/timezone_controller.h"
+#include "third_party/blink/renderer/platform/wtf/text/wtf_string.h"
+
+namespace blink {
+
+class WebTimeZoneOverride::Impl {
+ public:
+  bool SetOrChange(const std::string& timezone) {
+    String tz_blink = String::FromUtf8(base::as_byte_span(timezone));
+    if (handle_) {
+      handle_->change(tz_blink);
+      return true;
+    }
+
+    auto result = TimeZoneController::SetTimeZoneOverride(tz_blink);
+    if (result.status !=
+        TimeZoneController::TimeZoneOverrideStatus::kSuccess) {
+      return false;
+    }
+    handle_ = std::move(result.handle);
+    return true;
+  }
+
+  void Clear() { handle_.reset(); }
+
+ private:
+  std::unique_ptr<TimeZoneController::TimeZoneOverride> handle_;
+};
+
+WebTimeZoneOverride::WebTimeZoneOverride() : impl_(std::make_unique<Impl>()) {}
+
+WebTimeZoneOverride::~WebTimeZoneOverride() = default;
+
+bool WebTimeZoneOverride::SetOrChange(const std::string& timezone) {
+  return impl_->SetOrChange(timezone);
+}
+
+void WebTimeZoneOverride::Clear() {
+  impl_->Clear();
+}
+
+}  // namespace blink
