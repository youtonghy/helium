+// handle on behalf of every RenderFrameImpl in this renderer.
+//
+// blink::TimeZoneController enforces exclusive single-owner semantics: only one
+// override may be active per renderer process. If each RenderFrameImpl held its
+// own handle they would clobber one another (a second acquirer receives
+// kAlreadyInEffect and silently renders the first frame's timezone, and the
+// first frame's teardown clears the override for everyone else). This
+// coordinator reconciles every frame's desired timezone into exactly one
+// handle.
+//
+// Conflict policy: when multiple frames request different timezones, the main
+// frame's timezone wins; otherwise the most recently registered non-main frame
+// wins. The handle is released (restoring the host timezone) only when no
+// remaining frame wants an override.
+//
+// Not thread-safe; all methods must be called on the renderer main thread
+// (PrepareFrameForCommitment and WillDetach both run there).
+class PersonaTimezoneCoordinator {
+ public:
+  PersonaTimezoneCoordinator(const PersonaTimezoneCoordinator&) = delete;
+  PersonaTimezoneCoordinator& operator=(const PersonaTimezoneCoordinator&) =
+      delete;
+
+  static PersonaTimezoneCoordinator& GetInstance();
+
+  // Records |frame|'s desired timezone. An empty |timezone| means "this frame
+  // wants no override" (equivalent to Clear). Recomputes and drives the single
+  // global handle.
+  void Update(RenderFrameImpl* frame, const std::string& timezone);
+
+  // Removes |frame| from tracking. Called from RenderFrameImpl::WillDetach,
+  // before the frame is destroyed. Idempotent.
+  void Clear(RenderFrameImpl* frame);
+
+ private:
+  friend class base::NoDestructor<PersonaTimezoneCoordinator>;
+
+  PersonaTimezoneCoordinator();
+  ~PersonaTimezoneCoordinator() = default;
+
+  // Reads |desired_| and acquires / changes / releases the global handle.
+  void Recompute();
+
+  // Returns the effective timezone, or empty if no frame wants an override.
+  std::string PickEffective();
+
+  // Desired timezones keyed by frame. Cleared in WillDetach before the
+  // RenderFrameImpl is destroyed, so entries never dangle.
+  std::vector<std::pair<raw_ptr<RenderFrameImpl>, std::string>> desired_;
+
+  // The single process-wide handle. Active iff at least one frame wants an
+  // override and Blink accepted the requested timezone.
+  blink::WebTimeZoneOverride override_;
+};
+
+}  // namespace content
+
+#endif  // CONTENT_RENDERER_PERSONA_TIMEZONE_COORDINATOR_H_
