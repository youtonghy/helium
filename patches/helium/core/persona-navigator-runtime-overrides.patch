+#include "content/renderer/persona_timezone_coordinator.h"
+
+#include <algorithm>
+#include <utility>
+
+#include "content/renderer/render_frame_impl.h"
+
+namespace content {
+
+// static
+PersonaTimezoneCoordinator& PersonaTimezoneCoordinator::GetInstance() {
+  static base::NoDestructor<PersonaTimezoneCoordinator> instance;
+  return *instance;
+}
+
+PersonaTimezoneCoordinator::PersonaTimezoneCoordinator() = default;
+
+void PersonaTimezoneCoordinator::Update(RenderFrameImpl* frame,
+                                        const std::string& timezone) {
+  DCHECK(frame);
+  auto it = std::find_if(
+      desired_.begin(), desired_.end(),
+      [frame](const auto& entry) { return entry.first.get() == frame; });
+  if (timezone.empty()) {
+    if (it != desired_.end()) {
+      desired_.erase(it);
+    }
+  } else if (it != desired_.end()) {
+    it->second = timezone;
+  } else {
+    desired_.emplace_back(frame, timezone);
+  }
+  Recompute();
+}
+
+void PersonaTimezoneCoordinator::Clear(RenderFrameImpl* frame) {
+  std::erase_if(desired_,
+                [frame](const auto& entry) { return entry.first.get() == frame; });
+  Recompute();
+}
+
+std::string PersonaTimezoneCoordinator::PickEffective() {
+  std::string last;
+  for (const auto& [frame, timezone] : desired_) {
+    // The main frame's timezone wins outright.
+    if (frame->IsMainFrame()) {
+      return timezone;
+    }
+    last = timezone;
+  }
+  return last;
+}
+
+void PersonaTimezoneCoordinator::Recompute() {
+  std::string effective = PickEffective();
+
+  if (effective.empty()) {
+    // No frame needs an override: release the single handle, which restores
+    // the host timezone process-wide.
+    override_.Clear();
+    return;
+  }
+
+  // If a non-persona owner (e.g. DevTools emulation) already holds the
+  // override, Blink rejects this request and persona timezone remains
+  // best-effort relative to that session.
+  override_.SetOrChange(effective);
+}
+
+}  // namespace content
