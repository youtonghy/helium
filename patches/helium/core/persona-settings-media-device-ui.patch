+  private applyRandomMediaDevices_(persona: PersonaRecord) {
+    const osFamily = this.personaOsFamily_(persona);
+    const screen = persona.screen || {};
+    const screenWidth = this.numberValue_(screen['width']);
+    const screenHeight = this.numberValue_(screen['height']);
+    const commonVideoProfiles = [
+      {width: 1280, height: 720, frameRate: 30},
+      {width: 1920, height: 1080, frameRate: 30},
+      {width: 1280, height: 720, frameRate: 60},
+    ].filter(profile =>
+        (!screenWidth || profile.width <= screenWidth) &&
+        (!screenHeight || profile.height <= screenHeight));
+    const macLabels = [
+      ['MacBook Pro Microphone', 'FaceTime HD Camera', 'MacBook Pro Speakers'],
+      ['MacBook Air Microphone', 'FaceTime HD Camera', 'MacBook Air Speakers'],
+      ['Studio Display Microphone', 'Studio Display Camera', 'Studio Display Speakers'],
+    ];
+    const windowsLabels = [
+      ['Microphone Array', 'Integrated Camera', 'Speakers'],
+      ['Realtek Audio Microphone', 'USB2.0 HD UVC WebCam', 'Realtek Audio Speakers'],
+      ['Microphone', 'HD Webcam', 'Headphones'],
+    ];
+    const linuxLabels = [
+      ['Built-in Audio Analog Stereo', 'Integrated Camera', 'Built-in Audio Analog Stereo'],
+      [
+        'alsa_input.pci-0000_00_1f.3.analog-stereo',
+        'HD WebCam',
+        'alsa_output.pci-0000_00_1f.3.analog-stereo',
+      ],
+      ['Microphone', 'USB Camera', 'Speakers'],
+    ];
+    const labels = osFamily === 'mac' ? macLabels :
+        osFamily === 'linux' ? linuxLabels : windowsLabels;
+    const selectedLabels = this.randomFrom_(labels, labels[0]);
+    const video = this.randomFrom_(commonVideoProfiles, commonVideoProfiles[0]);
+    const sampleRate = this.randomFrom_([48000, 48000, 44100], 48000);
+    const channelCount = this.randomFrom_([1, 2, 2], 2);
+    const audioLatency =
+        this.randomFrom_([0.005, 0.01, 0.015, 0.02], 0.01);
+    const baseLatency =
+        this.randomFrom_([0.005, 0.01, 0.012, 0.02], 0.01);
+    const outputLatency =
+        this.randomFrom_([0.02, 0.03, 0.04, 0.08], 0.02);
+    persona.mediaDevices = this.makeMediaDeviceProfile_(
+        selectedLabels[0], selectedLabels[1], selectedLabels[2],
