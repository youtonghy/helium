+scoped_refptr<StaticBitmapImage> ApplyHeliumCanvasNoiseForExport(
+    scoped_refptr<StaticBitmapImage> image_bitmap,
+    ExecutionContext* execution_context) {
+  if (!execution_context || !execution_context->CanvasNoiseToken())
+    return image_bitmap;
+
+  const gfx::Size size = image_bitmap->Size();
+  const SkImageInfo info =
+      SkImageInfo::MakeN32Premul(size.width(), size.height());
+  Vector<uint8_t> pixels =
+      image_bitmap->CopyImageData(info, /*apply_orientation=*/false);
+  if (pixels.empty())
+    return image_bitmap;
+
+  NoisePixels(NoiseHash(*execution_context->CanvasNoiseToken()),
+              base::span(pixels), size.width(), size.height());
+
+  scoped_refptr<StaticBitmapImage> noisy_bitmap = StaticBitmapImage::Create(
+      SkData::MakeWithCopy(pixels.data(), pixels.size()), info,
+      image_bitmap->Orientation());
+  noisy_bitmap->SetOriginClean(image_bitmap->OriginClean());
+  return noisy_bitmap;
+}
