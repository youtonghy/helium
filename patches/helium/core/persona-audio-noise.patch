 namespace {

+constexpr uint64_t kFnvPrime = 0x00000100000001b3;
+
+uint64_t MixHeliumAudioNoise(uint64_t hash, uint64_t value) {
+  hash ^= value;
+  hash *= kFnvPrime;
+  return hash;
+}
+
+void ApplyHeliumAudioNoise(AudioBuffer* rendered_buffer, NoiseToken token) {
+  const uint64_t token_hash = token.Value();
+  for (uint32_t channel = 0; channel < rendered_buffer->numberOfChannels();
+       ++channel) {
+    base::span<float> samples =
+        rendered_buffer->getChannelData(channel)->AsSpan();
+    const uint64_t channel_hash = MixHeliumAudioNoise(token_hash, channel + 1);
+    for (size_t i = 0; i < samples.size(); ++i) {
+      const float sample = samples[i];
+      if (!std::isfinite(sample) || sample == 0.0f)
+        continue;
+
+      uint64_t sample_hash = MixHeliumAudioNoise(channel_hash, i + 1);
+      const float target = (sample_hash & 1)
+                               ? std::numeric_limits<float>::infinity()
+                               : -std::numeric_limits<float>::infinity();
+      float jittered = sample;
+      const uint64_t ulp_steps = ((sample_hash >> 1) % 31) + 1;
+      for (uint64_t step = 0; step < ulp_steps; ++step)
+        jittered = std::nextafter(jittered, target);
+      samples[i] = jittered;
+    }
+  }
+}
