+TEST(HeliumPersonaPrefsTest, BuiltinFontPackProfilesCoverPresetFontPacks) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  base::Value::List profiles = GetBuiltinFontPackProfiles();
+
+  for (const base::Value& value : presets) {
+    const base::Value::Dict* preset = value.GetIfDict();
+    ASSERT_TRUE(preset);
+    if (preset->FindBool("passthrough").value_or(false)) {
+      continue;
+    }
+    const base::Value::Dict* fonts = preset->FindDict("fonts");
+    ASSERT_TRUE(fonts);
+    const std::string* font_pack_id = fonts->FindString("id");
+    ASSERT_TRUE(font_pack_id);
+    EXPECT_TRUE(ProfilesContainId(profiles, *font_pack_id)) << *font_pack_id;
+  }
+}
