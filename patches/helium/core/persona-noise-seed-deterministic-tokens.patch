 // Derives a token by combining a browser context token with origin- and
 // persona-specific strings. This makes tokens unique per-origin and per-persona,
 // but consistent within the same BrowserContext/persona pair.
+blink::HeliumNoiseToken FinishDerivedToken(crypto::hash::Hasher& hasher) {
+  uint64_t token_hash = kFnvOffset;
+  std::array<uint8_t, crypto::hash::kSha256Size> digest;
+  hasher.Finish(digest);
+
+  token_hash ^= base::U64FromLittleEndian(base::span(digest).first<8>());
+  token_hash *= kFnvPrime;
+
+  return blink::HeliumNoiseToken(token_hash);
+}
+
+std::string_view FeatureSalt(blink::HeliumNoiseFeature feature) {
+  switch (feature) {
+    case blink::HeliumNoiseFeature::kCanvas:
+      return "canvas";
+    case blink::HeliumNoiseFeature::kAudio:
+      return "audio";
+    case blink::HeliumNoiseFeature::kHardware:
+      return "hardware";
+  }
+  return "unknown";
+}
+
 blink::HeliumNoiseToken DeriveToken(blink::HeliumNoiseToken token,
                                     std::string_view domain,
                                     std::string_view persona_salt) {
-  uint64_t token_hash = kFnvOffset;
   crypto::hash::Hasher hasher(crypto::hash::kSha256);
 
   hasher.Update(base::U64ToLittleEndian(token.Value()));
   hasher.Update(base::as_byte_span(domain));
   hasher.Update(base::as_byte_span(persona_salt));
 
-  std::array<uint8_t, crypto::hash::kSha256Size> digest;
-  hasher.Finish(digest);
-
-  token_hash ^= base::U64FromLittleEndian(base::span(digest).first<8>());
-  token_hash *= kFnvPrime;
-
-  return blink::HeliumNoiseToken(token_hash);
+  return FinishDerivedToken(hasher);
+}
+
+blink::HeliumNoiseToken DeriveSeededPersonaToken(
+    std::string_view noise_seed,
+    blink::HeliumNoiseFeature feature,
+    std::string_view domain,
+    std::string_view persona_salt) {
+  crypto::hash::Hasher hasher(crypto::hash::kSha256);
+
+  hasher.Update(base::as_byte_span(noise_seed));
+  hasher.Update(base::as_byte_span(FeatureSalt(feature)));
+  hasher.Update(base::as_byte_span(domain));
+  hasher.Update(base::as_byte_span(persona_salt));
+
+  return FinishDerivedToken(hasher);
 }
