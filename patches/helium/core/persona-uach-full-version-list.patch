+base::Value::List MakeUaChFullVersionListFromBrands(
+    const base::Value::List& brands,
+    std::string_view full_version) {
+  base::Value::List full_versions;
+  for (const base::Value& value : brands) {
+    const base::Value::Dict* brand = value.GetIfDict();
+    const std::string* brand_name =
+        brand ? brand->FindString("brand") : nullptr;
+    const std::string* brand_version =
+        brand ? brand->FindString("version") : nullptr;
+    if (!brand_name || brand_name->empty()) {
+      continue;
+    }
+    base::Value::Dict full_version_entry;
+    full_version_entry.Set("brand", *brand_name);
+    const bool is_grease =
+        (brand_name->find("Not") != std::string::npos ||
+         brand_name->find("not") != std::string::npos) &&
+        (brand_name->find("Brand") != std::string::npos ||
+         brand_name->find("brand") != std::string::npos);
+    full_version_entry.Set(
+        "version", is_grease || full_version.empty()
+            ? (brand_version ? *brand_version : std::string())
+            : std::string(full_version));
+    full_versions.Append(std::move(full_version_entry));
+  }
+  return full_versions;
+}
