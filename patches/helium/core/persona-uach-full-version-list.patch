+      std::string clean_brand = TrimPersonaString(*brand_name);
+      std::string clean_version = TrimPersonaString(*version);
+      if (clean_brand.empty() || clean_version.empty()) {
+        continue;
+      }
+      base::Value::Dict clean_entry;
+      clean_entry.Set("brand", std::move(clean_brand));
+      clean_entry.Set("version", std::move(clean_version));
+      clean.Append(std::move(clean_entry));
+    }
+  }
+  if (!clean.empty()) {
+    ua_ch.Set("fullVersionList", std::move(clean));
+    return true;
+  }
+
+  const base::Value::List* brands = ua_ch.FindList("brands");
+  const std::string* full_version = ua_ch.FindString("fullVersion");
+  if (!brands || brands->empty() || !full_version) {
+    return false;
+  }
+  ua_ch.Set("fullVersionList",
+            MakeUaChFullVersionListFromBrands(*brands, *full_version));
+  return true;
+}
