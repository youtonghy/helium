+bool IsUaChGreaseBrand(const std::string& brand) {
+  return (brand.find("Not") != std::string::npos ||
+          brand.find("not") != std::string::npos) &&
+         (brand.find("Brand") != std::string::npos ||
+          brand.find("brand") != std::string::npos);
+}
+
+std::vector<PersonaUaChBrand> GetUaChFullVersionList(
+    const base::Value::Dict& persona,
+    const std::vector<PersonaUaChBrand>& brands,
+    const std::string& full_version) {
+  std::vector<PersonaUaChBrand> full_versions;
+  const base::Value::Dict* ua_ch = persona.FindDict("uaCh");
+  const base::Value::List* list =
+      ua_ch ? ua_ch->FindList("fullVersionList") : nullptr;
+  if (list) {
+    for (const base::Value& value : *list) {
+      const base::Value::Dict* dict = value.GetIfDict();
+      if (!dict) {
+        continue;
+      }
+      const std::string* brand = dict->FindString("brand");
+      const std::string* version = dict->FindString("version");
+      if (!brand || brand->empty() || !version || version->empty()) {
+        continue;
+      }
+      PersonaUaChBrand entry;
+      entry.brand = *brand;
+      entry.version = *version;
+      full_versions.push_back(std::move(entry));
+    }
+  }
+  if (!full_versions.empty()) {
+    return full_versions;
+  }
+
+  for (const PersonaUaChBrand& brand : brands) {
+    if (brand.brand.empty()) {
+      continue;
+    }
+    PersonaUaChBrand entry;
+    entry.brand = brand.brand;
+    entry.version =
+        !full_version.empty() && !IsUaChGreaseBrand(brand.brand) ? full_version
+                                                                 : brand.version;
+    full_versions.push_back(std::move(entry));
+  }
+  return full_versions;
+}
