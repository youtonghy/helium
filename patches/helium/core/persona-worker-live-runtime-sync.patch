+void UpdateHeliumPersonaWorkerNoiseTokensIfCurrent(
+    WorkerThread* worker_thread,
+    HeliumNoiseTokenMap old_noise_tokens,
+    HeliumNoiseTokenMap new_noise_tokens) {
+  DCHECK(worker_thread->IsCurrentThread());
+  WorkerOrWorkletGlobalScope* global_scope = worker_thread->GlobalScope();
+  if (!global_scope) {
+    return;
+  }
+
+  if (global_scope->GetHeliumNoiseTokens() == old_noise_tokens) {
+    global_scope->SetHeliumNoiseTokens(new_noise_tokens);
+  }
+}
