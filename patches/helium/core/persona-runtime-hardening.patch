+std::string ExtractMajorVersion(std::string_view version) {
+  size_t dot = version.find('.');
+  std::string_view major = dot == std::string_view::npos
+                               ? version
+                               : version.substr(0, dot);
+  return std::string(major);
+}
+
+std::string ExtractUaChromeMajor(std::string_view ua) {
+  constexpr std::string_view kToken = "Chrome/";
+  size_t token = ua.find(kToken);
+  if (token == std::string_view::npos) {
+    return std::string();
+  }
+  std::string_view version = ua.substr(token + kToken.size());
+  size_t end = version.find_first_of(" ;)/");
+  if (end != std::string_view::npos) {
+    version = version.substr(0, end);
+  }
+  return ExtractMajorVersion(version);
+}
+
+bool IsUaChGreaseBrand(std::string_view brand) {
+  return Contains(brand, "not") && Contains(brand, "brand");
+}
