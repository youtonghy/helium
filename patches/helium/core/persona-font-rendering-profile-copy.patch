+
+  private makeCustomFontRenderingId_(sourceId: string): string {
+    const slug = (sourceId || 'rendering')
+        .toLowerCase()
+        .replace(/[^a-z0-9]+/g, '-')
+        .replace(/^-+|-+$/g, '') || 'rendering';
+    const usedIds = new Set(
+        (this.fontRenderingProfiles_ || [])
+            .map(profile => String(profile['id'] || '')));
+    let candidate = `custom-${slug}`;
+    let suffix = 2;
+    while (usedIds.has(candidate)) {
+      candidate = `custom-${slug}-${suffix++}`;
+    }
+    return candidate;
+  }
+
+  private isBuiltinFontRenderingId_(profileId: string): boolean {
+    return (this.fontRenderingProfiles_ || []).some(profile =>
+        Boolean(profile['builtin']) && String(profile['id'] || '') === profileId);
+  }
+
+  private makeCustomFontRenderingProfile_(
+      sourceProfile: Record<string, unknown>): Record<string, unknown> {
+    const profile = JSON.parse(JSON.stringify(sourceProfile || {}));
+    const sourceId = String(profile['id'] || 'rendering');
+    profile['id'] = this.makeCustomFontRenderingId_(sourceId);
+    const displayName = String(profile['displayName'] || sourceId || 'Rendering');
+    profile['displayName'] = displayName.endsWith(' copy') ?
+        displayName : `${displayName} copy`;
+    profile['builtin'] = false;
+    profile['modified'] = true;
+    return profile;
+  }
+
+  private normalizeFontRenderingProfile_(profile: Record<string, unknown>) {
+    profile['textGamma'] = Number(profile['textGamma'] || 0);
+    profile['textContrast'] = Number(profile['textContrast'] || 0);
+    profile['antialiasing'] = Boolean(profile['antialiasing']);
+    profile['subpixelRendering'] = Boolean(profile['subpixelRendering']);
+    profile['subpixelPositioning'] = Boolean(profile['subpixelPositioning']);
+    profile['lcdText'] = Boolean(profile['lcdText']);
+    profile['useAutohinter'] = Boolean(profile['useAutohinter']);
+    profile['useBitmaps'] = Boolean(profile['useBitmaps']);
+    profile['builtin'] = false;
+    profile['modified'] = true;
+    if (!profile['id'] || this.isBuiltinFontRenderingId_(String(profile['id']))) {
+      profile['id'] = this.makeCustomFontRenderingId_(String(profile['id'] || 'rendering'));
+      const displayName = String(profile['displayName'] || profile['id']);
+      profile['displayName'] = displayName.endsWith(' copy') ?
+          displayName : `${displayName} copy`;
+    }
+  }
