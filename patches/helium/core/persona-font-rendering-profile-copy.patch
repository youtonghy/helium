+bool CustomFontRenderingProfileIdExists(const PrefService& pref_service,
+                                        std::string_view profile_id) {
+  const base::Value::List& profiles =
+      pref_service.GetList(prefs::kHeliumCustomFontRenderingProfiles);
+  return FindPersonaInList(profiles, profile_id) != nullptr;
+}
+
+bool IsBuiltinFontRenderingProfileId(std::string_view profile_id) {
+  base::Value::List profiles = GetBuiltinFontRenderingProfiles();
+  return FindPersonaInList(profiles, profile_id) != nullptr;
+}
+
+std::string MakeCustomFontRenderingProfileId(const PrefService& pref_service,
+                                             std::string_view profile_id) {
+  std::string base_id = profile_id.empty() ? "rendering" : std::string(profile_id);
+  std::string candidate = base::StringPrintf("custom-%s", base_id.c_str());
+  int suffix = 2;
+  while (IsBuiltinFontRenderingProfileId(candidate) ||
+         CustomFontRenderingProfileIdExists(pref_service, candidate)) {
+    candidate = base::StringPrintf("custom-%s-%d", base_id.c_str(), suffix++);
+  }
+  return candidate;
+}
