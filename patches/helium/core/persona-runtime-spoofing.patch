+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "third_party/blink/renderer/core/helium_persona/persona_spoofing_helper.h"
+
+#include <algorithm>
+
+#include "third_party/blink/renderer/core/execution_context/execution_context.h"
+
+namespace blink {
+
+namespace {
+
+String ToBlinkString(const std::string& value) {
+  return String::FromUtf8(value);
+}
+
+std::optional<int> PositiveInt(int value) {
+  if (value <= 0) {
+    return std::nullopt;
+  }
+  return value;
+}
+
+std::optional<unsigned> PositiveUnsigned(int value) {
+  if (value <= 0) {
+    return std::nullopt;
+  }
+  return static_cast<unsigned>(value);
+}
+
+}  // namespace
+
+const HeliumPersonaSnapshot* PersonaSpoofingHelper::Get(
+    const ExecutionContext* context) {
+  if (!context) {
+    return nullptr;
+  }
+  const HeliumPersonaSnapshot& snapshot = context->GetHeliumPersonaSnapshot();
+  return snapshot.IsEnabled() ? &snapshot : nullptr;
+}
+
+bool PersonaSpoofingHelper::IsEnabled(const ExecutionContext* context) {
+  return Get(context);
+}
+
+String PersonaSpoofingHelper::UserAgent(const ExecutionContext* context,
+                                        const String& fallback) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->user_agent.empty()) {
+    return fallback;
+  }
+  return ToBlinkString(snapshot->user_agent);
+}
+
+String PersonaSpoofingHelper::Platform(const ExecutionContext* context,
+                                       const String& fallback) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->platform.empty()) {
+    return fallback;
+  }
+  return ToBlinkString(snapshot->platform);
+}
+
+Vector<String> PersonaSpoofingHelper::NavigatorLanguages(
+    const ExecutionContext* context) {
+  Vector<String> languages;
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return languages;
+  }
+  for (const std::string& language : snapshot->navigator_languages) {
+    if (!language.empty()) {
+      languages.push_back(ToBlinkString(language));
+    }
+  }
+  if (languages.empty() && !snapshot->locale.empty()) {
+    languages.push_back(ToBlinkString(snapshot->locale));
+  }
+  return languages;
+}
+
+bool PersonaSpoofingHelper::ClientHintsEnabled(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return !snapshot || snapshot->client_hints_enabled;
+}
+
+bool PersonaSpoofingHelper::ReduceSystemInfo(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return snapshot && snapshot->reduce_system_info;
+}
+
+bool PersonaSpoofingHelper::CanvasNoiseEnabled(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return !snapshot || snapshot->canvas_noise;
+}
+
+bool PersonaSpoofingHelper::AudioNoiseEnabled(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return !snapshot || snapshot->audio_noise;
+}
+
+bool PersonaSpoofingHelper::FontMetricNoiseEnabled(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return !snapshot || snapshot->font_metric_noise;
+}
+
+std::optional<unsigned> PersonaSpoofingHelper::HardwareConcurrency(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return std::nullopt;
+  }
+  return PositiveUnsigned(snapshot->hardware_concurrency);
+}
+
+std::optional<float> PersonaSpoofingHelper::DeviceMemory(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->device_memory <= 0) {
+    return std::nullopt;
+  }
+  return static_cast<float>(snapshot->device_memory);
+}
+
+std::optional<int> PersonaSpoofingHelper::MaxTouchPoints(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return std::nullopt;
+  }
+  if (!snapshot->touch_enabled) {
+    return 0;
+  }
+  return std::max(1, snapshot->max_touch_points);
+}
+
+std::optional<double> PersonaSpoofingHelper::DeviceScaleFactor(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->device_scale_factor <= 0) {
+    return std::nullopt;
+  }
+  return snapshot->device_scale_factor;
+}
+
+std::optional<int> PersonaSpoofingHelper::ScreenWidth(
