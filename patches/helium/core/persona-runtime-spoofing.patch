+base::ReadOnlySharedMemoryRegion CreatePersonaFontEnumerationRegion(
+    const blink::HeliumPersonaSnapshot& snapshot) {
+  if (!snapshot.IsEnabled() || snapshot.font_families.empty()) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+
+  blink::FontEnumerationTable table;
+  size_t virtual_font_index = 0;
+  for (const std::string& family : snapshot.font_families) {
+    if (family.empty()) {
+      continue;
+    }
+    blink::FontEnumerationTable_FontData* font = table.add_fonts();
+    font->set_postscript_name(
+        "HeliumPersona-Font-" + std::to_string(++virtual_font_index));
+    font->set_full_name(family);
+    font->set_family(family);
+    font->set_style("Regular");
+  }
+  if (table.fonts().empty()) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+
+  base::MappedReadOnlyRegion font_data_region =
+      base::ReadOnlySharedMemoryRegion::Create(table.ByteSizeLong());
+  if (!font_data_region.mapping.IsValid()) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+  base::span<uint8_t> font_mem(font_data_region.mapping);
+  if (!table.SerializeToArray(font_mem.data(), font_mem.size())) {
+    return base::ReadOnlySharedMemoryRegion();
+  }
+  return std::move(font_data_region.region);
+}
