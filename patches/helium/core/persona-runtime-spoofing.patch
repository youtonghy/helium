+}
+
+std::optional<String> PersonaSpoofingHelper::WebGLVendor(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->gpu_vendor.empty()) {
+    return std::nullopt;
+  }
+  return ToBlinkString(snapshot->gpu_vendor);
+}
+
+std::optional<String> PersonaSpoofingHelper::WebGLRenderer(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->gpu_renderer.empty()) {
+    return std::nullopt;
+  }
+  return ToBlinkString(snapshot->gpu_renderer);
+}
+
+std::optional<String> PersonaSpoofingHelper::WebGPUAdapter(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return std::nullopt;
+  }
+  if (!snapshot->webgpu_adapter.empty()) {
+    return ToBlinkString(snapshot->webgpu_adapter);
+  }
+  if (!snapshot->gpu_renderer.empty()) {
+    return ToBlinkString(snapshot->gpu_renderer);
+  }
+  return std::nullopt;
+}
+
+std::optional<String> PersonaSpoofingHelper::GPUDriver(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot || snapshot->gpu_driver.empty()) {
+    return std::nullopt;
+  }
+  return ToBlinkString(snapshot->gpu_driver);
+}
+
+Vector<String> PersonaSpoofingHelper::FontFamilies(
+    const ExecutionContext* context) {
+  Vector<String> families;
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  if (!snapshot) {
+    return families;
+  }
+  for (const std::string& family : snapshot->font_families) {
+    if (!family.empty()) {
+      families.push_back(ToBlinkString(family));
+    }
+  }
+  return families;
+}
+
+bool PersonaSpoofingHelper::IsVirtualFontPostscriptName(
+    const String& postscript_name) {
+  return postscript_name.starts_with("HeliumPersona-");
+}
