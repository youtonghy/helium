+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return snapshot ? PositiveInt(snapshot->screen_width) : std::nullopt;
+}
+
+std::optional<int> PersonaSpoofingHelper::ScreenHeight(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
