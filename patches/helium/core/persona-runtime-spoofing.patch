+std::optional<unsigned> PersonaSpoofingHelper::ScreenColorDepth(
+    const ExecutionContext* context) {
+  const HeliumPersonaSnapshot* snapshot = Get(context);
+  return snapshot ? PositiveUnsigned(snapshot->color_depth) : std::nullopt;
+}
+
+std::optional<unsigned> PersonaSpoofingHelper::ScreenPixelDepth(
+    const ExecutionContext* context) {
