+  target.ua_ch_platform_version = source.ua_ch_platform_version;
+  target.ua_ch_architecture = source.ua_ch_architecture;
+  target.ua_ch_bitness = source.ua_ch_bitness;
+  target.ua_ch_model = source.ua_ch_model;
+  target.ua_ch_mobile = source.ua_ch_mobile;
+  target.timezone = source.timezone;
+  target.locale = source.locale;
+  target.accept_language = source.accept_language;
+  target.navigator_languages = source.navigator_languages;
+  target.gpu_vendor = source.gpu_vendor;
+  target.gpu_renderer = source.gpu_renderer;
+  target.webgpu_adapter = source.webgpu_adapter;
+  target.gpu_driver = source.gpu_driver;
+  target.screen_width = source.screen_width;
+  target.screen_height = source.screen_height;
+  target.avail_width = source.avail_width;
+  target.avail_height = source.avail_height;
+  target.device_scale_factor = source.device_scale_factor;
+  target.color_depth = source.color_depth;
+  target.pixel_depth = source.pixel_depth;
+  target.refresh_rate = source.refresh_rate;
+  target.hardware_concurrency = source.hardware_concurrency;
+  target.device_memory = source.device_memory;
+  target.touch_enabled = source.touch_enabled;
