+bool EnumerationExposesMediaDeviceInfo(
+    const Vector<Vector<WebMediaDeviceInfo>>& enumeration) {
+  for (const auto& devices : enumeration) {
+    for (const auto& device : devices) {
+      if (!device.device_id.empty() || !device.label.empty() ||
+          !device.group_id.empty()) {
+        return true;
+      }
+    }
+  }
+  return false;
+}
+
+void ApplyPersonaMediaDevicePermissionVisibility(
+    Vector<Vector<WebMediaDeviceInfo>>& enumeration,
+    bool expose_device_info) {
+  if (expose_device_info) {
+    return;
+  }
+
+  for (auto& devices : enumeration) {
+    for (auto& device : devices) {
+      device.device_id.clear();
+      device.label.clear();
+      device.group_id.clear();
+      device.video_control_support = media::VideoCaptureControlSupport();
+      device.video_facing = mojom::blink::FacingMode::kNone;
+      device.availability.reset();
+    }
+  }
