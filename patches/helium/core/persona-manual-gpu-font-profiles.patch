+bool DeleteFontRenderingProfile(PrefService& pref_service,
+                                std::string_view profile_id) {
+  base::Value::List profiles = CloneCustomFontRenderingProfiles(pref_service);
+  bool removed = false;
+  for (auto it = profiles.begin(); it != profiles.end();) {
+    const base::Value::Dict* dict = it->GetIfDict();
+    const std::string* id = dict ? dict->FindString("id") : nullptr;
+    if (id && *id == profile_id) {
+      it = profiles.erase(it);
+      removed = true;
+    } else {
+      ++it;
+    }
+  }
+  if (!removed) {
+    return false;
