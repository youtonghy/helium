+TEST(HeliumPersonaPrefsTest, ValidationWarnsForInconsistentMacArchitecture) {
+  base::Value::List presets = GetBuiltinPersonaPresets();
+  base::Value::Dict persona = DictAt(presets, 2).Clone();
+  base::Value::Dict* ua_ch = persona.FindDict("uaCh");
+  ASSERT_TRUE(ua_ch);
+  ua_ch->Set("architecture", "x86");
+
+  base::Value::List warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "Apple Silicon macOS personas"));
+
+  ua_ch->Set("architecture", "arm");
+  base::Value::Dict* gpu = persona.FindDict("gpu");
+  ASSERT_TRUE(gpu);
+  gpu->Set("vendor", "AMD");
+  gpu->Set("renderer", "ANGLE (AMD, AMD Radeon Pro 5500M, Metal)");
+  gpu->Set("driver", "Metal");
+
+  warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "Intel or AMD macOS personas"));
+
+  gpu->Set("vendor", "Apple Inc.");
+  gpu->Set("renderer", "ANGLE (Apple, Apple M3, OpenGL)");
+  gpu->Set("driver", "OpenGL");
+  warnings = ValidatePersona(persona);
+  EXPECT_TRUE(WarningsContain(warnings, "Apple Silicon macOS GPU data"));
+}
