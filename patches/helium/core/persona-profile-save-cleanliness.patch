+  EXPECT_FALSE(preset_rendering->FindBool("builtin").has_value());
+  EXPECT_FALSE(preset_rendering->FindBool("modified").has_value());
+  EXPECT_FALSE(preset_rendering->FindDouble("updated").has_value());
