 constexpr uint64_t UndefinedLimitValue<uint64_t>() {
   return wgpu::kLimitU64Undefined;
 }
+
+bool IsMinimumAlignmentLimit(std::string_view name) {
+  return name == "minUniformBufferOffsetAlignment" ||
+         name == "minStorageBufferOffsetAlignment";
+}
+
+template <typename T>
+bool RequiredLimitSupported(std::string_view name, T required, T supported) {
+  if (required == UndefinedLimitValue<T>()) {
+    return true;
+  }
+  if (supported == UndefinedLimitValue<T>()) {
+    return false;
+  }
+  if (IsMinimumAlignmentLimit(name)) {
+    return required >= supported;
+  }
+  return required <= supported;
+}
