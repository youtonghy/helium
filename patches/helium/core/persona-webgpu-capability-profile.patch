 // GPUSupportedLimits
 
 GPUSupportedLimits::GPUSupportedLimits(const ComboLimits& limits) {
   limits.UnlinkedCopyTo(&limits_);
+}
+
+// static
+void GPUSupportedLimits::ApplyPersonaDefaults(ComboLimits* out) {
+  out->maxTextureDimension1D = 8192;
+  out->maxTextureDimension2D = 8192;
+  out->maxTextureDimension3D = 2048;
+  out->maxTextureArrayLayers = 256;
+  out->maxBindGroups = 4;
+  out->maxBindGroupsPlusVertexBuffers = 24;
+  out->maxBindingsPerBindGroup = 1000;
+  out->maxDynamicUniformBuffersPerPipelineLayout = 8;
+  out->maxDynamicStorageBuffersPerPipelineLayout = 4;
+  out->maxSampledTexturesPerShaderStage = 16;
+  out->maxSamplersPerShaderStage = 16;
+  out->maxStorageBuffersPerShaderStage = 8;
+  out->maxStorageTexturesPerShaderStage = 4;
+  out->maxUniformBuffersPerShaderStage = 12;
+  out->maxUniformBufferBindingSize = 65536;
+  out->maxStorageBufferBindingSize = 134217728;
+  out->minUniformBufferOffsetAlignment = 256;
+  out->minStorageBufferOffsetAlignment = 256;
+  out->maxVertexBuffers = 8;
+  out->maxBufferSize = 268435456;
+  out->maxVertexAttributes = 16;
+  out->maxVertexBufferArrayStride = 2048;
+  out->maxInterStageShaderVariables = 16;
+  out->maxColorAttachments = 8;
+  out->maxColorAttachmentBytesPerSample = 32;
+  out->maxComputeWorkgroupStorageSize = 16384;
+  out->maxComputeInvocationsPerWorkgroup = 256;
+  out->maxComputeWorkgroupSizeX = 256;
+  out->maxComputeWorkgroupSizeY = 256;
+  out->maxComputeWorkgroupSizeZ = 64;
+  out->maxComputeWorkgroupsPerDimension = 65535;
+  out->maxStorageBuffersInFragmentStage = 8;
+  out->maxStorageTexturesInFragmentStage = 4;
+  out->maxStorageBuffersInVertexStage = 8;
+  out->maxStorageTexturesInVertexStage = 4;
+  out->maxImmediateSize = 0;
+}
+
+bool GPUSupportedLimits::SupportsRequiredLimits(
+    const ComboLimits& required_limits,
+    String* unsupported_limit_name) const {
+#define X(name)                                                            \
+  if (!RequiredLimitSupported(#name, required_limits.name, limits_.name)) { \
+    if (unsupported_limit_name) {                                           \
+      *unsupported_limit_name = String::FromUTF8(#name);                    \
+    }                                                                       \
+    return false;                                                           \
+  }
+  SUPPORTED_LIMITS(X)
+#undef X
+  return true;
 }
 
