+std::optional<blink::mojom::FontEnumerationStatus> PersonaFontEnumerationStatus(
+    const blink::HeliumPersonaSnapshot& snapshot,
+    base::ReadOnlySharedMemoryRegion* region) {
+  if (!snapshot.IsEnabled()) {
+    return std::nullopt;
+  }
+
+  *region = CreatePersonaFontEnumerationRegion(snapshot);
+  if (region->IsValid()) {
+    return blink::mojom::FontEnumerationStatus::kOk;
+  }
+
+  if (!snapshot.allow_local_fonts) {
+    return blink::mojom::FontEnumerationStatus::kPermissionDenied;
+  }
+
+  return std::nullopt;
+}
+
+bool PersonaBlocksLocalFontEnumeration(
+    const blink::HeliumPersonaSnapshot& snapshot) {
+  return snapshot.IsEnabled() && !snapshot.allow_local_fonts &&
+         snapshot.font_families.empty();
+}
