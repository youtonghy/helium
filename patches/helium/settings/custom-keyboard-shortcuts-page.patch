+  string display_text;
+  bool user_modifiable;
+};
+
+struct BrowserShortcutCommand {
+  int32 command_id;
+  string name;
+  bool modified;
+  array<BrowserShortcutAccelerator> accelerators;
+};
+
+struct BrowserShortcutsEvent {
+  map<int32, BrowserShortcutCommand> added_or_updated;
+  array<int32> removed;
+};
+
+enum BrowserShortcutAssignmentResult {
+  kSuccess,
+  kInvalidAccelerator,
+  kUnknownCommand,
+  kShortcutLocked,
+};
+
+struct BrowserShortcutAssignmentResponse {
+  BrowserShortcutAssignmentResult result;
+  int32 conflicting_command_id;
+  string conflicting_command_name;
+};
+
+interface BrowserShortcutsPage {
+  Changed(BrowserShortcutsEvent event);
+};
+
+interface BrowserShortcutsHandler {
+  GetCommands() => (array<BrowserShortcutCommand> commands);
+  AssignAcceleratorToCommand(int32 command_id, string serialized_accelerator) =>
+      (BrowserShortcutAssignmentResponse response);
+  UnassignAcceleratorFromCommand(
+      int32 command_id, string serialized_accelerator) => (bool success);
+  ResetAcceleratorsForCommand(int32 command_id) => (bool success);
+  ResetAccelerators() => ();
+  GetAcceleratorDisplayText(string serialized_accelerator) =>
+      (string display_text);
+};
+
+interface BrowserShortcutsHandlerFactory {
+  CreateBrowserShortcutsHandler(
+      pending_remote<BrowserShortcutsPage> page,
