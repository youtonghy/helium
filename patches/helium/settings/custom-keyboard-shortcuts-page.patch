+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/settings/browser_shortcuts_handler.h"
+
+#include <algorithm>
+#include <optional>
+#include <string>
+#include <utility>
+
+#include "base/strings/utf_string_conversions.h"
+#include "build/build_config.h"
+#include "chrome/browser/ui/browser_shortcuts/browser_shortcut_serialization.h"
+
+namespace settings {
+
+namespace {
+
+mojom::BrowserShortcutAssignmentResult ToMojomResult(
+    browser_shortcuts::AssignmentResult result) {
+  switch (result) {
+    case browser_shortcuts::AssignmentResult::kSuccess:
+      return mojom::BrowserShortcutAssignmentResult::kSuccess;
+    case browser_shortcuts::AssignmentResult::kInvalidAccelerator:
+      return mojom::BrowserShortcutAssignmentResult::kInvalidAccelerator;
+    case browser_shortcuts::AssignmentResult::kUnknownCommand:
+      return mojom::BrowserShortcutAssignmentResult::kUnknownCommand;
+    case browser_shortcuts::AssignmentResult::kShortcutLocked:
+      return mojom::BrowserShortcutAssignmentResult::kShortcutLocked;
+  }
+}
+
+std::string GetCommandName(
+    const std::vector<browser_shortcuts::CommandInfo>& commands,
+    int command_id) {
+  auto it = std::ranges::find(commands, command_id,
+                              &browser_shortcuts::CommandInfo::command_id);
+  return it == commands.end() ? std::string() : base::UTF16ToUTF8(it->name);
+}
+
+}  // namespace
+
+BrowserShortcutsHandler::BrowserShortcutsHandler(
+    mojo::PendingRemote<mojom::BrowserShortcutsPage> page,
+    mojo::PendingReceiver<mojom::BrowserShortcutsHandler> receiver,
+    browser_shortcuts::BrowserShortcutService* service)
+    : page_(std::move(page)),
+      receiver_(this, std::move(receiver)),
+      service_(service) {
+  service_->AddObserver(this);
+}
+
+BrowserShortcutsHandler::~BrowserShortcutsHandler() {
+  service_->RemoveObserver(this);
+}
+
+void BrowserShortcutsHandler::GetCommands(GetCommandsCallback callback) {
+  std::vector<mojom::BrowserShortcutCommandPtr> commands;
+  for (const browser_shortcuts::CommandInfo& command :
+       service_->GetCommands()) {
+    commands.push_back(MakeCommand(command));
+  }
+  std::move(callback).Run(std::move(commands));
+}
+
+void BrowserShortcutsHandler::AssignAcceleratorToCommand(
+    int32_t command_id,
+    const std::string& serialized_accelerator,
+    AssignAcceleratorToCommandCallback callback) {
+  std::optional<int> conflicting_command_id =
+      service_->FindCommandForAccelerator(serialized_accelerator);
+  std::string conflicting_command_name;
+  if (conflicting_command_id && *conflicting_command_id != command_id) {
+    conflicting_command_name =
+        GetCommandName(service_->GetCommands(), *conflicting_command_id);
+  }
+  browser_shortcuts::AssignmentResult result =
+      service_->AssignAcceleratorToCommand(command_id, serialized_accelerator);
+
+  auto response = mojom::BrowserShortcutAssignmentResponse::New();
+  response->result = ToMojomResult(result);
+  response->conflicting_command_id = -1;
+  if (conflicting_command_id && *conflicting_command_id != command_id) {
+    response->conflicting_command_id = *conflicting_command_id;
+    response->conflicting_command_name = std::move(conflicting_command_name);
+  }
+#if BUILDFLAG(IS_MAC)
+  if (result == browser_shortcuts::AssignmentResult::kShortcutLocked &&
+      response->conflicting_command_name.empty()) {
+    response->conflicting_command_name = "macOS";
+  }
+#endif
+  std::move(callback).Run(std::move(response));
+}
+
+void BrowserShortcutsHandler::UnassignAcceleratorFromCommand(
+    int32_t command_id,
+    const std::string& serialized_accelerator,
+    UnassignAcceleratorFromCommandCallback callback) {
+  std::move(callback).Run(service_->UnassignAcceleratorFromCommand(
+      command_id, serialized_accelerator));
+}
+
+void BrowserShortcutsHandler::ResetAcceleratorsForCommand(
+    int32_t command_id,
+    ResetAcceleratorsForCommandCallback callback) {
+  std::move(callback).Run(service_->ResetAcceleratorsForCommand(command_id));
+}
+
+void BrowserShortcutsHandler::ResetAccelerators(
+    ResetAcceleratorsCallback callback) {
+  service_->ResetAccelerators();
+  std::move(callback).Run();
+}
+
+void BrowserShortcutsHandler::GetAcceleratorDisplayText(
+    const std::string& serialized_accelerator,
+    GetAcceleratorDisplayTextCallback callback) {
+  std::optional<ui::Accelerator> accelerator =
+      browser_shortcuts::AcceleratorFromString(serialized_accelerator);
+  std::move(callback).Run(
+      accelerator
+          ? base::UTF16ToUTF8(
+                browser_shortcuts::AcceleratorToDisplayString(*accelerator))
+          : std::string());
+}
+
+void BrowserShortcutsHandler::OnBrowserShortcutsChanged() {
+  if (page_.is_bound()) {
+    page_->Changed(MakeFullEvent());
+  }
+}
+
+mojom::BrowserShortcutCommandPtr BrowserShortcutsHandler::MakeCommand(
+    const browser_shortcuts::CommandInfo& command) const {
+  auto result = mojom::BrowserShortcutCommand::New();
+  result->command_id = command.command_id;
+  result->name = base::UTF16ToUTF8(command.name);
+  result->modified = command.modified;
+  for (const browser_shortcuts::ShortcutInfo& accelerator :
+       command.accelerators) {
+    auto item = mojom::BrowserShortcutAccelerator::New();
+    item->serialized_accelerator = accelerator.serialized;
+    item->display_text = base::UTF16ToUTF8(accelerator.display_text);
+    item->user_modifiable = accelerator.user_modifiable;
+    result->accelerators.push_back(std::move(item));
+  }
+  return result;
+}
+
+mojom::BrowserShortcutsEventPtr BrowserShortcutsHandler::MakeFullEvent() const {
+  auto event = mojom::BrowserShortcutsEvent::New();
+  for (const browser_shortcuts::CommandInfo& command :
+       service_->GetCommands()) {
+    event->added_or_updated.emplace(command.command_id, MakeCommand(command));
+  }
+  return event;
+}
+
+}  // namespace settings
