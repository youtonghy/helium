+bool ChromeOmniboxClient::ShouldUseMinimalLocationBar() const {
+  OmniboxController* omnibox_controller = location_bar_->GetOmniboxController();
+  OmniboxEditModel* edit_model =
+      omnibox_controller ? omnibox_controller->edit_model() : nullptr;
+  return edit_model && edit_model->focus_state() == OMNIBOX_FOCUS_NONE &&
+         GetPrefs()->GetBoolean(prefs::kHeliumMinimalLocationBar);
+}
