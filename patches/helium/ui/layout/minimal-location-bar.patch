+void OmniboxViewViews::UpdateSteadyStateTextAlignment() {
+  bool center_text = false;
+  if (controller()->edit_model()->focus_state() == OMNIBOX_FOCUS_NONE &&
+      !controller()->edit_model()->user_input_in_progress() &&
+      location_bar_view_ && location_bar_view_->GetProfile()) {
+    center_text = location_bar_view_->GetProfile()->GetPrefs()->GetBoolean(
+        prefs::kHeliumMinimalLocationBar);
+  }
+
+  SetHorizontalAlignment(center_text ? gfx::ALIGN_CENTER : gfx::ALIGN_LEFT);
+  set_placeholder_text_draw_flags(center_text ? gfx::Canvas::TEXT_ALIGN_CENTER
+                                              : gfx::Canvas::TEXT_ALIGN_LEFT);
+}
