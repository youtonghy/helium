+// Copyright 2026 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/views/helium/frame_corner_radius.h"
+
+#include "build/build_config.h"
+#include "chrome/browser/ui/layout_constants.h"
+
+int GetGenericFrameRadius() {
+  return 8;
+}
+
+#if !BUILDFLAG(IS_MAC)
+int GetSystemWindowRadius() {
+  return 8;
+}
+#endif
+
+int GetPaddedFrameRadius() {
+  return GetSystemWindowRadius() -
+         GetLayoutConstant(LayoutConstant::kHeliumBasePadding);
+}
